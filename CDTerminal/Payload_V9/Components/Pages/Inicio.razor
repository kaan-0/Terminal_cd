    private static void AplicarPerfil(
        TerminalSesion sesion,
        PerfilDispositivo perfil)
    {
        sesion.Configuracion.Velocidad = perfil.Velocidad;
        sesion.Configuracion.BitsDeDatos = perfil.BitsDeDatos;
        sesion.Configuracion.Paridad = perfil.Paridad;
        sesion.Configuracion.BitsDeParada = perfil.BitsDeParada;
        sesion.Configuracion.ControlDeFlujo = perfil.ControlDeFlujo;
        sesion.Configuracion.HabilitarDtr = perfil.HabilitarDtr;
        sesion.Configuracion.HabilitarRts = perfil.HabilitarRts;

        if (!string.IsNullOrWhiteSpace(perfil.PuertoPreferido) &&
            sesion.Puertos.Contains(
                perfil.PuertoPreferido,
                StringComparer.OrdinalIgnoreCase
            ))
        {
            sesion.PuertoSeleccionado = perfil.PuertoPreferido;
        }

        sesion.Configuracion.NombrePuerto =
            sesion.PuertoSeleccionado;

        sesion.IdEsclavoModbus = perfil.IdEsclavoModbus;
        sesion.TimeoutModbusMs = perfil.TimeoutModbusMs;
        sesion.ReintentosModbus = perfil.ReintentosModbus;
        sesion.FuncionModbus = perfil.FuncionModbus;
        sesion.DireccionInicialModbus = perfil.DireccionInicialModbus;
        sesion.CantidadRegistrosModbus = perfil.CantidadRegistrosModbus;
        sesion.IntervaloPollingModbusMs =
            perfil.IntervaloPollingModbusMs;
        sesion.DireccionRegistroGrafica =
            perfil.DireccionRegistroGrafica;
        sesion.MaxPuntosGrafica = perfil.MaxPuntosGrafica;

        sesion.TramaModbusPrevia = string.Empty;
        sesion.UltimaRespuestaModbus = string.Empty;
        sesion.CrcModbusValido = null;
        sesion.RegistrosModbus.Clear();
        sesion.MuestrasGrafica.Clear();
    }

