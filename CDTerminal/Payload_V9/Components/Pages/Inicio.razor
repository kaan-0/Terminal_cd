    private async Task EnviarTramaManualModbusAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (!ValidarDisponibilidadTramaManual(sesion))
        {
            return;
        }

        if (!TryPrepararTramaManual(
                sesion,
                out byte[] trama,
                out string descripcion,
                out string error))
        {
            sesion.UltimaEscrituraModbusExitosa = false;
            sesion.ResumenTramaManual = string.Empty;
            sesion.MensajeEstado = error;
            return;
        }

        sesion.TramaPreparadaModbus = ConvertirAHex(trama);
        sesion.RespuestaEscrituraModbus = string.Empty;
        sesion.CrcEscrituraModbusValido = null;
        sesion.UltimaEscrituraModbusExitosa = null;
        sesion.ResumenTramaManual = descripcion;

        byte funcion = trama[1];

        if (EsFuncionEscrituraModbus(funcion))
        {
            sesion.MostrarConfirmacionEscrituraModbus = true;
            sesion.MensajeEstado =
                "Revisa la trama final antes de confirmar la escritura.";
            return;
        }

        await TransmitirTramaManualModbusAsync(sesion, trama);
    }

    private void CancelarEnvioTramaManualModbus()
    {
        TerminalSesion sesion = SesionActiva;
        sesion.MostrarConfirmacionEscrituraModbus = false;
        sesion.MensajeEstado = "Envío de trama cancelado.";
    }

    private async Task ConfirmarEnvioTramaManualModbusAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (!TryParsearBytesHexadecimales(
                sesion.TramaPreparadaModbus,
                out byte[] trama,
                out string error))
        {
            sesion.MostrarConfirmacionEscrituraModbus = false;
            sesion.MensajeEstado =
                $"No se pudo recuperar la trama preparada: {error}";
            return;
        }

        sesion.MostrarConfirmacionEscrituraModbus = false;
        await TransmitirTramaManualModbusAsync(sesion, trama);
    }

    private void LimpiarTramaManualModbus()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.EscrituraModbusEnCurso)
        {
            return;
        }

        sesion.TramaEscrituraModbus = string.Empty;
        sesion.TramaPreparadaModbus = string.Empty;
        sesion.RespuestaEscrituraModbus = string.Empty;
        sesion.ResumenTramaManual = string.Empty;
        sesion.CrcEscrituraModbusValido = null;
        sesion.UltimaEscrituraModbusExitosa = null;
        sesion.MostrarConfirmacionEscrituraModbus = false;
        sesion.MensajeEstado = "Editor de trama Modbus limpio.";
    }

    private async Task TransmitirTramaManualModbusAsync(
        TerminalSesion sesion,
        byte[] solicitud)
    {
        if (!ValidarDisponibilidadTramaManual(sesion))
        {
            return;
        }

        sesion.TramaPreparadaModbus = ConvertirAHex(solicitud);
        sesion.RespuestaEscrituraModbus = string.Empty;
        sesion.CrcEscrituraModbusValido = null;
        sesion.UltimaEscrituraModbusExitosa = null;
        sesion.EscrituraModbusEnCurso = true;
        sesion.MensajeEstado =
            $"Enviando función Modbus 0x{solicitud[1]:X2}...";

        AgregarLineaTerminal(
            sesion,
            "SYS",
            $"Trama manual preparada · Función 0x{solicitud[1]:X2}."
        );

        await InvokeAsync(StateHasChanged);

        try
        {
            int reintentos = Math.Clamp(
                sesion.ReintentosModbus,
                0,
                10
            );

            int intentosTotales = reintentos + 1;
            Exception? ultimoError = null;

            for (int intento = 1;
                 intento <= intentosTotales;
                 intento++)
            {
                if (intento > 1)
                {
                    AgregarLineaTerminal(
                        sesion,
                        "SYS",
                        $"Reintento de trama {intento - 1} de {reintentos}."
                    );
                }

                AgregarLineaTerminal(
                    sesion,
                    "TX",
                    sesion.TramaPreparadaModbus
                );

                await InvokeAsync(StateHasChanged);

                try
                {
                    byte[] respuesta = await sesion.Servicio
                        .TransaccionModbusAsync(
                            solicitud,
                            Math.Clamp(
                                sesion.TimeoutModbusMs,
                                100,
                                10000
                            ),
                            CancellationToken.None
                        );

                    ProcesarRespuestaTramaManual(
                        sesion,
                        solicitud,
                        respuesta
                    );

                    sesion.UltimaEscrituraModbusExitosa = true;
                    sesion.UltimaEscrituraModbus = DateTime.Now;
                    sesion.MensajeEstado =
                        $"Respuesta Modbus recibida para función 0x{solicitud[1]:X2}.";

                    AgregarLineaTerminal(
                        sesion,
                        "SYS",
                        $"Trama manual confirmada · CRC correcto."
                    );

                    return;
                }
                catch (TimeoutException ex)
                {
                    ultimoError = ex;

                    if (intento < intentosTotales)
                    {
                        AgregarLineaTerminal(
                            sesion,
                            "SYS",
                            "Sin respuesta. Se repetirá el envío."
                        );
                    }
                }
            }

            throw ultimoError ?? new TimeoutException(
                "El dispositivo no respondió a la trama manual."
            );
        }
        catch (Exception ex)
        {
            sesion.UltimaEscrituraModbusExitosa = false;
            sesion.MensajeEstado =
                $"El envío de la trama falló: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                $"Trama manual · {ex.Message}"
            );
        }
        finally
        {
            sesion.EscrituraModbusEnCurso = false;

            if (!componenteLiberado)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static bool ValidarDisponibilidadTramaManual(
        TerminalSesion sesion)
    {
        if (!sesion.Servicio.EstaConectado)
        {
            sesion.MensajeEstado =
                "Conecta el puerto RS-485 antes de enviar una trama.";
            return false;
        }

        if (sesion.PollingModbusActivo)
        {
            sesion.MensajeEstado =
                "Detén el polling antes de enviar una trama manual.";
            return false;
        }

        if (sesion.ConsultaModbusEnCurso ||
            sesion.EscrituraModbusEnCurso)
        {
            sesion.MensajeEstado =
                "Espera a que termine la operación Modbus actual.";
            return false;
        }

        if (sesion.TimeoutModbusMs is < 100 or > 10000)
        {
            sesion.MensajeEstado =
                "El tiempo de espera debe estar entre 100 y 10000 ms.";
            return false;
        }

        if (sesion.ReintentosModbus is < 0 or > 10)
        {
            sesion.MensajeEstado =
                "Los reintentos deben estar entre 0 y 10.";
            return false;
        }

        return true;
    }

    private static bool TryPrepararTramaManual(
        TerminalSesion sesion,
        out byte[] trama,
        out string descripcion,
        out string error)
    {
        trama = Array.Empty<byte>();
        descripcion = string.Empty;

        if (!TryParsearBytesHexadecimales(
                sesion.TramaEscrituraModbus,
                out byte[] bytesIngresados,
                out error))
        {
            return false;
        }

        if (bytesIngresados.Length < 2)
        {
            error =
                "La trama debe incluir al menos el ID del esclavo y la función.";
            return false;
        }

        byte esclavo = bytesIngresados[0];
        byte funcion = bytesIngresados[1];

        if (esclavo is < 1 or > 247)
        {
            error =
                "El ID del esclavo debe estar entre 1 y 247. El broadcast 0 todavía no se admite.";
            return false;
        }

        if (!EsFuncionModbusAdmitida(funcion))
        {
            error =
                $"La función 0x{funcion:X2} todavía no está admitida por el lector de respuestas.";
            return false;
        }

        if (sesion.AgregarCrcAutomaticoTrama)
        {
            ReadOnlySpan<byte> datosSinCrc = bytesIngresados;
            int longitudSinCrcEsperada =
                ObtenerLongitudSolicitudSinCrc(bytesIngresados);

            bool incluyeCrcValido =
                bytesIngresados.Length >= 4 &&
                EsCrcModbusValido(bytesIngresados);

            if (incluyeCrcValido)
            {
                trama = bytesIngresados;
            }
            else
            {
                if (longitudSinCrcEsperada > 0 &&
                    bytesIngresados.Length == longitudSinCrcEsperada + 2)
                {
                    datosSinCrc = bytesIngresados.AsSpan(0, bytesIngresados.Length - 2);
                }

                ushort crc = CalcularCrcModbus(datosSinCrc);
                trama = new byte[datosSinCrc.Length + 2];
                datosSinCrc.CopyTo(trama);
                trama[^2] = (byte)(crc & 0xFF);
                trama[^1] = (byte)(crc >> 8);
            }
        }
        else
        {
            trama = bytesIngresados;

            if (trama.Length < 4)
            {
                error =
                    "En modo exacto la trama debe incluir los dos bytes CRC.";
                return false;
            }
        }

        string estadoCrc = EsCrcModbusValido(trama)
            ? "CRC válido"
            : "CRC no válido, envío exacto";

        descripcion =
            $"Esclavo {esclavo} · Función 0x{funcion:X2} · " +
            $"{trama.Length} bytes · {estadoCrc}";

        if (funcion == 0x06 && trama.Length >= 8)
        {
            ushort direccion = (ushort)(
                (trama[2] << 8) |
                trama[3]
            );

            ushort valor = (ushort)(
                (trama[4] << 8) |
                trama[5]
            );

            descripcion +=
                $" · Registro {direccion} = {valor} (0x{valor:X4})";
        }
        else if (funcion == 0x10 && trama.Length >= 8)
        {
            ushort direccion = (ushort)(
                (trama[2] << 8) |
                trama[3]
            );

            ushort cantidad = (ushort)(
                (trama[4] << 8) |
                trama[5]
            );

            descripcion +=
                $" · Inicio {direccion} · {cantidad} registro(s)";
        }

        error = string.Empty;
        return true;
    }

    private static bool TryParsearBytesHexadecimales(
        string texto,
        out byte[] bytes,
        out string error)
    {
        bytes = Array.Empty<byte>();
        error = string.Empty;

        if (string.IsNullOrWhiteSpace(texto))
        {
            error = "Escribe una trama hexadecimal antes de enviarla.";
            return false;
        }

        string normalizado = texto
            .Replace("0x", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace(',', ' ')
            .Replace(';', ' ')
            .Replace('-', ' ')
            .Replace(':', ' ')
            .Replace('\r', ' ')
            .Replace('\n', ' ')
            .Replace('\t', ' ');

        string[] partes = normalizado.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries |
            StringSplitOptions.TrimEntries
        );

        List<byte> resultado = new(partes.Length);

        for (int indice = 0; indice < partes.Length; indice++)
        {
            string parte = partes[indice];

            if (parte.Length != 2 ||
                !byte.TryParse(
                    parte,
                    System.Globalization.NumberStyles.HexNumber,
                    System.Globalization.CultureInfo.InvariantCulture,
                    out byte valor))
            {
                error =
                    $"El byte #{indice + 1} ('{parte}') no es hexadecimal válido. Usa pares como 0D, 06 o FF.";
                return false;
            }

            resultado.Add(valor);
        }

        bytes = resultado.ToArray();
        return true;
    }

    private static int ObtenerLongitudSolicitudSinCrc(
        IReadOnlyList<byte> trama)
    {
        if (trama.Count < 2)
        {
            return 0;
        }

        byte funcion = trama[1];

        if (funcion is >= 0x01 and <= 0x06)
        {
            return 6;
        }

        if (funcion is 0x0F or 0x10)
        {
            if (trama.Count < 7)
            {
                return 0;
            }

            return 7 + trama[6];
        }

        return 0;
    }

    private static bool EsFuncionModbusAdmitida(byte funcion)
    {
        return funcion is
            0x01 or 0x02 or 0x03 or 0x04 or
            0x05 or 0x06 or 0x0F or 0x10;
    }

    private static bool EsFuncionEscrituraModbus(byte funcion)
    {
        return funcion is 0x05 or 0x06 or 0x0F or 0x10;
    }

    private static bool EsCrcModbusValido(
        IReadOnlyList<byte> trama)
    {
        if (trama.Count < 4)
        {
            return false;
        }

        byte[] datos = trama.ToArray();
        ushort calculado = CalcularCrcModbus(
            datos.AsSpan(0, datos.Length - 2)
        );

        ushort recibido = (ushort)(
            datos[^2] |
            (datos[^1] << 8)
        );

        return calculado == recibido;
    }

    private static void ProcesarRespuestaTramaManual(
        TerminalSesion sesion,
        byte[] solicitud,
        byte[] respuesta)
    {
        sesion.RespuestaEscrituraModbus =
            ConvertirAHex(respuesta);

        AgregarLineaTerminal(
            sesion,
            "RX",
            sesion.RespuestaEscrituraModbus
        );

        if (respuesta.Length < 5)
        {
            throw new InvalidDataException(
                "La respuesta Modbus está incompleta."
            );
        }

        sesion.CrcEscrituraModbusValido =
            EsCrcModbusValido(respuesta);

        if (sesion.CrcEscrituraModbusValido != true)
        {
            throw new InvalidDataException(
                "La respuesta contiene un CRC incorrecto."
            );
        }

        if (respuesta[0] != solicitud[0])
        {
            throw new InvalidDataException(
                $"Respondió el esclavo {respuesta[0]}, pero se esperaba el {solicitud[0]}."
            );
        }

        byte funcionSolicitud = solicitud[1];
        byte funcionRespuesta = respuesta[1];

        if (funcionRespuesta == (byte)(funcionSolicitud | 0x80))
        {
            byte codigoExcepcion = respuesta[2];

            throw new InvalidOperationException(
                $"Excepción Modbus 0x{codigoExcepcion:X2}: " +
                DescribirExcepcionModbus(codigoExcepcion)
            );
        }

        if (funcionRespuesta != funcionSolicitud)
        {
            throw new InvalidDataException(
                $"La respuesta usa la función 0x{funcionRespuesta:X2}, pero se envió 0x{funcionSolicitud:X2}."
            );
        }

        if (funcionSolicitud is 0x05 or 0x06 or 0x0F or 0x10)
        {
            if (solicitud.Length < 6 || respuesta.Length < 8)
            {
                throw new InvalidDataException(
                    "La confirmación de escritura Modbus está incompleta."
                );
            }

            for (int indice = 0; indice < 6; indice++)
            {
                if (respuesta[indice] != solicitud[indice])
                {
                    throw new InvalidDataException(
                        "La confirmación no coincide con la dirección o los datos enviados."
                    );
                }
            }
        }
    }

    private async Task AlternarPollingModbusAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesion,
                registrarMensaje: true
            );

            return;
        }

        if (!sesion.Servicio.EstaConectado)
        {
            sesion.MensajeEstado =
                "Conecta el puerto RS-485 antes de iniciar el polling.";
            return;
        }

        if (!ValidarParametrosModbus(sesion))
        {
            return;
        }

        if (sesion.IntervaloPollingModbusMs is < 250 or > 60000)
        {
            sesion.MensajeEstado =
                "El intervalo de polling debe estar entre 250 y 60000 ms.";
            return;
        }

        sesion.LecturasPollingCorrectas = 0;
        sesion.ErroresPolling = 0;
        sesion.UltimaLecturaPolling = null;
        sesion.UltimoErrorPolling = string.Empty;
        sesion.PollingCancellation =
            new CancellationTokenSource();
        sesion.PollingModbusActivo = true;

        AgregarLineaTerminal(
            sesion,
            "SYS",
            $"Polling iniciado cada " +
            $"{sesion.IntervaloPollingModbusMs} ms."
        );

        sesion.MensajeEstado =
            "Lectura automática Modbus RTU activa.";

        sesion.PollingTask = EjecutarPollingModbusAsync(
            sesion,
            sesion.PollingCancellation.Token
        );

        await InvokeAsync(StateHasChanged);
    }

    private async Task EjecutarPollingModbusAsync(
        TerminalSesion sesion,
        CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested &&
                   sesion.Servicio.EstaConectado)
            {
                bool lecturaCorrecta =
                    await EjecutarLecturaModbusAsync(
                        sesion,
                        sesion.RegistrarPollingEnTerminal,
                        esPolling: true,
                        cancellationToken
                    );

                if (cancellationToken.IsCancellationRequested)
                {
                    break;
                }

                if (lecturaCorrecta)
                {
                    sesion.LecturasPollingCorrectas++;
                    sesion.UltimaLecturaPolling = DateTime.Now;
                    sesion.UltimoErrorPolling = string.Empty;
                    sesion.MensajeEstado =
                        $"Polling activo · " +
                        $"{sesion.LecturasPollingCorrectas} correcta(s) · " +
                        $"{sesion.ErroresPolling} error(es).";
                }
                else
                {
                    sesion.ErroresPolling++;
                    sesion.MensajeEstado =
                        $"Polling activo · " +
                        $"{sesion.LecturasPollingCorrectas} correcta(s) · " +
                        $"{sesion.ErroresPolling} error(es).";
                }

                if (!componenteLiberado)
                {
                    await InvokeAsync(StateHasChanged);
                }

                await Task.Delay(
                    Math.Clamp(
                        sesion.IntervaloPollingModbusMs,
                        250,
                        60000
                    ),
                    cancellationToken
                );
            }
        }
        catch (OperationCanceledException)
            when (cancellationToken.IsCancellationRequested)
        {
            // Detención solicitada por el usuario.
        }
        catch (Exception ex)
        {
            sesion.ErroresPolling++;
            sesion.MensajeEstado =
                $"El polling se detuvo: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                $"Polling detenido: {ex.Message}"
            );
        }
        finally
        {
            sesion.PollingModbusActivo = false;
            sesion.ConsultaModbusEnCurso = false;

            CancellationTokenSource? cancellation =
                sesion.PollingCancellation;

            sesion.PollingCancellation = null;
            sesion.PollingTask = null;
            cancellation?.Dispose();

            if (!componenteLiberado)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task DetenerPollingModbusAsync(
        TerminalSesion sesion,
        bool registrarMensaje)
    {
        CancellationTokenSource? cancellation =
            sesion.PollingCancellation;

        Task? pollingTask = sesion.PollingTask;

        if (!sesion.PollingModbusActivo &&
            cancellation is null &&
            pollingTask is null)
        {
            return;
        }

        cancellation?.Cancel();

        if (pollingTask is not null)
        {
            try
            {
                await pollingTask;
            }
            catch (OperationCanceledException)
            {
                // Cancelación normal.
            }
        }

        if (registrarMensaje)
        {
            sesion.MensajeEstado =
                "Lectura automática Modbus RTU detenida.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                "Polling Modbus RTU detenido."
            );
        }

        if (!componenteLiberado)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> EjecutarLecturaModbusAsync(
        TerminalSesion sesion,
        bool registrarEnTerminal,
        bool esPolling,
        CancellationToken cancellationToken)
    {
        if (sesion.Tipo != TipoSesion.ModbusRtu)
        {
            return false;
        }

        if (!sesion.Servicio.EstaConectado)
        {
            sesion.MensajeEstado =
                "Conecta el puerto RS-485 antes de consultar el sensor.";
            return false;
        }

        if (sesion.ConsultaModbusEnCurso)
        {
            return false;
        }

        if (!ValidarParametrosModbus(sesion))
        {
            return false;
        }

        byte funcion = sesion.FuncionModbus == "04"
            ? (byte)0x04
            : (byte)0x03;

        byte[] solicitud = ConstruirTramaLecturaModbus(
            (byte)sesion.IdEsclavoModbus,
            funcion,
            (ushort)sesion.DireccionInicialModbus,
            (ushort)sesion.CantidadRegistrosModbus
        );

        sesion.TramaModbusPrevia = ConvertirAHex(solicitud);
        sesion.ConsultaModbusEnCurso = true;

        if (!esPolling)
        {
            sesion.UltimaRespuestaModbus = string.Empty;
            sesion.CrcModbusValido = null;
            sesion.RegistrosModbus.Clear();
            sesion.MensajeEstado =
                $"Consultando al esclavo {sesion.IdEsclavoModbus}...";
        }

        if (!componenteLiberado)
        {
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            int reintentos = Math.Clamp(
                sesion.ReintentosModbus,
                0,
                10
            );

            int intentosTotales = reintentos + 1;
            Exception? ultimoError = null;

            for (int intento = 1;
                 intento <= intentosTotales;
                 intento++)
            {
                cancellationToken.ThrowIfCancellationRequested();

                if (intento > 1 && registrarEnTerminal)
                {
                    AgregarLineaTerminal(
                        sesion,
                        "SYS",
                        $"Reintento {intento - 1} de {reintentos}."
                    );
                }

                if (registrarEnTerminal)
                {
                    AgregarLineaTerminal(
                        sesion,
                        "TX",
                        sesion.TramaModbusPrevia
                    );
                }

                if (!componenteLiberado)
                {
                    await InvokeAsync(StateHasChanged);
                }

                try
                {
                    byte[] respuesta = await sesion.Servicio
                        .TransaccionModbusAsync(
                            solicitud,
                            Math.Clamp(
                                sesion.TimeoutModbusMs,
                                100,
                                10000
                            ),
                            cancellationToken
                        );

                    ProcesarRespuestaModbus(
                        sesion,
                        respuesta,
                        funcion,
                        registrarEnTerminal
                    );

                    RegistrarMuestraGrafica(sesion);

                    await RegistrarLecturaCsvAsync(sesion);

                    await EnviarLecturaServidorSiCorrespondeAsync(
                        sesion,
                        esPolling,
                        cancellationToken
                    );

                    return true;
                }
                catch (TimeoutException ex)
                {
                    ultimoError = ex;

                    if (intento < intentosTotales &&
                        registrarEnTerminal)
                    {
                        AgregarLineaTerminal(
                            sesion,
                            "SYS",
                            "Sin respuesta. Se intentará nuevamente."
                        );
                    }
                }
            }

            throw ultimoError ?? new TimeoutException(
                "El dispositivo no respondió."
            );
        }
        catch (OperationCanceledException)
            when (cancellationToken.IsCancellationRequested)
        {
            return false;
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                esPolling
                    ? $"Polling: {ex.Message}"
                    : $"La consulta Modbus falló: {ex.Message}";

            bool registrarError =
                !esPolling ||
                registrarEnTerminal ||
                !string.Equals(
                    sesion.UltimoErrorPolling,
                    ex.Message,
                    StringComparison.Ordinal
                );

            if (registrarError)
            {
                AgregarLineaTerminal(
                    sesion,
                    "ERROR",
                    ex.Message
                );
            }

            if (esPolling)
            {
                sesion.UltimoErrorPolling = ex.Message;
            }

            return false;
        }
        finally
        {
            sesion.ConsultaModbusEnCurso = false;

            if (!componenteLiberado)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void AlternarGraficaTiempoReal()
    {
        TerminalSesion sesion = SesionActiva;

        sesion.GraficaActiva = !sesion.GraficaActiva;

        sesion.MensajeEstado = sesion.GraficaActiva
            ? "Gráfica en tiempo real activada."
            : "Gráfica en tiempo real pausada.";
    }

    private void LimpiarGraficaTiempoReal()
    {
        TerminalSesion sesion = SesionActiva;

        sesion.MuestrasGrafica.Clear();
        sesion.MensajeEstado =
            "Los puntos de la gráfica fueron eliminados.";
    }

    private static void RegistrarMuestraGrafica(
        TerminalSesion sesion)
    {
        if (!sesion.GraficaActiva ||
            sesion.RegistrosModbus.Count == 0)
        {
            return;
        }

        RegistroModbusResultado? registro =
            sesion.RegistrosModbus.FirstOrDefault(
                item => item.Direccion ==
                    sesion.DireccionRegistroGrafica
            );

        if (registro is null)
        {
            registro = sesion.RegistrosModbus[0];
            sesion.DireccionRegistroGrafica =
                registro.Direccion;
        }

        sesion.MuestrasGrafica.Add(
            new MuestraGrafica(
                DateTime.Now,
                registro.Direccion,
                registro.ValorSinSigno
            )
        );

        int maximo = Math.Clamp(
            sesion.MaxPuntosGrafica,
            20,
            1000
        );

        sesion.MaxPuntosGrafica = maximo;

        if (sesion.MuestrasGrafica.Count > maximo)
        {
            int cantidadEliminar =
                sesion.MuestrasGrafica.Count - maximo;

            sesion.MuestrasGrafica.RemoveRange(
                0,
                cantidadEliminar
            );
        }
    }

    private static string ValorActualGrafica(
        TerminalSesion sesion)
    {
        return sesion.MuestrasGrafica.Count == 0
            ? "—"
            : sesion.MuestrasGrafica[^1]
                .Valor
                .ToString(CultureInfo.InvariantCulture);
    }

    private static string ValorMinimoGrafica(
        TerminalSesion sesion)
    {
        return sesion.MuestrasGrafica.Count == 0
            ? "—"
            : sesion.MuestrasGrafica
                .Min(muestra => muestra.Valor)
                .ToString(CultureInfo.InvariantCulture);
    }

    private static string ValorMaximoGrafica(
