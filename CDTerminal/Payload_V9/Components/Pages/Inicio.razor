    }

    private async Task EliminarDestinoRestAsync()
    {
        if (EsDestinoRestNuevo || operacionServidorRestEnCurso)
        {
            return;
        }

        Guid destinoId = destinoRestEditando.Id;
        string nombre = destinoRestEditando.Nombre;
        guardadoServidorRestEnCurso = true;
        errorServidorRest = string.Empty;

        try
        {
            await ServidorRestService.EliminarDestinoAsync(destinoId);
            estadosDestinosRest.Remove(destinoId);
            RecargarDestinosRest();

            if (destinosRest.Count > 0)
            {
                SeleccionarDestinoRest(destinosRest[0].Id);
            }
            else
            {
                NuevoDestinoRest();
            }

            mensajeEstado = $"Destino REST '{nombre}' eliminado.";
        }
        catch (Exception ex)
        {
            errorServidorRest = ex.Message;
            mensajeEstado =
                $"No fue posible eliminar el destino: {ex.Message}";
        }
        finally
        {
            destinoRestConfirmarEliminacionId = null;
            guardadoServidorRestEnCurso = false;
        }
    }

    private async Task ProbarConexionServidorRestAsync()
    {
        if (operacionServidorRestEnCurso)
        {
            return;
        }

        pruebaServidorRestEnCurso = true;
        errorServidorRest = string.Empty;

        EstadoDestinoRest estado = EstadoServidorRestSeleccionado;
        estado.Mensaje = "Probando endpoint HTTP...";

        try
        {
            ResultadoServidorRest resultado =
                await ServidorRestService.ProbarConexionAsync(
                    destinoRestEditando
