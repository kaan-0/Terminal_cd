@using System.Globalization
@using CDTerminal.Models
@using System.IO
@using System.Text
@using System.Threading
@using System.Threading.Tasks
@implements IDisposable
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JSRuntime
@inject CDTerminal.Services.IFileExportService FileExportService
@inject CDTerminal.Services.IPerfilDispositivoService PerfilDispositivoService
@inject CDTerminal.Services.IServidorRestService ServidorRestService
@using Microsoft.Extensions.DependencyInjection

<div class="app-shell @(!MostrarBarraEstadoActual ? "statusbar-hidden" : string.Empty)">

    <nav class="app-menu" aria-label="Menú principal">

        <div class="menu-links">

            <button type="button"
                    class="menu-item @(ModuloInicioActivo ? "active" : "")"
                    @onclick="MostrarInicioVacio">
                Inicio
            </button>

            <div class="menu-dropdown">

                <button type="button"
                        class="menu-item communication @(mostrarMenuComunicacion ? "open" : "") @(ModuloSesionActivo ? "active" : "")"
                        @onclick="AlternarMenuComunicacion">
                    Comunicación
                    <span class="menu-arrow">@(mostrarMenuComunicacion ? "▲" : "▼")</span>
                </button>

                @if (mostrarMenuComunicacion)
                {
                    <div class="session-type-menu communication-options">

                        <button type="button"
                                class="session-type-option"
                                @onclick="() => CrearNuevaSesion(TipoSesion.Serial)">
                            <span class="session-type-icon serial">&gt;_</span>
                            <span>
                                <strong>Terminal serial</strong>
                                <small>USB-TTL, RS-232 y comunicación RAW</small>
                            </span>
                        </button>

                        <button type="button"
                                class="session-type-option"
                                @onclick="() => CrearNuevaSesion(TipoSesion.ModbusRtu)">
                            <span class="session-type-icon modbus">MB</span>
                            <span>
                                <strong>Modbus RTU</strong>
                                <small>Sensores y equipos RS-485</small>
                            </span>
                        </button>

                    </div>
                }

            </div>

            <div class="menu-dropdown">

                <button type="button"
                        class="menu-item view @(mostrarMenuVer ? "open" : "")"
                        disabled="@(!ModuloSesionActivo)"
                        title="@(ModuloSesionActivo ? "Mostrar u ocultar paneles" : "Abre una terminal serial o Modbus RTU")"
                        @onclick="AlternarMenuVer">
                    Ver
                    <span class="menu-arrow">@(mostrarMenuVer ? "▲" : "▼")</span>
                </button>

                @if (mostrarMenuVer)
                {
                    <div class="session-type-menu view-options">

                        <div class="session-menu-title">Elementos de la interfaz</div>

                        <button type="button"
                                class="view-option"
                                aria-pressed="@panelConexionVisible"
                                @onclick="AlternarPanelConexion">
                            <span class="view-check @(panelConexionVisible ? "checked" : "")">
                                @(panelConexionVisible ? "✓" : "")
                            </span>
                            <span>
                                <strong>Panel de conexión</strong>
                                <small>Puerto y configuración serial</small>
                            </span>
                        </button>

                        <button type="button"
                                class="view-option"
                                aria-pressed="@terminalVisible"
                                @onclick="AlternarTerminal">
                            <span class="view-check @(terminalVisible ? "checked" : "")">
                                @(terminalVisible ? "✓" : "")
                            </span>
                            <span>
                                <strong>Terminal de datos</strong>
                                <small>Mensajes RX, TX, SYS y errores</small>
                            </span>
                        </button>

                        <button type="button"
                                class="view-option"
                                aria-pressed="@graficaVisible"
                                @onclick="AlternarVisibilidadGrafica">
                            <span class="view-check @(graficaVisible ? "checked" : "")">
                                @(graficaVisible ? "✓" : "")
                            </span>
                            <span>
                                <strong>Gráfica en tiempo real</strong>
                                <small>Disponible en sesiones Modbus RTU</small>
                            </span>
                        </button>

                        <button type="button"
                                class="view-option"
                                aria-pressed="@barraEstadoVisible"
                                @onclick="AlternarBarraEstado">
                            <span class="view-check @(barraEstadoVisible ? "checked" : "")">
                                @(barraEstadoVisible ? "✓" : "")
                            </span>
                            <span>
                                <strong>Barra de estado</strong>
                                <small>Resumen inferior de la sesión</small>
                            </span>
                        </button>

                        <div class="view-menu-divider"></div>

                        <button type="button"
                                class="view-reset-option"
                                @onclick="RestablecerVista">
                            <span>↺</span>
                            Restablecer vista
                        </button>

                    </div>
                }

            </div>

            <div class="menu-dropdown">

                <button type="button"
                        class="menu-item tools @(mostrarMenuHerramientas ? "open" : "") @(ModuloIotActivo ? "active" : "")"
                        @onclick="AlternarMenuHerramientas">
                    Herramientas
                    <span class="menu-arrow">@(mostrarMenuHerramientas ? "▲" : "▼")</span>
                </button>

                @if (mostrarMenuHerramientas)
                {
                    <div class="session-type-menu tools-options">

                        <button type="button"
                                class="session-type-option"
                                disabled="@(!ModuloSesionActivo)"
                                @onclick="AbrirGuardarPerfil">
                            <span class="session-type-icon profile">＋</span>
                            <span>
                                <strong>Guardar perfil actual</strong>
                                <small>Conserva la configuración de esta sesión</small>
                            </span>
                        </button>

                        <button type="button"
                                class="session-type-option"
                                disabled="@(!ModuloSesionActivo)"
                                @onclick="AbrirAdministradorPerfiles">
                            <span class="session-type-icon profiles">▤</span>
                            <span>
                                <strong>Perfiles de dispositivos</strong>
                                <small>@perfilesDispositivo.Count perfil(es) guardado(s)</small>
                            </span>
                        </button>

                        <button type="button"
                                class="session-type-option"
                                title="Configurar el controlador con una conexión serial propia"
                                @onclick="AbrirConfiguracionEquipoIot">
                            <span class="session-type-icon iot">IOT</span>
                            <span>
                                <strong>Configurar equipo IoT</strong>
                                <small>DHCP, red estática, servidor, puerto, URL y período</small>
                            </span>
                        </button>

                        <div class="tools-menu-divider"></div>

                        <button type="button"
                                class="session-type-option"
                                @onclick="AbrirConfiguracionServidorRest">
                            <span class="session-type-icon server">API</span>
                            <span>
                                <strong>Destinos de datos</strong>
                                <small>@ResumenServidorRestMenu</small>
                            </span>
                        </button>

                    </div>
                }

            </div>

            <button type="button"
                    class="menu-item"
                    title="Se habilitará en una próxima etapa"
                    disabled>
                Ayuda
            </button>

        </div>

        <div class="menu-status @ClaseEstadoMenuPrincipal">

            <span class="status-dot"></span>
            <span>@TextoEstadoMenuPrincipal</span>

        </div>

    </nav>

    @if (ModuloSesionActivo)
    {
    <main class="workspace @(!panelConexionVisible ? "without-control-panel" : string.Empty)">

        @if (panelConexionVisible)
        {
        <aside class="control-panel">

            <div class="sidebar-tabs">

                <button type="button"
                        class="sidebar-tab @(pestanaActiva == "puerto" ? "active" : "")"
                        @onclick="MostrarPuerto">

                    <span class="sidebar-tab-icon">⌁</span>
                    Conexión

                </button>

                <button type="button"
                        class="sidebar-tab @(pestanaActiva == "configuracion" ? "active" : "")"
                        @onclick="MostrarConfiguracion">

                    <span class="sidebar-tab-icon">⚙</span>
                    Configuración

                </button>

            </div>

            <div class="panel-body">

                @if (pestanaActiva == "puerto")
                {
                    <section class="panel-section">

                        <div class="section-header">

                            <div>
                                <span class="section-icon">⌁</span>
                                <div>
                                    <span class="section-eyebrow">CONEXIÓN</span>
                                    <h2>Puerto serial</h2>
                                </div>
                            </div>

                            <button type="button"
                                    class="icon-button"
                                    title="Actualizar puertos"
                                    disabled="@SerialPortService.EstaConectado"
                                    @onclick="ActualizarPuertos">
                                ↻
                            </button>

                        </div>

                        @if (puertos.Count == 0)
                        {
                            <div class="empty-state">

                                <span class="empty-state-icon">USB</span>
                                <strong>No hay puertos disponibles</strong>
                                <span>
                                    Conecta un dispositivo y presiona actualizar.
                                </span>

                            </div>
                        }
                        else
                        {
                            <div class="field-group">

                                <label>Puerto COM</label>

                                <div class="port-selector">

                                    <button type="button"
                                            class="port-selector-button"
                                            disabled="@SerialPortService.EstaConectado"
                                            @onclick="AlternarLista">

                                        <span class="port-button-content">
                                            <span class="port-symbol">▰</span>
                                            <strong>
                                                @(string.IsNullOrWhiteSpace(puertoSeleccionado)
                                                    ? "Seleccione un puerto"
                                                    : puertoSeleccionado)
                                            </strong>
                                        </span>

                                        <span class="selector-arrow">
                                            @(mostrarLista ? "▲" : "▼")
                                        </span>

                                    </button>

                                    @if (mostrarLista &&
                                         !SerialPortService.EstaConectado)
                                    {
                                        <div class="port-options">

                                            @foreach (var puerto in puertos)
                                            {
                                                <button type="button"
                                                        class="port-option @(puerto == puertoSeleccionado
                                                                                ? "selected"
                                                                                : "")"
                                                        @onclick="() => SeleccionarPuerto(puerto)">

                                                    <span class="port-icon">◉</span>
                                                    <span>@puerto</span>

                                                    @if (puerto == puertoSeleccionado)
                                                    {
                                                        <span class="option-check">✓</span>
                                                    }

                                                </button>
                                            }

                                        </div>
                                    }

                                </div>

                            </div>

                            <div class="information-grid">

                                <div class="information-card">
                                    <span class="info-icon">▣</span>
                                    <div>
                                        <span>Puertos detectados</span>
                                        <strong>@puertos.Count</strong>
                                    </div>
                                </div>

                                <div class="information-card selected-port-card">
                                    <span class="info-icon">✓</span>
                                    <div>
                                        <span>Puerto seleccionado</span>
                                        <strong>@puertoSeleccionado</strong>
                                    </div>
                                </div>

                            </div>

                            <div class="side-card configuration-card">

                                <div class="card-title-row">
                                    <span class="card-icon">⚙</span>
                                    <span>CONFIGURACIÓN ACTUAL</span>
                                </div>

                                <dl class="configuration-list">
                                    <div>
                                        <dt>Protocolo</dt>
                                        <dd>@NombreTipoSesion(SesionActiva.Tipo)</dd>
                                    </div>
                                    @if (EsSesionModbus)
                                    {
                                        <div>
                                            <dt>ID esclavo</dt>
                                            <dd>@SesionActiva.IdEsclavoModbus</dd>
                                        </div>
                                    }
                                    <div>
                                        <dt>Baudios</dt>
                                        <dd>@configuracion.Velocidad bps</dd>
                                    </div>
                                    <div>
                                        <dt>Bits de datos</dt>
                                        <dd>@configuracion.BitsDeDatos bits</dd>
                                    </div>
                                    <div>
                                        <dt>Paridad</dt>
                                        <dd>@NombreParidad(configuracion.Paridad)</dd>
                                    </div>
                                    <div>
                                        <dt>Bits de parada</dt>
                                        <dd>@NombreBitsParada(configuracion.BitsDeParada) stop</dd>
                                    </div>
                                    <div>
                                        <dt>Control de flujo</dt>
                                        <dd>@NombreControlFlujo(configuracion.ControlDeFlujo)</dd>
                                    </div>
                                </dl>

                                <button type="button"
                                        class="card-action"
                                        disabled="@SerialPortService.EstaConectado"
                                        @onclick="MostrarConfiguracion">
                                    ✎ Modificar configuración
                                </button>

                            </div>

                            <div class="side-card device-card">

                                <div class="card-title-row">
                                    <span class="card-icon">▣</span>
                                    <span>DISPOSITIVO</span>
                                </div>

                                <dl class="device-list">
                                    <div>
                                        <dt>Estado</dt>
                                        <dd>
                                            <span class="mini-status-dot @(SerialPortService.EstaConectado ? "online" : "offline")"></span>
                                            @(SerialPortService.EstaConectado ? "Conectado" : "Sin conexión")
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Puerto</dt>
                                        <dd>@(SerialPortService.PuertoActual ?? puertoSeleccionado)</dd>
                                    </div>
                                    <div>
                                        <dt>Tipo</dt>
                                        <dd>@DescripcionTipoSesion(SesionActiva.Tipo)</dd>
                                    </div>
                                    <div>
                                        <dt>Sesión</dt>
                                        <dd>@(SerialPortService.EstaConectado ? "Activa" : "—")</dd>
                                    </div>
                                </dl>

                            </div>
                        }

                    </section>
                }
                else
                {
                    <section class="panel-section">

                        <div class="section-header">

                            <div>
                                <span class="section-icon">⚙</span>
                                <div>
                                    <span class="section-eyebrow">PUERTO SERIAL</span>
                                    <h2>Configuración</h2>
                                </div>
                            </div>

                        </div>

                        <div class="configuration-fields">

                            <SelectorPersonalizado Etiqueta="Velocidad"
                                                   Opciones="opcionesVelocidad"
                                                   @bind-ValorSeleccionado="VelocidadSeleccionada"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Bits de datos"
                                                   Opciones="opcionesBitsDeDatos"
                                                   @bind-ValorSeleccionado="BitsDeDatosSeleccionados"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Paridad"
                                                   Opciones="opcionesParidad"
                                                   @bind-ValorSeleccionado="ParidadSeleccionada"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Bits de parada"
                                                   Opciones="opcionesBitsDeParada"
                                                   @bind-ValorSeleccionado="BitsDeParadaSeleccionados"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Control de flujo"
                                                   Opciones="opcionesControlDeFlujo"
                                                   @bind-ValorSeleccionado="ControlDeFlujoSeleccionado"
                                                   Disabled="@SerialPortService.EstaConectado" />

                        </div>

                        <div class="advanced-options">

                            <span class="advanced-title">
                                Líneas de control
                            </span>

                            <label class="toggle-option">

                                <input type="checkbox"
                                       @bind="configuracion.HabilitarDtr"
                                       disabled="@SerialPortService.EstaConectado" />

                                <span>
                                    <strong>DTR</strong>
                                    <small>Data Terminal Ready</small>
                                </span>

                            </label>

                            <label class="toggle-option">

                                <input type="checkbox"
                                       @bind="configuracion.HabilitarRts"
                                       disabled="@SerialPortService.EstaConectado" />

                                <span>
                                    <strong>RTS</strong>
                                    <small>Request To Send</small>
                                </span>

                            </label>

                        </div>

                        @if (EsSesionModbus)
                        {
                            <div class="modbus-config-section">

                                <div class="modbus-section-heading">
                                    <span class="session-type-icon modbus">MB</span>
                                    <div>
                                        <strong>Parámetros Modbus RTU</strong>
                                        <small>Configuración del dispositivo esclavo</small>
                                    </div>
                                </div>

                                <div class="modbus-config-grid">

                                    <label class="numeric-field">
                                        <span>ID del esclavo</span>
                                        <input type="number"
                                               min="1"
                                               max="247"
                                               @bind="SesionActiva.IdEsclavoModbus" />
                                        <small>Rango permitido: 1 a 247</small>
                                    </label>

                                    <label class="numeric-field">
                                        <span>Tiempo de espera</span>
                                        <div class="input-with-unit">
                                            <input type="number"
                                                   min="100"
                                                   max="10000"
                                                   step="100"
                                                   @bind="SesionActiva.TimeoutModbusMs" />
                                            <span>ms</span>
                                        </div>
                                    </label>

                                    <label class="numeric-field">
                                        <span>Reintentos</span>
                                        <input type="number"
                                               min="0"
                                               max="10"
                                               @bind="SesionActiva.ReintentosModbus" />
                                    </label>

                                </div>

                            </div>
                        }

                    </section>
                }

            </div>

            <div class="connection-footer">

                <div class="connection-summary">

                    <span class="connection-label">
                        Estado de conexión
                    </span>

                    <div class="connection-value">

                        <span class="connection-indicator @(SerialPortService.EstaConectado
                                                                 ? "online"
                                                                 : "offline")">
                        </span>

                        <strong>
                            @(SerialPortService.EstaConectado
                                ? SerialPortService.PuertoActual
                                : "Sin conexión")
                        </strong>

                    </div>

                </div>

                @if (SerialPortService.EstaConectado)
                {
                    <button type="button"
                            class="primary-action disconnect"
                            @onclick="DesconectarAsync">
                        <span>■</span>
                        Desconectar
                    </button>
                }
                else
                {
                    <button type="button"
                            class="primary-action connect"
                            disabled="@string.IsNullOrWhiteSpace(puertoSeleccionado)"
                            @onclick="Conectar">
                        <span>▷</span>
                        Conectar
                    </button>
                }

            </div>

        </aside>
        }

        <section class="terminal-workspace">

            <div class="terminal-tabs">

                @foreach (TerminalSesion sesion in sesiones)
                {
                    <button type="button"
                            @key="sesion.Id"
                            class="terminal-tab @(sesion.Id == sesionActivaId ? "active" : "")"
                            title="@(sesion.Servicio.EstaConectado
                                ? $"{sesion.Nombre} · {sesion.Servicio.PuertoActual}"
                                : sesion.Nombre)"
                            @onclick="() => SeleccionarTerminalAsync(sesion.Id)">

                        <span class="terminal-tab-dot @(sesion.Servicio.EstaConectado ? "online" : "offline")"></span>
                        <span class="terminal-tab-protocol @(sesion.Tipo == TipoSesion.ModbusRtu ? "modbus" : "serial")">
                            @(sesion.Tipo == TipoSesion.ModbusRtu ? "RTU" : "SER")
                        </span>
                        <span class="terminal-tab-name">@sesion.Nombre</span>

                        <span class="terminal-tab-close"
                              title="Cerrar terminal"
                              @onclick:stopPropagation="true"
                              @onclick="() => CerrarTerminalAsync(sesion.Id)">
                            ×
                        </span>

                    </button>
                }

                <div class="new-session-wrapper">

                    <button type="button"
                            class="new-terminal-tab @(mostrarSelectorNuevaSesion ? "open" : "")"
                            title="Abrir nueva sesión"
                            @onclick="AlternarSelectorNuevaSesion">
                        +
                    </button>

                    @if (mostrarSelectorNuevaSesion)
                    {
                        <div class="session-type-menu new-session-options">

                            <div class="session-menu-title">Nueva sesión</div>

                            <button type="button"
                                    class="session-type-option"
                                    @onclick="() => CrearNuevaSesion(TipoSesion.Serial)">
                                <span class="session-type-icon serial">&gt;_</span>
                                <span>
                                    <strong>Terminal serial</strong>
                                    <small>Comunicación libre por puerto COM</small>
                                </span>
                            </button>

                            <button type="button"
                                    class="session-type-option"
                                    @onclick="() => CrearNuevaSesion(TipoSesion.ModbusRtu)">
                                <span class="session-type-icon modbus">MB</span>
                                <span>
                                    <strong>Modbus RTU</strong>
                                    <small>Consultas industriales sobre RS-485</small>
                                </span>
                            </button>

                        </div>
                    }

                </div>

            </div>

            <section class="terminal-panel @(EsSesionModbus ? "modbus-mode" : "serial-mode") @(!terminalVisible ? "terminal-view-hidden" : string.Empty)">

                @if (terminalVisible)
                {
                <header class="terminal-header">

                    <div class="terminal-title">

                        <div class="terminal-icon @(EsSesionModbus ? "modbus" : "serial")">
                            @(EsSesionModbus ? "MB" : ">_")
                        </div>

                        <div>
                            <h2>@(EsSesionModbus ? "Modbus RTU" : "Terminal serial")</h2>
                            <span>
                                @(EsSesionModbus
                                    ? "Consultas y lectura de registros sobre RS-485"
                                    : "Datos recibidos en tiempo real")
                            </span>
                        </div>

                    </div>

                    <div class="terminal-toolbar">

                        <div class="line-counter">
                            @lineasTerminal.Count líneas
                        </div>

                        <label class="auto-scroll-option">

                            <input type="checkbox"
                                   @bind="autoScroll" />

                            <span>Auto scroll</span>

                        </label>

                        <button type="button"
                                class="export-terminal-button"
                                title="Guardar el contenido visible de esta terminal"
                                disabled="@(lineasTerminal.Count == 0)"
                                @onclick="ExportarTerminalTxtAsync">
                            <span>⇩</span>
                            TXT
                        </button>

                        <button type="button"
                                class="clear-button"
                                disabled="@(lineasTerminal.Count == 0)"
                                @onclick="LimpiarTerminal">
                            <span>⌫</span>
                            Limpiar
                        </button>

                    </div>

                </header>

                <div class="terminal-screen"
                     @ref="terminalElement">

                    @if (lineasTerminal.Count == 0)
                    {
                        <div class="terminal-empty">

                            <span class="terminal-empty-icon">@(EsSesionModbus ? "MB" : ">_")</span>
                            <strong>
                                @(EsSesionModbus
                                    ? "Configura tu primera consulta"
                                    : "Esperando información")
                            </strong>
                            <p>
                                @(EsSesionModbus
                                    ? "Las tramas preparadas y respuestas aparecerán aquí."
                                    : "Los datos recibidos aparecerán aquí.")
                            </p>

                        </div>
                    }
                    else
                    {
                        @foreach (var linea in lineasTerminal)
                        {
                            <div class="@($"terminal-line {ClaseLinea(linea)}")">
                                <span class="terminal-time">@MarcaTiempoLinea(linea)</span>
                                <span class="terminal-kind">@TipoVisualLinea(linea):</span>
                                <span class="terminal-content">@ContenidoVisualLinea(linea)</span>
                            </div>
                        }
                    }

                </div>
                }

                @if (!EsSesionModbus)
                {
                    <div class="send-container">

                        <div class="send-header">

                            <div>
                                <strong>Escribir al dispositivo</strong>
                                <span>Envía texto al microcontrolador conectado</span>
                            </div>

                            <span class="raw-mode-badge"
                                  title="Actualmente el texto se envía sin CR ni LF">
                                RAW
                            </span>

                        </div>

                        <div class="send-row">

                            <div class="send-input-wrapper">

                                <span class="send-prefix">TX</span>

                                <input type="text"
                                       class="send-input"
                                       placeholder="Escribe aquí..."
                                       autocomplete="off"
                                       @bind="textoParaEnviar"
                                       @bind:event="oninput"
                                       @onkeydown="ManejarTeclaEnvio"
                                       disabled="@(!SerialPortService.EstaConectado)" />

                            </div>

                            <button type="button"
                                    class="send-button"
                                    disabled="@(!PuedeEnviarTexto)"
                                    @onclick="EnviarTexto">
                                <span>➤</span>
                                Enviar
                            </button>

                        </div>

                    </div>
                }
                else
                {
                    <div class="modbus-builder">

                        <div class="modbus-builder-header">
                            <div>
                                <strong>Consulta Modbus RTU</strong>
                                <span>Configura y lee los registros del sensor</span>
                            </div>
                            <span class="preview-mode-badge @(SesionActiva.PollingModbusActivo
                                ? "polling"
                                : SesionActiva.ConsultaModbusEnCurso
                                    ? "reading"
                                    : SerialPortService.EstaConectado ? "ready" : "")">
                                @(SesionActiva.PollingModbusActivo
                                    ? "AUTOMÁTICO"
                                    : SesionActiva.ConsultaModbusEnCurso
                                        ? "LEYENDO"
                                        : SerialPortService.EstaConectado ? "LISTO" : "DESCONECTADO")
                            </span>
                        </div>

                        <div class="modbus-query-grid compact">

                            <SelectorPersonalizado Etiqueta="Función"
                                                   Opciones="opcionesFuncionesModbus"
                                                   @bind-ValorSeleccionado="FuncionModbusSeleccionada"
                                                   Disabled="@BloquearParametrosModbus" />

                            <label class="numeric-field">
                                <span>Dirección inicial</span>
                                <input type="number"
                                       min="0"
                                       max="65535"
                                       disabled="@BloquearParametrosModbus"
                                       @bind="SesionActiva.DireccionInicialModbus" />
                                <small>Base 0</small>
                            </label>

                            <label class="numeric-field">
                                <span>Cantidad</span>
                                <input type="number"
                                       min="1"
                                       max="125"
                                       disabled="@BloquearParametrosModbus"
                                       @bind="SesionActiva.CantidadRegistrosModbus" />
                                <small>Registros de 16 bits</small>
                            </label>

                            <button type="button"
                                    class="generate-frame-button"
                                    disabled="@(!PuedeLeerModbus)"
                                    @onclick="LeerRegistrosModbusAsync">
                                <span>@(SesionActiva.ConsultaModbusEnCurso ? "◌" : "◇")</span>
                                @(SesionActiva.PollingModbusActivo
                                    ? "Polling activo"
                                    : SesionActiva.ConsultaModbusEnCurso
                                        ? "Leyendo..."
                                        : "Leer")
                            </button>

                        </div>

                        <div class="modbus-summary-strip">
                            <div class="summary-chip">
                                <span>Último valor</span>
                                <strong>
                                    @(SesionActiva.RegistrosModbus.Count == 0
                                        ? "—"
                                        : SesionActiva.RegistrosModbus[0].ValorSinSigno.ToString())
                                </strong>
                            </div>

                            <div class="summary-chip">
                                <span>CRC</span>
                                <strong class="@(SesionActiva.CrcModbusValido == true ? "ok" : SesionActiva.CrcModbusValido == false ? "bad" : "")">
                                    @(SesionActiva.CrcModbusValido == true
                                        ? "Correcto"
                                        : SesionActiva.CrcModbusValido == false ? "Incorrecto" : "—")
                                </strong>
                            </div>

                            <div class="summary-chip">
                                <span>Polling</span>
                                <strong class="@(SesionActiva.PollingModbusActivo ? "ok" : "")">
                                    @(SesionActiva.PollingModbusActivo
                                        ? $"{SesionActiva.IntervaloPollingModbusMs} ms"
                                        : "Detenido")
                                </strong>
                            </div>

                            <div class="summary-chip">
                                <span>CSV</span>
                                <strong class="@(SesionActiva.RegistroCsvActivo ? "ok" : "")">
                                    @(SesionActiva.RegistroCsvActivo
                                        ? $"{SesionActiva.FilasCsvGuardadas} filas"
                                        : "Inactivo")
                                </strong>
                            </div>
                        </div>

                        <div class="modbus-compact-sections">

                            <details class="modbus-compact-section modbus-write-section">
                                <summary>
                                    <span class="compact-section-title">
                                        <span class="compact-section-icon write">HEX</span>
                                        <span>
                                            <strong>Enviar trama Modbus</strong>
                                            <small>Escritura manual en hexadecimal</small>
                                        </span>
                                    </span>
                                    <span class="compact-section-chevron">⌄</span>
                                </summary>

                                <div class="compact-section-body">
                                    <div class="modbus-write-panel @(SesionActiva.UltimaEscrituraModbusExitosa == true ? "success" : SesionActiva.UltimaEscrituraModbusExitosa == false ? "failed" : "")">

                                        <div class="modbus-write-header">
                                            <div>
                                                <strong>Trama hexadecimal</strong>
                                                <span>Escribe los bytes Modbus RTU separados por espacios.</span>
                                            </div>

                                            <span class="modbus-write-state @(SesionActiva.EscrituraModbusEnCurso ? "working" : SesionActiva.UltimaEscrituraModbusExitosa == true ? "success" : SesionActiva.UltimaEscrituraModbusExitosa == false ? "failed" : "")">
                                                @(SesionActiva.EscrituraModbusEnCurso
                                                    ? "ENVIANDO"
                                                    : SesionActiva.UltimaEscrituraModbusExitosa == true
                                                        ? "RESPUESTA OK"
                                                        : SesionActiva.UltimaEscrituraModbusExitosa == false
                                                            ? "FALLÓ"
                                                            : "LISTA")
                                            </span>
                                        </div>

                                        <label class="modbus-frame-editor-field">
                                            <span>Trama TX</span>
                                            <textarea rows="3"
                                                      spellcheck="false"
                                                      disabled="@BloquearEscrituraModbus"
                                                      placeholder="Ejemplo sin CRC: 0D 06 00 00 00 20"
                                                      @bind="SesionActiva.TramaEscrituraModbus"
                                                      @bind:event="oninput"></textarea>
                                            <small>
                                                Puedes usar espacios, comas, guiones o saltos de línea. También se acepta el prefijo 0x.
                                            </small>
                                        </label>

                                        <div class="modbus-frame-toolbar">
                                            <label class="modbus-crc-option">
                                                <input type="checkbox"
                                                       disabled="@BloquearEscrituraModbus"
                                                       @bind="SesionActiva.AgregarCrcAutomaticoTrama" />
                                                <span>
                                                    <strong>CRC automático</strong>
                                                    <small>
                                                        Activado: agrega o corrige CRC. Desactivado: envía exactamente la trama escrita.
                                                    </small>
                                                </span>
                                            </label>

                                            <div class="modbus-frame-actions">
                                                <button type="button"
                                                        class="modbus-frame-clear"
                                                        disabled="@SesionActiva.EscrituraModbusEnCurso"
                                                        @onclick="LimpiarTramaManualModbus">
                                                    Limpiar
                                                </button>

                                                <button type="button"
                                                        class="modbus-write-prepare"
                                                        disabled="@(!PuedePrepararEscrituraModbus || string.IsNullOrWhiteSpace(SesionActiva.TramaEscrituraModbus))"
                                                        @onclick="EnviarTramaManualModbusAsync">
                                                    <span>➤</span>
                                                    @(SesionActiva.EscrituraModbusEnCurso ? "Enviando..." : "Enviar trama")
                                                </button>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(SesionActiva.ResumenTramaManual))
                                        {
                                            <div class="modbus-frame-summary">
                                                <span>Interpretación</span>
                                                <strong>@SesionActiva.ResumenTramaManual</strong>
                                            </div>
                                        }

                                        @if (SesionActiva.MostrarConfirmacionEscrituraModbus)
                                        {
                                            <div class="modbus-write-confirmation" role="alert">
                                                <div class="modbus-write-warning-icon">!</div>
                                                <div class="modbus-write-confirmation-text">
                                                    <strong>La trama contiene una función de escritura</strong>
                                                    <span>
                                                        Revisa la trama final antes de modificar el dispositivo:
                                                        <code>@SesionActiva.TramaPreparadaModbus</code>
                                                    </span>
                                                </div>
                                                <div class="modbus-write-confirmation-actions">
                                                    <button type="button"
                                                            class="modbus-write-cancel"
                                                            @onclick="CancelarEnvioTramaManualModbus">
                                                        Cancelar
                                                    </button>
                                                    <button type="button"
                                                            class="modbus-write-confirm"
                                                            disabled="@SesionActiva.EscrituraModbusEnCurso"
                                                            @onclick="ConfirmarEnvioTramaManualModbusAsync">
                                                        @(SesionActiva.EscrituraModbusEnCurso ? "Enviando..." : "Sí, enviar")
                                                    </button>
                                                </div>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(SesionActiva.TramaPreparadaModbus))
                                        {
                                            <div class="modbus-write-frames">
                                                <div>
                                                    <span>TX final</span>
                                                    <code>@SesionActiva.TramaPreparadaModbus</code>
                                                </div>
                                                <div class="response">
                                                    <span>RX recibida</span>
                                                    <code>@(string.IsNullOrWhiteSpace(SesionActiva.RespuestaEscrituraModbus) ? "Esperando respuesta" : SesionActiva.RespuestaEscrituraModbus)</code>
                                                </div>
                                            </div>
                                        }

                                        <div class="modbus-write-note">
                                            <span>ⓘ</span>
                                            Las funciones 05, 06, 0F y 10 requieren confirmación. Se admiten respuestas de las funciones 01 a 06, 0F y 10.
                                        </div>

                                    </div>
                                </div>
                            </details>

                            <details class="modbus-compact-section">
                                <summary>
                                    <span class="compact-section-title">
                                        <span class="compact-section-icon">↻</span>
                                        <span>
                                            <strong>Lectura automática</strong>
                                            <small>
                                                @(SesionActiva.PollingModbusActivo
                                                    ? $"Activa cada {SesionActiva.IntervaloPollingModbusMs} ms"
                                                    : "Polling, contadores e intervalo")
                                            </small>
                                        </span>
                                    </span>
                                    <span class="compact-section-chevron">⌄</span>
                                </summary>

                                <div class="compact-section-body">
                                    <div class="modbus-polling-panel @(SesionActiva.PollingModbusActivo ? "active" : "")">

                                        <div class="polling-panel-header">
                                            <div>
                                                <strong>Lectura automática</strong>
                                                <span>Evita solicitudes superpuestas</span>
                                            </div>

                                            <button type="button"
                                                    class="polling-action @(SesionActiva.PollingModbusActivo ? "stop" : "start")"
                                                    disabled="@(!SesionActiva.PollingModbusActivo && !PuedeIniciarPollingModbus)"
                                                    @onclick="AlternarPollingModbusAsync">
                                                <span>@(SesionActiva.PollingModbusActivo ? "■" : "▶")</span>
                                                @(SesionActiva.PollingModbusActivo ? "Detener" : "Iniciar")
                                            </button>
                                        </div>

                                        <div class="polling-controls compact">

                                            <label class="numeric-field polling-interval">
                                                <span>Intervalo</span>
                                                <div class="input-with-unit">
                                                    <input type="number"
                                                           min="250"
                                                           max="60000"
                                                           step="250"
                                                           disabled="@SesionActiva.PollingModbusActivo"
                                                           @bind="SesionActiva.IntervaloPollingModbusMs" />
                                                    <span>ms</span>
                                                </div>
                                            </label>

                                            <label class="polling-log-option">
                                                <input type="checkbox"
                                                       @bind="SesionActiva.RegistrarPollingEnTerminal" />
                                                <span>
                                                    <strong>Registrar tramas</strong>
                                                    <small>Agrega TX, RX y CRC a la terminal</small>
                                                </span>
                                            </label>

                                            <div class="polling-stat">
                                                <span>Correctas</span>
                                                <strong>@SesionActiva.LecturasPollingCorrectas</strong>
                                            </div>

                                            <div class="polling-stat error">
                                                <span>Errores</span>
                                                <strong>@SesionActiva.ErroresPolling</strong>
                                            </div>

                                            <div class="polling-stat last">
                                                <span>Última</span>
                                                <strong>
                                                    @(SesionActiva.UltimaLecturaPolling is null
                                                        ? "—"
                                                        : SesionActiva.UltimaLecturaPolling.Value.ToString("HH:mm:ss"))
                                                </strong>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </details>

                            @if (graficaVisible)
                            {
                            <details class="modbus-compact-section graph-compact-section">
                                <summary>
                                    <span class="compact-section-title">
                                        <span class="compact-section-icon graph">⌁</span>
                                        <span>
                                            <strong>Gráfica en tiempo real</strong>
                                            <small>
                                                @(SesionActiva.GraficaActiva
                                                    ? $"Capturando · {SesionActiva.MuestrasGrafica.Count} punto(s)"
                                                    : $"Pausada · {SesionActiva.MuestrasGrafica.Count} punto(s)")
                                            </small>
                                        </span>
                                    </span>
                                    <span class="compact-section-chevron">⌄</span>
                                </summary>

                                <div class="compact-section-body">
                                    <div class="realtime-chart-panel @(SesionActiva.GraficaActiva ? "active" : "paused")">

                                        <div class="chart-toolbar">
                                            <div class="chart-heading">
                                                <div>
                                                    <strong>Registro @SesionActiva.DireccionRegistroGrafica</strong>
                                                    <span>Valor UInt16 recibido durante cada lectura</span>
                                                </div>

                                                <span class="chart-live-badge @(SesionActiva.GraficaActiva ? "live" : "")">
                                                    <span></span>
                                                    @(SesionActiva.GraficaActiva ? "EN VIVO" : "PAUSADA")
                                                </span>
                                            </div>

                                            <div class="chart-actions">
                                                <label class="chart-number-field">
                                                    <span>Registro</span>
                                                    <input type="number"
                                                           min="0"
                                                           max="65535"
                                                           @bind="SesionActiva.DireccionRegistroGrafica" />
                                                </label>

                                                <label class="chart-number-field points">
                                                    <span>Puntos</span>
                                                    <input type="number"
                                                           min="20"
                                                           max="1000"
                                                           step="10"
                                                           @bind="SesionActiva.MaxPuntosGrafica" />
                                                </label>

                                                <button type="button"
                                                        class="chart-action-button @(SesionActiva.GraficaActiva ? "pause" : "start")"
                                                        @onclick="AlternarGraficaTiempoReal">
                                                    <span>@(SesionActiva.GraficaActiva ? "Ⅱ" : "▶")</span>
                                                    @(SesionActiva.GraficaActiva ? "Pausar" : "Continuar")
                                                </button>

                                                <button type="button"
                                                        class="chart-action-button clear"
                                                        disabled="@(SesionActiva.MuestrasGrafica.Count == 0)"
                                                        @onclick="LimpiarGraficaTiempoReal">
                                                    <span>⌫</span>
                                                    Limpiar
                                                </button>
                                            </div>
                                        </div>

                                        <div class="chart-stat-grid">
                                            <div class="chart-stat current">
                                                <span>Actual</span>
                                                <strong>@ValorActualGrafica(SesionActiva)</strong>
                                            </div>
                                            <div class="chart-stat">
                                                <span>Mínimo</span>
                                                <strong>@ValorMinimoGrafica(SesionActiva)</strong>
                                            </div>
                                            <div class="chart-stat">
                                                <span>Máximo</span>
                                                <strong>@ValorMaximoGrafica(SesionActiva)</strong>
                                            </div>
                                            <div class="chart-stat">
                                                <span>Promedio</span>
                                                <strong>@ValorPromedioGrafica(SesionActiva)</strong>
                                            </div>
                                        </div>

                                        @if (SesionActiva.MuestrasGrafica.Count == 0)
                                        {
                                            <div class="chart-empty-state">
                                                <span class="chart-empty-icon">⌁</span>
                                                <strong>Esperando lecturas</strong>
                                                <small>Inicia el polling o presiona Leer para dibujar la gráfica.</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="chart-viewport">
                                                <svg viewBox="0 0 1000 260"
                                                     preserveAspectRatio="none"
                                                     role="img"
                                                     aria-label="Gráfica de lecturas Modbus RTU">
                                                    <line class="chart-grid-line" x1="18" y1="18" x2="982" y2="18" />
                                                    <line class="chart-grid-line" x1="18" y1="74" x2="982" y2="74" />
                                                    <line class="chart-grid-line" x1="18" y1="130" x2="982" y2="130" />
                                                    <line class="chart-grid-line" x1="18" y1="186" x2="982" y2="186" />
                                                    <line class="chart-grid-line" x1="18" y1="242" x2="982" y2="242" />

                                                    <path class="chart-area"
                                                          d="@AreaGraficaSvg(SesionActiva)" />

                                                    <polyline class="chart-line"
                                                              points="@PuntosGraficaSvg(SesionActiva)" />

                                                    <circle class="chart-last-point"
                                                            cx="@UltimoPuntoXGrafica(SesionActiva)"
                                                            cy="@UltimoPuntoYGrafica(SesionActiva)"
                                                            r="6" />
                                                </svg>

                                                <span class="chart-axis-label y-max">@ValorMaximoGrafica(SesionActiva)</span>
                                                <span class="chart-axis-label y-min">@ValorMinimoGrafica(SesionActiva)</span>

                                                <div class="chart-time-axis">
                                                    <span>@HoraPrimeraMuestraGrafica(SesionActiva)</span>
                                                    <span>@HoraUltimaMuestraGrafica(SesionActiva)</span>
                                                </div>
                                            </div>
                                        }

                                        <div class="chart-footnote">
                                            <span>ⓘ</span>
                                            La gráfica conserva los últimos @Math.Clamp(SesionActiva.MaxPuntosGrafica, 20, 1000) puntos y no llena la terminal.
                                        </div>

                                    </div>
                                </div>
                            </details>
                            }

                            <details class="modbus-compact-section">
                                <summary>
                                    <span class="compact-section-title">
                                        <span class="compact-section-icon">CSV</span>
                                        <span>
                                            <strong>Registro de datos</strong>
                                            <small>
                                                @(SesionActiva.RegistroCsvActivo
                                                    ? $"Grabando · {SesionActiva.FilasCsvGuardadas} filas"
                                                    : "Guardar lecturas en CSV")
                                            </small>
                                        </span>
                                    </span>
                                    <span class="compact-section-chevron">⌄</span>
                                </summary>

                                <div class="compact-section-body">
                                    <div class="data-export-panel compact @(SesionActiva.RegistroCsvActivo ? "active" : "")">

                                        <div class="data-export-header">
                                            <div>
                                                <strong>Registro CSV</strong>
                                                <span>Guarda cada lectura Modbus</span>
                                            </div>

                                            <button type="button"
                                                    class="csv-action @(SesionActiva.RegistroCsvActivo ? "stop" : "start")"
                                                    @onclick="AlternarRegistroCsvAsync">
                                                <span>@(SesionActiva.RegistroCsvActivo ? "■" : "●")</span>
                                                @(SesionActiva.RegistroCsvActivo ? "Detener" : "Iniciar CSV")
                                            </button>
                                        </div>

                                        <div class="data-export-status compact">
                                            <div class="export-status-item">
                                                <span>Estado</span>
                                                <strong class="@(SesionActiva.RegistroCsvActivo ? "recording" : "")">
                                                    @(SesionActiva.RegistroCsvActivo ? "Grabando" : "Inactivo")
                                                </strong>
                                            </div>

                                            <div class="export-status-item">
                                                <span>Filas</span>
                                                <strong>@SesionActiva.FilasCsvGuardadas</strong>
                                            </div>

                                            <div class="export-status-item file">
                                                <span>Archivo</span>
                                                <strong title="@SesionActiva.RutaArchivoCsv">
                                                    @(string.IsNullOrWhiteSpace(SesionActiva.RutaArchivoCsv)
                                                        ? "Sin seleccionar"
                                                        : Path.GetFileName(SesionActiva.RutaArchivoCsv))
                                                </strong>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(SesionActiva.UltimoErrorCsv))
                                        {
                                            <div class="csv-error-message">
                                                @SesionActiva.UltimoErrorCsv
                                            </div>
                                        }
                                    </div>
                                </div>
                            </details>

                            <details class="modbus-compact-section">
                                <summary>
                                    <span class="compact-section-title">
                                        <span class="compact-section-icon">HEX</span>
                                        <span>
                                            <strong>Tramas y registros</strong>
                                            <small>
                                                @(SesionActiva.RegistrosModbus.Count == 0
                                                    ? "TX, RX y tabla de resultados"
                                                    : $"{SesionActiva.RegistrosModbus.Count} registro(s) recibido(s)")
                                            </small>
                                        </span>
                                    </span>
                                    <span class="compact-section-chevron">⌄</span>
                                </summary>

                                <div class="compact-section-body compact-results-body">
                                    @if (!string.IsNullOrWhiteSpace(SesionActiva.TramaModbusPrevia))
                                    {
                                        <div class="frame-preview">
                                            <span>TX</span>
                                            <code>@SesionActiva.TramaModbusPrevia</code>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(SesionActiva.UltimaRespuestaModbus))
                                    {
                                        <div class="frame-preview response">
                                            <span>RX</span>
                                            <code>@SesionActiva.UltimaRespuestaModbus</code>
                                        </div>
                                    }

                                    @if (SesionActiva.RegistrosModbus.Count > 0)
                                    {
                                        <div class="modbus-results">

                                            <div class="modbus-results-header">
                                                <div>
                                                    <strong>Registros recibidos</strong>
                                                    <span>@SesionActiva.RegistrosModbus.Count valor(es)</span>
                                                </div>

                                                @if (SesionActiva.CrcModbusValido == true)
                                                {
                                                    <span class="crc-status valid">✓ CRC correcto</span>
                                                }
                                            </div>

                                            <div class="modbus-register-table">
                                                <div class="modbus-register-row header">
                                                    <span>Dirección</span>
                                                    <span>Hexadecimal</span>
                                                    <span>Decimal</span>
                                                    <span>Con signo</span>
                                                </div>

                                                @foreach (RegistroModbusResultado registro in SesionActiva.RegistrosModbus)
                                                {
                                                    <div class="modbus-register-row" @key="registro.Direccion">
                                                        <strong>@registro.Direccion</strong>
                                                        <code>0x@(registro.ValorHex)</code>
                                                        <span>@registro.ValorSinSigno</span>
                                                        <span>@registro.ValorConSigno</span>
                                                    </div>
                                                }
                                            </div>

                                        </div>
                                    }
                                </div>
                            </details>

                        </div>

                        <div class="modbus-stage-note compact @(SerialPortService.EstaConectado ? "active" : "")">
                            <span>ⓘ</span>
                            @(SerialPortService.EstaConectado
                                ? "Consulta lista. Abre las secciones solo cuando necesites más detalles."
                                : "Conecta el puerto RS-485 antes de leer el sensor.")
                        </div>

                    </div>
                }

            </section>

        </section>

    </main>
    }
    else if (ModuloInicioActivo)
    {
        <main class="empty-workspace" aria-label="Área de trabajo vacía"></main>
    }

    @if (mostrarModalPerfiles)
    {
        <div class="profile-modal-backdrop"
             @onclick="CerrarModalPerfiles">

            <section class="profile-modal"
                     role="dialog"
                     aria-modal="true"
                     aria-label="Perfiles de dispositivos"
                     @onclick:stopPropagation="true">

                <header class="profile-modal-header">
                    <div>
                        <span class="profile-modal-eyebrow">HERRAMIENTAS</span>
                        <h2>@(mostrarFormularioPerfil
                            ? perfilEditandoId is null
                                ? "Guardar perfil"
                                : "Editar perfil"
                            : "Perfiles de dispositivos")</h2>
                        <p>@(mostrarFormularioPerfil
                            ? "Guarda una configuración para recuperarla después con un clic."
                            : "Administra tus sensores, adaptadores y equipos habituales.")</p>
                    </div>

                    <button type="button"
                            class="profile-modal-close"
                            title="Cerrar"
                            @onclick="CerrarModalPerfiles">
                        ×
                    </button>
                </header>

                @if (mostrarFormularioPerfil)
                {
                    <div class="profile-form">

                        <label class="profile-field">
                            <span>Nombre del perfil</span>
                            <input type="text"
                                   maxlength="80"
                                   placeholder="Ej. Sensor de voltaje RS-485"
                                   @bind="nombrePerfil"
                                   @bind:event="oninput" />
                        </label>

                        <label class="profile-field">
                            <span>Descripción <small>opcional</small></span>
                            <textarea maxlength="240"
                                      rows="3"
                                      placeholder="Ubicación, modelo o notas del dispositivo"
                                      @bind="descripcionPerfil"></textarea>
                        </label>

                        <div class="profile-current-summary">
                            <div class="profile-type-mark @(FormularioPerfilEsModbus ? "modbus" : "serial")">
                                @(FormularioPerfilEsModbus ? "MB" : ">_")
                            </div>
                            <div>
                                <strong>@NombreTipoFormularioPerfil</strong>
                                <span>@ResumenFormularioPerfil</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(errorPerfil))
                        {
                            <div class="profile-form-error">@errorPerfil</div>
                        }

                        <div class="profile-form-actions">
                            <button type="button"
                                    class="profile-secondary-button"
                                    @onclick="VolverAListaPerfiles">
                                Cancelar
                            </button>

                            <button type="button"
                                    class="profile-primary-button"
                                    disabled="@string.IsNullOrWhiteSpace(nombrePerfil)"
                                    @onclick="GuardarPerfilActualAsync">
                                @(perfilEditandoId is null
                                    ? "Guardar perfil"
                                    : "Guardar cambios")
                            </button>
                        </div>

                    </div>
                }
                else
                {
                    <div class="profile-manager-toolbar">
                        <span>
                            <strong>@perfilesDispositivo.Count</strong>
                            perfil(es) almacenado(s) localmente
                        </span>

                        <button type="button"
                                class="profile-primary-button compact"
                                @onclick="AbrirGuardarPerfil">
                            ＋ Guardar actual
                        </button>
                    </div>

                    <div class="profile-list">

                        @if (perfilesDispositivo.Count == 0)
                        {
                            <div class="profile-empty-state">
                                <span>▤</span>
                                <strong>No hay perfiles guardados</strong>
                                <p>Guarda la configuración de una sesión para verla aquí.</p>
                                <button type="button"
                                        class="profile-primary-button"
                                        @onclick="AbrirGuardarPerfil">
                                    Crear primer perfil
                                </button>
                            </div>
                        }
                        else
                        {
                            @foreach (PerfilDispositivo perfil in perfilesDispositivo)
                            {
                                <article class="profile-card" @key="perfil.Id">

                                    <div class="profile-card-icon @(EsPerfilModbus(perfil) ? "modbus" : "serial")">
                                        @(EsPerfilModbus(perfil) ? "MB" : ">_")
                                    </div>

                                    <div class="profile-card-content">
                                        <div class="profile-card-title">
                                            <div>
                                                <strong>@perfil.Nombre</strong>
                                                <span>@NombreTipoPerfil(perfil)</span>
                                            </div>
                                            <small>@perfil.ActualizadoEn.ToString("dd/MM/yyyy HH:mm")</small>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(perfil.Descripcion))
                                        {
                                            <p>@perfil.Descripcion</p>
                                        }

                                        <div class="profile-card-tags">
                                            <span>@(string.IsNullOrWhiteSpace(perfil.PuertoPreferido)
                                                ? "Puerto automático"
                                                : perfil.PuertoPreferido)</span>
                                            <span>@perfil.Velocidad bps</span>
                                            @if (EsPerfilModbus(perfil))
                                            {
                                                <span>ID @perfil.IdEsclavoModbus</span>
                                                <span>F@perfil.FuncionModbus · R@perfil.DireccionInicialModbus</span>
                                            }
                                        </div>

                                        <div class="profile-card-actions">
                                            <button type="button"
                                                    class="profile-load-button"
                                                    @onclick="() => CargarPerfilAsync(perfil.Id)">
                                                Abrir perfil
                                            </button>

                                            <button type="button"
                                                    class="profile-link-button"
                                                    @onclick="() => EditarPerfil(perfil.Id)">
                                                Editar
                                            </button>

                                            @if (perfilConfirmarEliminacionId == perfil.Id)
                                            {
                                                <button type="button"
                                                        class="profile-delete-button confirm"
                                                        @onclick="() => EliminarPerfilAsync(perfil.Id)">
                                                    Confirmar
                                                </button>

                                                <button type="button"
                                                        class="profile-link-button"
                                                        @onclick="CancelarEliminarPerfil">
                                                    Cancelar
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="profile-delete-button"
                                                        @onclick="() => SolicitarEliminarPerfil(perfil.Id)">
                                                    Eliminar
                                                </button>
                                            }
                                        </div>
                                    </div>

                                </article>
                            }
                        }

                    </div>
                }

            </section>

        </div>
    }

    @if (ModuloIotActivo)
    {
        <main class="iot-module-shell">

            <section class="iot-config-page"
                     aria-label="Configuración serial del equipo IoT">

                <header class="iot-page-header">
                    <div>
                        <span>HERRAMIENTAS · CONFIGURACIÓN SERIAL</span>
                        <h2>Configurar equipo IoT</h2>
                        <p>Configura la red local, el servidor HTTP y el conector usando los comandos del firmware actual.</p>
                    </div>

                    <button type="button"
                            class="iot-page-close"
                            title="Cerrar módulo"
                            disabled="@configuracionIotEnCurso"
                            @onclick="CerrarConfiguracionEquipoIot">
                        ×
                    </button>
                </header>

                <div class="iot-direct-connection">
                    <div class="iot-direct-connection-copy">
                        <span>CONEXIÓN DIRECTA</span>
                        <strong>Puerto serial del configurador</strong>
                        <small>Esta conexión es independiente de las sesiones Terminal serial y Modbus RTU.</small>
                    </div>

                    <div class="iot-selector-field iot-port-selector-field">
                        <span>Puerto COM</span>
                        <div class="iot-dropdown @(mostrarListaPuertosIot ? "open" : "")">
                            <button type="button"
                                    class="iot-dropdown-button"
                                    disabled="@(ServicioIot.EstaConectado || configuracionIotEnCurso)"
                                    @onclick="AlternarListaPuertosIot">
                                <strong>
                                    @(string.IsNullOrWhiteSpace(puertoIotSeleccionado)
                                        ? "Selecciona un puerto"
                                        : puertoIotSeleccionado)
                                </strong>
                                <span>@(mostrarListaPuertosIot ? "▲" : "▼")</span>
                            </button>

                            @if (mostrarListaPuertosIot &&
                                 !ServicioIot.EstaConectado &&
                                 !configuracionIotEnCurso)
                            {
                                <div class="iot-dropdown-options">
                                    @if (puertosIot.Count == 0)
                                    {
                                        <div class="iot-dropdown-empty">
                                            No se detectaron puertos COM.
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (string puerto in puertosIot)
                                        {
                                            <button type="button"
                                                    class="iot-dropdown-option @(string.Equals(puerto, puertoIotSeleccionado, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                                    @onclick="() => SeleccionarPuertoIot(puerto)">
                                                <span>COM</span>
                                                <strong>@puerto</strong>
                                            </button>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="iot-selector-field iot-baud-selector-field">
                        <span>Baud rate</span>
                        <div class="iot-dropdown @(mostrarListaVelocidadesIot ? "open" : "")">
                            <button type="button"
                                    class="iot-dropdown-button"
                                    disabled="@(ServicioIot.EstaConectado || configuracionIotEnCurso)"
                                    @onclick="AlternarListaVelocidadesIot">
                                <strong>@configuracionSerialIot.Velocidad bps</strong>
                                <span>@(mostrarListaVelocidadesIot ? "▲" : "▼")</span>
                            </button>

                            @if (mostrarListaVelocidadesIot &&
                                 !ServicioIot.EstaConectado &&
                                 !configuracionIotEnCurso)
                            {
                                <div class="iot-dropdown-options baud-options">
                                    @foreach (int velocidad in velocidadesIot)
                                    {
                                        <button type="button"
                                                class="iot-dropdown-option @(velocidad == configuracionSerialIot.Velocidad ? "selected" : "")"
                                                @onclick="() => SeleccionarVelocidadIot(velocidad)">
                                            <span>bps</span>
                                            <strong>@velocidad</strong>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="iot-control-lines">
                        <span>Líneas USB</span>
                        <div class="iot-control-lines-options">
                            <label title="Data Terminal Ready. Algunos Arduino, Pico y puertos USB CDC lo necesitan para transmitir al PC.">
                                <input type="checkbox"
                                       disabled="@(ServicioIot.EstaConectado || configuracionIotEnCurso)"
                                       @bind="configuracionSerialIot.HabilitarDtr" />
                                <span>DTR</span>
                            </label>
                            <label title="Request To Send. Normalmente puede permanecer desactivado.">
                                <input type="checkbox"
                                       disabled="@(ServicioIot.EstaConectado || configuracionIotEnCurso)"
                                       @bind="configuracionSerialIot.HabilitarRts" />
                                <span>RTS</span>
                            </label>
                        </div>
                    </div>

                    <button type="button"
                            class="iot-refresh-ports"
                            title="Actualizar puertos"
                            disabled="@(ServicioIot.EstaConectado || configuracionIotEnCurso)"
                            @onclick="ActualizarPuertosIot">
                        ↻
                    </button>

                    <button type="button"
                            class="iot-connect-button @(ServicioIot.EstaConectado ? "disconnect" : "connect")"
                            disabled="@configuracionIotEnCurso"
                            @onclick="AlternarConexionIot">
                        @(ServicioIot.EstaConectado ? "Desconectar" : "Conectar")
                    </button>
                </div>

                <div class="iot-config-body">

                    <div class="iot-config-workspace">

                        <div class="iot-config-editor">

                            <div class="iot-status-banner @ClaseEstadoConfiguracionIot">
                                <span class="iot-status-icon">@IconoEstadoConfiguracionIot</span>
                                <div>
                                    <strong>@TextoEstadoConfiguracionIot</strong>
                                    <small>@MensajeEstadoConfiguracionIot</small>
                                </div>
                            </div>

                            <div class="iot-config-note">
                                <span>COM</span>
                                <div>
                                    <strong>Comandos reconocidos por el firmware</strong>
                                    <small>Cada botón envía un comando compatible con el firmware actual. Los cambios se guardan en la EEPROM AT24C256.</small>
                                </div>
                            </div>

                            <div class="iot-config-grid">
                                <div class="iot-field iot-field-id">
                                    <span>ID del dispositivo</span>
                                    <input type="text"
                                           maxlength="24"
                                           placeholder="LC0001C"
                                           disabled="@configuracionIotEnCurso"
                                           @bind="idModuloIot"
                                           @bind:event="oninput" />
                                    <small>Debe coincidir con ID_DEVICE en el firmware.</small>
                                </div>

                                <div class="iot-field iot-field-wide">
                                    <span>Modo de red local</span>
                                    <div class="iot-network-mode-selector">
                                        <button type="button"
                                                class="@(modoDhcpIot ? "active" : "")"
                                                disabled="@configuracionIotEnCurso"
                                                @onclick="() => SeleccionarModoRedIot(true)">
                                            <strong>DHCP</strong>
                                            <small>IP automática</small>
                                        </button>

                                        <button type="button"
                                                class="@(!modoDhcpIot ? "active" : "")"
                                                disabled="@configuracionIotEnCurso"
                                                @onclick="() => SeleccionarModoRedIot(false)">
                                            <strong>IP estática</strong>
                                            <small>IP y máscara manuales</small>
                                        </button>

                                        @if (modoDhcpIot)
                                        {
                                            <button type="button"
                                                    class="iot-network-mode-send"
                                                    disabled="@(!PuedeOperarConfiguracionIot)"
                                                    @onclick="EnviarDhcpIotAsync">
                                                Enviar DHCP
                                            </button>
                                        }
                                    </div>
                                    <small>DHCP envía ID_DEVICEdhcpZ. El cambio se aplica al reiniciar el controlador.</small>
                                </div>

                                @if (!modoDhcpIot)
                                {
                                    <div class="iot-field">
                                        <span>IP local estática</span>
                                        <input type="text"
                                               maxlength="15"
                                               placeholder="192.168.1.50"
                                               disabled="@configuracionIotEnCurso"
                                               @bind="ipLocalIot"
                                               @bind:event="oninput" />
                                        <small>Dirección IPv4 del controlador.</small>
                                    </div>

                                    <div class="iot-field">
                                        <span>Máscara local</span>
                                        <div class="iot-field-control">
                                            <input type="text"
                                                   maxlength="15"
                                                   placeholder="255.255.255.0"
                                                   disabled="@configuracionIotEnCurso"
                                                   @bind="mascaraLocalIot"
                                                   @bind:event="oninput" />
                                            <button type="button"
                                                    disabled="@(!PuedeOperarConfiguracionIot)"
                                                    @onclick="EnviarRedLocalEstaticaIotAsync">
                                                Enviar red
                                            </button>
                                        </div>
                                        <small>Envía ID_DEVICEIP/MASCARAZ.</small>
                                    </div>
                                }

                                <div class="iot-field">
                                    <span>IP del servidor</span>
                                    <input type="text"
                                           maxlength="15"
                                           placeholder="192.168.1.200"
                                           disabled="@configuracionIotEnCurso"
                                           @bind="ipServidorIot"
                                           @bind:event="oninput" />
                                    <small>Dirección IPv4 del servidor HTTP.</small>
                                </div>

                                <div class="iot-field">
                                    <span>Máscara del servidor</span>
                                    <div class="iot-field-control">
                                        <input type="text"
                                               maxlength="15"
                                               placeholder="255.255.255.0"
                                               disabled="@configuracionIotEnCurso"
                                               @bind="mascaraServidorIot"
                                               @bind:event="oninput" />
                                        <button type="button"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="EnviarServidorIotAsync">
                                            Enviar
                                        </button>
                                    </div>
                                    <small>Envía ID_DEVICE_IP/MASCARAZ.</small>
                                </div>

                                <div class="iot-field">
                                    <span>Puerto HTTP</span>
                                    <div class="iot-field-control">
                                        <input type="number"
                                               min="1"
                                               max="65535"
                                               disabled="@configuracionIotEnCurso"
                                               @bind="puertoServidorIot" />
                                        <button type="button"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="EnviarPuertoServidorIotAsync">
                                            Enviar
                                        </button>
                                    </div>
                                    <small>Envía ID_DEVICEPUERTOZ. Rango: 1 a 65535.</small>
                                </div>

                                <div class="iot-field">
                                    <span>Tiempo de envío</span>
                                    <div class="iot-field-control iot-period-control">
                                        <div class="iot-input-with-unit">
                                            <input type="number"
                                                   min="1"
                                                   max="65535"
                                                   disabled="@configuracionIotEnCurso"
                                                   @bind="periodoEnvioIot" />
                                            <span>min</span>
                                        </div>
                                        <button type="button"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="EnviarPeriodoIotAsync">
                                            Enviar
                                        </button>
                                    </div>
                                    <small>Envía ID_DEVICETIEMPOM.</small>
                                </div>

                                <div class="iot-field iot-field-wide">
                                    <span>URL del conector</span>
                                    <div class="iot-field-control">
                                        <input type="text"
                                               maxlength="180"
                                               placeholder="e_IOT/DISPOSITIVOS/D.PHP?"
                                               disabled="@configuracionIotEnCurso"
                                               @bind="rutaConectorIot"
                                               @bind:event="oninput" />
                                        <button type="button"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="EnviarRutaConectorIotAsync">
                                            Enviar
                                        </button>
                                    </div>
                                    <small>El signo ? se agrega cuando falta. El comando termina con ! y admite hasta 180 caracteres.</small>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(errorConfiguracionIot))
                            {
                                <div class="iot-config-error">
                                    @errorConfiguracionIot
                                </div>
                            }

                            <div class="iot-device-actions">
                                <div class="iot-device-actions-copy">
                                    <span>ACCIONES DEL CONTROLADOR</span>
                                    <strong>Consultar o reiniciar el equipo</strong>
                                    <small>La lectura no modifica la EEPROM. El reinicio envía el comando RAW <code>@($"{IdModuloIotNormalizado}resetZ")</code>.</small>
                                </div>

                                <div class="iot-device-actions-buttons">
                                    <button type="button"
                                            class="iot-action-button read"
                                            disabled="@(!PuedeOperarConfiguracionIot)"
                                            @onclick="LeerConfiguracionEquipoIotAsync">
                                        <span>↧</span>
                                        <span>
                                            <strong>@(leyendoConfiguracionIot ? "Leyendo..." : "Leer configuración")</strong>
                                            <small>Consultar EEPROM</small>
                                        </span>
                                    </button>

                                    @if (confirmarResetIot)
                                    {
                                        <button type="button"
                                                class="iot-action-button cancel-reset"
                                                disabled="@configuracionIotEnCurso"
                                                @onclick="CancelarResetIot">
                                            Cancelar
                                        </button>

                                        <button type="button"
                                                class="iot-action-button confirm-reset"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="EnviarResetIotAsync">
                                            <span>↻</span>
                                            <span>
                                                <strong>Confirmar reinicio</strong>
                                                <small>Enviar resetZ</small>
                                            </span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="iot-action-button reset"
                                                disabled="@(!PuedeOperarConfiguracionIot)"
                                                @onclick="SolicitarResetIot">
                                            <span>↻</span>
                                            <span>
                                                <strong>Reiniciar equipo</strong>
                                                <small>Solicita confirmación</small>
                                            </span>
                                        </button>
                                    }
                                </div>
                            </div>

                        </div>

                        <aside class="iot-live-terminal">
                            <header class="iot-terminal-header">
                                <div>
                                    <span>TERMINAL SERIAL</span>
                                    <strong>Transmisión y recepción del controlador</strong>
                                </div>

                                <div class="iot-terminal-header-actions">
                                    <label class="iot-terminal-autoscroll">
                                        <input type="checkbox"
                                               @bind="autoScrollTerminalIot" />
                                        <span>Auto scroll</span>
                                    </label>

                                    <button type="button"
                                            title="Limpiar esta terminal"
                                            @onclick="LimpiarTerminalIot">
                                        Limpiar
                                    </button>
                                </div>
                            </header>

                            <div class="iot-terminal-screen"
                                 @ref="terminalIotElement">
                                @if (lineasTerminalIot.Count == 0 &&
                                     string.IsNullOrWhiteSpace(fragmentoRecepcionIot))
                                {
                                    <div class="iot-terminal-empty">
                                        <span>COM</span>
                                        <strong>Esperando datos del controlador</strong>
                                        <small>Todo lo que transmita el microcontrolador aparecerá aquí, incluso cuando todavía no haya enviado un salto de línea.</small>
                                    </div>
                                }
                                else
                                {
                                    @foreach (string linea in lineasTerminalIot)
                                    {
                                        <div class="iot-terminal-line @ClaseLinea(linea)">
                                            <span class="iot-terminal-time">@MarcaTiempoLinea(linea)</span>
                                            <span class="iot-terminal-kind">@TipoVisualLinea(linea)</span>
                                            <span class="iot-terminal-content">@ContenidoVisualLinea(linea)</span>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(fragmentoRecepcionIot))
                                    {
                                        <div class="iot-terminal-line received live">
                                            <span class="iot-terminal-time">@MarcaTiempoLinea(fragmentoRecepcionIot)</span>
                                            <span class="iot-terminal-kind">RX</span>
                                            <span class="iot-terminal-content">@ContenidoVisualLinea(fragmentoRecepcionIot)<span class="iot-live-cursor">▌</span></span>
                                        </div>
                                    }
                                }
                            </div>

                            <div class="iot-terminal-send">
                                <span class="iot-terminal-send-prefix">TX</span>
                                <input type="text"
                                       placeholder="Escribe un comando RAW..."
                                       autocomplete="off"
                                       disabled="@(!ServicioIot.EstaConectado || configuracionIotEnCurso)"
                                       @bind="textoManualIot"
                                       @bind:event="oninput"
                                       @onkeydown="ManejarTeclaEnvioManualIot" />
                                <button type="button"
                                        disabled="@(!PuedeEnviarTextoManualIot)"
                                        @onclick="EnviarTextoManualIot">
                                    Enviar
                                </button>
                            </div>

                            <footer class="iot-terminal-footer">
                                <span class="@(ServicioIot.EstaConectado ? "online" : "offline")"></span>
                                <strong>@(ServicioIot.EstaConectado ? ServicioIot.PuertoActual : "Sin conexión")</strong>
                                <small>RAW · @configuracionSerialIot.Velocidad bps · DTR @(configuracionSerialIot.HabilitarDtr ? "ON" : "OFF") · RX @bytesRecibidosIot byte(s)</small>
                            </footer>
                        </aside>

                    </div>

                </div>
            </section>
        </main>
    }

    @if (mostrarModalServidorRest)
    {
        <div class="profile-modal-backdrop"
             @onclick="CerrarConfiguracionServidorRest">

            <section class="profile-modal rest-modal rest-destinations-modal"
                     role="dialog"
                     aria-modal="true"
                     aria-label="Destinos de datos HTTP REST"
                     @onclick:stopPropagation="true">

                <header class="profile-modal-header rest-modal-header">
                    <div>
                        <span class="profile-modal-eyebrow">CD TERMINAL PRO · HTTP REST</span>
                        <h2>Destinos de datos</h2>
                        <p>Configura uno o varios servidores y decide cuáles reciben las lecturas Modbus RTU.</p>
                    </div>

                    <button type="button"
                            class="profile-modal-close"
                            title="Cerrar"
                            @onclick="CerrarConfiguracionServidorRest">
