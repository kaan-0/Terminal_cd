    private void SeleccionarVelocidadIot(int velocidad)
    {
        if (ServicioIot.EstaConectado || configuracionIotEnCurso ||
            !velocidadesIot.Contains(velocidad))
        {
            return;
        }

        configuracionSerialIot.Velocidad = velocidad;
        mostrarListaVelocidadesIot = false;
        errorConfiguracionIot = string.Empty;
