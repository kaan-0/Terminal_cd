    protected override void OnInitialized()
    {
        TerminalSesion primeraSesion =
            CrearSesion(TipoSesion.Serial);

        sesiones.Add(primeraSesion);
        sesionActivaId = primeraSesion.Id;

        ServicioIot =
            ServiceProvider.GetRequiredService<ISerialPortService>();

        configuracionSerialIot.Velocidad = 9600;
        configuracionSerialIot.BitsDeDatos = 8;
        configuracionSerialIot.Paridad = Parity.None;
        configuracionSerialIot.BitsDeParada = StopBits.One;
        configuracionSerialIot.ControlDeFlujo = Handshake.None;
        // Muchos controladores USB CDC no transmiten hasta que el host activa DTR.
        configuracionSerialIot.HabilitarDtr = true;
        configuracionSerialIot.HabilitarRts = false;

        ServicioIot.DatosRecibidos += AlRecibirDatosIot;
        ServicioIot.ErrorOcurrido += AlOcurrirErrorIot;
        ServicioIot.ConexionPerdida += AlPerderConexionIot;

        perfilesDispositivo =
            PerfilDispositivoService.ObtenerPerfiles();

        RecargarDestinosRest();

        ActualizarPuertos(primeraSesion);
        ActualizarPuertosIot();
    }

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        if (ModuloIotActivo &&
            autoScrollTerminalIot &&
            scrollTerminalIotPendiente)
        {
            scrollTerminalIotPendiente = false;

            await JSRuntime.InvokeVoidAsync(
                "cdTerminal.scrollToBottom",
                terminalIotElement
            );
        }

        if (!ModuloSesionActivo)
        {
            return;
        }

        TerminalSesion sesion = SesionActiva;

        if (!terminalVisible ||
            !sesion.ScrollPendiente ||
            !sesion.AutoScroll)
        {
            return;
        }

        sesion.ScrollPendiente = false;

        await JSRuntime.InvokeVoidAsync(
            "cdTerminal.scrollToBottom",
            terminalElement
        );
    }

    private TerminalSesion CrearSesion(
        TipoSesion tipo,
        ConfiguracionSerial? configuracionBase = null)
    {
        int id = siguienteIdSesion++;
        int numero = tipo == TipoSesion.ModbusRtu
            ? siguienteNumeroModbus++
            : siguienteNumeroSerial++;

        string nombre = tipo == TipoSesion.ModbusRtu
            ? $"Modbus RTU {numero}"
            : $"Terminal {numero}";

        ISerialPortService servicio =
            ServiceProvider.GetRequiredService<ISerialPortService>();

        ConfiguracionSerial nuevaConfiguracion =
            CrearCopiaConfiguracion(configuracionBase);

        TerminalSesion sesion = new(
            id,
            nombre,
            tipo,
            servicio,
            nuevaConfiguracion
        );

        sesion.ManejadorDatos = (_, datos) =>
            AlRecibirDatos(sesion, datos);

        sesion.ManejadorError = (_, error) =>
            AlOcurrirError(sesion, error);

        sesion.ManejadorConexionPerdida = (_, mensaje) =>
            AlPerderConexion(sesion, mensaje);

        servicio.DatosRecibidos += sesion.ManejadorDatos;
        servicio.ErrorOcurrido += sesion.ManejadorError;
        servicio.ConexionPerdida +=
            sesion.ManejadorConexionPerdida;

        return sesion;
    }

