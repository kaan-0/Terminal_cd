                            </span>
                        </label>

                        <div class="rest-stat-grid">
                            <div class="rest-stat">
                                <span>Envíos correctos</span>
                                <strong>@EstadoServidorRestSeleccionado.EnviosCorrectos</strong>
                            </div>
                            <div class="rest-stat error">
                                <span>Fallidos</span>
                                <strong>@EstadoServidorRestSeleccionado.EnviosFallidos</strong>
                            </div>
                            <div class="rest-stat">
                                <span>Último envío</span>
                                <strong>@(EstadoServidorRestSeleccionado.UltimaTransmision is null
                                    ? "—"
                                    : EstadoServidorRestSeleccionado.UltimaTransmision.Value.ToString("HH:mm:ss"))</strong>
                            </div>
                            <div class="rest-stat">
                                <span>Último HTTP</span>
                                <strong>@(EstadoServidorRestSeleccionado.UltimoCodigoHttp?.ToString() ?? "—")</strong>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(errorServidorRest))
                        {
                            <div class="profile-form-error rest-error">
                                @errorServidorRest
                            </div>
                        }

                        <div class="rest-form-actions rest-destination-actions">
                            <button type="button"
                                    class="profile-secondary-button"
                                    disabled="@operacionServidorRestEnCurso"
                                    @onclick="ProbarConexionServidorRestAsync">
                                @(pruebaServidorRestEnCurso ? "Probando..." : "Probar conexión")
                            </button>

                            <button type="button"
                                    class="rest-send-button"
                                    disabled="@(!PuedeEnviarUltimaLecturaServidorRest)"
                                    @onclick="EnviarUltimaLecturaServidorRestAsync">
                                @(envioServidorRestEnCurso ? "Enviando..." : "Enviar última lectura")
                            </button>

                            <button type="button"
                                    class="profile-primary-button"
                                    disabled="@operacionServidorRestEnCurso"
                                    @onclick="GuardarConfiguracionServidorRestAsync">
                                @(guardadoServidorRestEnCurso ? "Guardando..." : "Guardar destino")
                            </button>

                            @if (!EsDestinoRestNuevo)
                            {
                                @if (destinoRestConfirmarEliminacionId == destinoRestEditando.Id)
                                {
                                    <button type="button"
                                            class="profile-delete-button confirm rest-delete-destination"
                                            disabled="@operacionServidorRestEnCurso"
                                            @onclick="EliminarDestinoRestAsync">
                                        Confirmar eliminación
                                    </button>

                                    <button type="button"
                                            class="profile-link-button"
                                            disabled="@operacionServidorRestEnCurso"
                                            @onclick="CancelarEliminarDestinoRest">
                                        Cancelar
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="profile-delete-button rest-delete-destination"
                                            disabled="@operacionServidorRestEnCurso"
                                            @onclick="SolicitarEliminarDestinoRest">
                                        Eliminar
                                    </button>
                                }
                            }
                        </div>

                    </div>

                </div>

            </section>

        </div>
    }

    @if (MostrarBarraEstadoActual)
    {
    <footer class="app-statusbar">

        <div class="statusbar-message">
            <span class="statusbar-icon">ⓘ</span>
            <span>
                @(string.IsNullOrWhiteSpace(mensajeEstado)
                    ? "CD Terminal listo."
