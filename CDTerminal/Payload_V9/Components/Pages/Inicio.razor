                            </label>

                            <label class="profile-field">
                                <span>Ruta de prueba</span>
                                <input type="text"
                                       placeholder="/health"
                                       disabled="@operacionServidorRestEnCurso"
                                       @bind="destinoRestEditando.RutaPrueba" />
