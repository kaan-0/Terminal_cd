    private static string LimpiarContenidoTerminalIot(string contenido)
    {
        return contenido
            .Replace("\0", string.Empty)
            .Replace("\r\n", " ")
            .Replace('\r', ' ')
            .Replace('\n', ' ')
            .Trim();
    }

    private void AgregarLineaTerminalIot(
        string tipo,
        string contenido)
    {
        string contenidoLimpio =
            LimpiarContenidoTerminalIot(contenido);

        if (string.IsNullOrWhiteSpace(contenidoLimpio))
        {
            return;
        }

        lineasTerminalIot.Add(
            $"[{DateTime.Now:HH:mm:ss.fff}] {tipo}: {contenidoLimpio}"
        );

        if (lineasTerminalIot.Count > 500)
        {
            lineasTerminalIot.RemoveRange(
                0,
                lineasTerminalIot.Count - 500
            );
        }

        scrollTerminalIotPendiente = true;
    }

    private void LimpiarTerminalIot()
    {
        lineasTerminalIot.Clear();
        bufferRecepcionIot.Clear();
        fragmentoRecepcionIot = string.Empty;
        scrollTerminalIotPendiente = false;
        errorConfiguracionIot = string.Empty;
    }

    private static bool EsDireccionIpv4Valida(string valor)
    {
        return System.Net.IPAddress.TryParse(
                   valor.Trim(),
                   out System.Net.IPAddress? direccion) &&
               direccion.AddressFamily ==
                   System.Net.Sockets.AddressFamily.InterNetwork;
    }

    private static bool EsMascaraIpv4Valida(string valor)
    {
        if (!System.Net.IPAddress.TryParse(
                valor.Trim(),
                out System.Net.IPAddress? mascara) ||
            mascara.AddressFamily !=
                System.Net.Sockets.AddressFamily.InterNetwork)
        {
            return false;
        }

        byte[] bytes = mascara.GetAddressBytes();
        uint numero =
            ((uint)bytes[0] << 24) |
            ((uint)bytes[1] << 16) |
            ((uint)bytes[2] << 8) |
            bytes[3];

        if (numero == 0 || numero == uint.MaxValue)
        {
            return false;
        }

        uint inversa = ~numero;
        return (inversa & (inversa + 1)) == 0;
    }

    private static string NormalizarRutaConectorIot(string ruta)
    {
        string resultado = ruta.Trim().TrimStart('/');

        if (!resultado.EndsWith(
                "?",
                StringComparison.Ordinal))
        {
            resultado += "?";
        }

        return resultado;
    }

    private void PrepararLecturaConfiguracionIot()
    {
        leyendoConfiguracionIot = true;
        lecturaIotFinalizada = false;
    }

    private bool LecturaConfiguracionIotCompleta()
    {
        return lecturaIotFinalizada;
    }

    private void ProcesarLineaConfiguracionIot(string linea)
    {
        if (!leyendoConfiguracionIot)
        {
            return;
        }

        string lineaLimpia = linea.Trim();

        if (lineaLimpia.Contains(
                "FIN DE LA CONFIGURACION",
                StringComparison.OrdinalIgnoreCase))
        {
            lecturaIotFinalizada = true;
            leyendoConfiguracionIot = false;
            mensajeConfiguracionIot =
                "Configuración leída correctamente desde la EEPROM del equipo.";
            mensajeEstado =
                "Configuración del equipo IoT recibida.";
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "ID del dispositivo",
                out string idDispositivo) &&
            !string.IsNullOrWhiteSpace(idDispositivo))
        {
            idModuloIot = idDispositivo;
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "Modo de red",
                out string modoRed))
        {
            modoDhcpIot = modoRed.Contains(
                "DHCP",
                StringComparison.OrdinalIgnoreCase);
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "IP local",
                out string ipLocal))
        {
            ipLocalIot = EsDireccionIpv4Valida(ipLocal)
                ? ipLocal
                : string.Empty;
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "Mascara local",
                out string mascaraLocal))
        {
            mascaraLocalIot = EsMascaraIpv4Valida(mascaraLocal)
                ? mascaraLocal
                : mascaraLocalIot;
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "IP del servidor",
                out string ipServidor))
        {
            ipServidorIot = EsDireccionIpv4Valida(ipServidor)
                ? ipServidor
                : string.Empty;
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "Mascara servidor",
                out string mascaraServidor))
        {
            mascaraServidorIot = EsMascaraIpv4Valida(mascaraServidor)
                ? mascaraServidor
                : mascaraServidorIot;
            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "Puerto HTTP",
                out string puerto))
        {
            string numeroPuerto = puerto
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .FirstOrDefault() ?? string.Empty;

            if (int.TryParse(numeroPuerto, out int puertoLeido))
            {
                puertoServidorIot = puertoLeido;
            }

            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "Tiempo de envio",
                out string periodo))
        {
            string numeroPeriodo = periodo
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .FirstOrDefault() ?? string.Empty;

            if (int.TryParse(numeroPeriodo, out int periodoLeido))
            {
                periodoEnvioIot = periodoLeido;
            }

            return;
        }

        if (TryObtenerValorEtiquetaIot(
                lineaLimpia,
                "URL del conector",
                out string conector))
        {
            rutaConectorIot = conector.Equals(
                "No configurada",
                StringComparison.OrdinalIgnoreCase)
                    ? string.Empty
                    : conector;
        }
    }

    private static bool TryObtenerValorEtiquetaIot(
        string linea,
        string etiquetaEsperada,
        out string valor)
    {
        valor = string.Empty;
        int posicionDosPuntos = linea.IndexOf(':');

        if (posicionDosPuntos <= 0)
        {
            return false;
        }

        string etiqueta = linea[..posicionDosPuntos].Trim();

        if (!etiqueta.Equals(
                etiquetaEsperada,
                StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        valor = linea[(posicionDosPuntos + 1)..].Trim();
        return !string.IsNullOrWhiteSpace(valor);
    }

