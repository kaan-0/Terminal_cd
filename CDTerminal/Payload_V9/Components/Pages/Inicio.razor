    private void Conectar()
    {
        TerminalSesion sesion = SesionActiva;

        try
        {
            IReadOnlyList<string> puertosDisponibles =
                sesion.Servicio.ObtenerPuertosDisponibles();

            sesion.Puertos = puertosDisponibles;

            if (string.IsNullOrWhiteSpace(
                    sesion.PuertoSeleccionado))
            {
                sesion.MensajeEstado =
                    "Selecciona un puerto COM antes de conectar.";
                return;
            }

            if (!puertosDisponibles.Contains(
                    sesion.PuertoSeleccionado,
                    StringComparer.OrdinalIgnoreCase))
            {
                sesion.MensajeEstado =
                    $"El puerto {sesion.PuertoSeleccionado} ya no está disponible. " +
                    "Actualiza la lista y vuelve a seleccionarlo.";

                AgregarLineaTerminal(
                    sesion,
                    "ERROR",
                    sesion.MensajeEstado
                );
                return;
            }

            sesion.Configuracion.NombrePuerto =
                sesion.PuertoSeleccionado;

            sesion.Servicio.Conectar(
                sesion.Configuracion
            );

            sesion.ConexionPerdidaNotificada = false;
            sesion.MostrarListaPuertos = false;
            sesion.MensajeEstado =
                $"Conexión establecida en " +
                $"{sesion.PuertoSeleccionado}.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Conectado a {sesion.PuertoSeleccionado} " +
                $"a {sesion.Configuracion.Velocidad} bps."
            );
        }
        catch (UnauthorizedAccessException)
        {
            sesion.MensajeEstado =
                $"No se puede acceder a " +
                $"{sesion.PuertoSeleccionado}. " +
                "Probablemente está siendo utilizado por " +
                "otra terminal o programa.";
        }
        catch (IOException ex)
        {
            sesion.MensajeEstado =
                $"Error de comunicación: {ex.Message}";
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible conectar: {ex.Message}";
        }
    }

    private async Task DesconectarAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesion,
                registrarMensaje: true
            );
        }

        if (sesion.ConsultaModbusEnCurso ||
            sesion.EscrituraModbusEnCurso)
        {
            sesion.MensajeEstado =
                "Espera a que termine la operación Modbus antes de desconectar.";
            return;
        }

        if (sesion.RegistroCsvActivo)
        {
            DetenerRegistroCsv(
                sesion,
                "Registro CSV detenido al desconectar el puerto."
            );
        }

        try
        {
            string puertoAnterior =
                sesion.Servicio.PuertoActual ??
                sesion.PuertoSeleccionado;

            sesion.Servicio.Desconectar();

            sesion.MensajeEstado =
                $"El puerto {puertoAnterior} fue desconectado.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Puerto {puertoAnterior} desconectado."
            );
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible desconectar: {ex.Message}";
        }
    }

    private void AlRecibirDatos(
        TerminalSesion sesion,
        string datos)
    {
        if (sesion.Tipo == TipoSesion.ModbusRtu)
        {
            return;
        }

        if (string.IsNullOrEmpty(datos))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            ProcesarDatosRecibidos(sesion, datos);
            StateHasChanged();
        });
    }

    private void ProcesarDatosRecibidos(
        TerminalSesion sesion,
        string datos)
    {
        foreach (char caracter in datos)
        {
            if (caracter == '\r')
            {
                CompletarLineaRecibida(sesion);
                sesion.IgnorarSiguienteLf = true;
                continue;
            }

            if (caracter == '\n')
            {
                if (sesion.IgnorarSiguienteLf)
                {
                    sesion.IgnorarSiguienteLf = false;
                    continue;
                }

                CompletarLineaRecibida(sesion);
                continue;
            }

            sesion.IgnorarSiguienteLf = false;
            sesion.BufferLineaRecepcion.Append(caracter);
        }
    }

    private void CompletarLineaRecibida(
        TerminalSesion sesion)
    {
        string linea = sesion.BufferLineaRecepcion
            .ToString()
            .Trim();

        sesion.BufferLineaRecepcion.Clear();

        if (string.IsNullOrWhiteSpace(linea))
        {
            return;
        }

        AgregarLineaTerminal(
            sesion,
            "RX",
            linea
        );
    }

    private void AlOcurrirError(
        TerminalSesion sesion,
        string error)
    {
        _ = InvokeAsync(() =>
        {
            AgregarLineaTerminal(
                sesion,
                "ERROR",
                error
            );

            sesion.MensajeEstado = error;
            StateHasChanged();
        });
    }


    private void AlPerderConexion(
        TerminalSesion sesion,
        string mensaje)
    {
        _ = InvokeAsync(() =>
        {
            if (componenteLiberado ||
                sesion.ConexionPerdidaNotificada)
            {
                return;
            }

            sesion.ConexionPerdidaNotificada = true;
            sesion.PollingCancellation?.Cancel();
            sesion.PollingModbusActivo = false;
            sesion.MostrarConfirmacionEscrituraModbus = false;
            sesion.UltimoErrorPolling = mensaje;

            if (sesion.RegistroCsvActivo)
            {
                DetenerRegistroCsv(
                    sesion,
                    "Registro CSV detenido porque se perdió la conexión serial."
                );
            }

            try
            {
                sesion.Puertos =
                    sesion.Servicio.ObtenerPuertosDisponibles();
            }
            catch
            {
                sesion.Puertos = Array.Empty<string>();
            }

            sesion.MensajeEstado =
                mensaje + " Reconecta el adaptador, actualiza los puertos " +
                "y conecta nuevamente.";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                sesion.MensajeEstado
            );

            StateHasChanged();
        });
    }

    private void AgregarLineaTerminal(
        string tipo,
        string contenido)
    {
        AgregarLineaTerminal(
            SesionActiva,
            tipo,
            contenido
        );
    }

    private static void AgregarLineaTerminal(
        TerminalSesion sesion,
        string tipo,
        string contenido)
    {
        string contenidoLimpio = contenido
            .Replace("\r\n", " ")
            .Replace('\r', ' ')
            .Replace('\n', ' ')
            .Trim();

        if (string.IsNullOrWhiteSpace(contenidoLimpio))
        {
            return;
        }

        string texto =
            $"[{DateTime.Now:HH:mm:ss.fff}] " +
            $"{tipo}: {contenidoLimpio}";

        sesion.LineasTerminal.Add(texto);

        if (sesion.LineasTerminal.Count > 500)
        {
            int cantidadEliminar =
                sesion.LineasTerminal.Count - 500;

            sesion.LineasTerminal.RemoveRange(
                0,
                cantidadEliminar
            );
        }

        if (sesion.AutoScroll)
        {
            sesion.ScrollPendiente = true;
        }
    }

    private void LimpiarTerminal()
    {
        TerminalSesion sesion = SesionActiva;

        sesion.LineasTerminal.Clear();
        sesion.BufferLineaRecepcion.Clear();
        sesion.IgnorarSiguienteLf = false;
        sesion.MensajeEstado =
            "La terminal fue limpiada.";
    }

    private async Task ExportarTerminalTxtAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.LineasTerminal.Count == 0)
        {
            sesion.MensajeEstado =
                "No hay registros en la terminal para exportar.";
            return;
        }

        string nombreSugerido =
            $"CDTerminal_{CrearNombreArchivoSeguro(sesion.Nombre)}_" +
            $"{DateTime.Now:yyyyMMdd_HHmmss}.txt";

        string? ruta = FileExportService.SeleccionarRutaGuardado(
            nombreSugerido,
            ".txt",
            "Archivo de texto (*.txt)|*.txt|Todos los archivos (*.*)|*.*"
        );

        if (string.IsNullOrWhiteSpace(ruta))
        {
            return;
        }

        try
        {
            StringBuilder contenido = new();

            contenido.AppendLine("CD Terminal");
            contenido.AppendLine("========================================");
            contenido.AppendLine($"Sesión: {sesion.Nombre}");
            contenido.AppendLine($"Tipo: {NombreTipoSesion(sesion.Tipo)}");
            contenido.AppendLine($"Exportado: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
            contenido.AppendLine(
                $"Puerto: {sesion.Servicio.PuertoActual ?? sesion.PuertoSeleccionado}"
            );
            contenido.AppendLine(
                $"Configuración: {sesion.Configuracion.Velocidad} bps, " +
                $"{sesion.Configuracion.BitsDeDatos} bits, " +
                $"{NombreParidad(sesion.Configuracion.Paridad)}, " +
                $"{NombreBitsParada(sesion.Configuracion.BitsDeParada)} stop"
            );
            contenido.AppendLine($"Registros: {sesion.LineasTerminal.Count}");
            contenido.AppendLine("========================================");
            contenido.AppendLine();

            foreach (string linea in sesion.LineasTerminal)
            {
                contenido.AppendLine(linea);
            }

            await FileExportService.EscribirTextoAsync(
                ruta,
                contenido.ToString(),
                anexar: false
            );

            sesion.MensajeEstado =
                $"Terminal exportada en {Path.GetFileName(ruta)}.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Terminal guardada en TXT: {Path.GetFileName(ruta)}"
            );
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible guardar el TXT: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                sesion.MensajeEstado
            );
        }
    }

    private async Task AlternarRegistroCsvAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.Tipo != TipoSesion.ModbusRtu)
        {
            return;
        }

        if (sesion.RegistroCsvActivo)
        {
            DetenerRegistroCsv(
                sesion,
                "Registro continuo CSV detenido."
            );

            await InvokeAsync(StateHasChanged);
            return;
        }

        string nombreSugerido =
            $"CDTerminal_{CrearNombreArchivoSeguro(sesion.Nombre)}_" +
            $"{DateTime.Now:yyyyMMdd_HHmmss}.csv";

        string? ruta = FileExportService.SeleccionarRutaGuardado(
            nombreSugerido,
            ".csv",
            "Archivo CSV (*.csv)|*.csv|Todos los archivos (*.*)|*.*"
        );

        if (string.IsNullOrWhiteSpace(ruta))
        {
            return;
        }

        try
        {
            const string encabezado =
                "FechaHora,Sesion,Puerto,IdEsclavo,Funcion," +
                "DireccionInicial,CantidadSolicitada,DireccionRegistro," +
                "Hexadecimal,DecimalSinSigno,DecimalConSigno," +
                "TramaTX,TramaRX,CRCValido\r\n";

            await FileExportService.EscribirTextoAsync(
                ruta,
                encabezado,
                anexar: false
            );

            sesion.RutaArchivoCsv = ruta;
            sesion.RegistroCsvActivo = true;
            sesion.FilasCsvGuardadas = 0;
            sesion.InicioRegistroCsv = DateTime.Now;
            sesion.UltimoErrorCsv = string.Empty;
            sesion.MensajeEstado =
                $"Registro CSV activo: {Path.GetFileName(ruta)}.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Registro CSV iniciado: {Path.GetFileName(ruta)}"
            );
        }
        catch (Exception ex)
        {
            sesion.RegistroCsvActivo = false;
            sesion.UltimoErrorCsv = ex.Message;
            sesion.MensajeEstado =
                $"No fue posible iniciar el CSV: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                sesion.MensajeEstado
            );
        }
    }

    private static void DetenerRegistroCsv(
        TerminalSesion sesion,
        string mensaje)
    {
        if (!sesion.RegistroCsvActivo)
        {
            return;
        }

        sesion.RegistroCsvActivo = false;
        sesion.MensajeEstado = mensaje;

        AgregarLineaTerminal(
            sesion,
            "SYS",
            $"{mensaje} Filas guardadas: {sesion.FilasCsvGuardadas}."
        );
    }

    private async Task RegistrarLecturaCsvAsync(
        TerminalSesion sesion)
    {
        if (!sesion.RegistroCsvActivo ||
            string.IsNullOrWhiteSpace(sesion.RutaArchivoCsv) ||
            sesion.RegistrosModbus.Count == 0)
        {
            return;
        }

        await sesion.BloqueoCsv.WaitAsync();

        try
        {
            if (!sesion.RegistroCsvActivo)
            {
                return;
            }

            DateTime fechaHora = DateTime.Now;
            string puerto =
                sesion.Servicio.PuertoActual ??
                sesion.PuertoSeleccionado;

            StringBuilder filas = new();

            foreach (RegistroModbusResultado registro in
                     sesion.RegistrosModbus)
            {
                string[] columnas =
                [
                    fechaHora.ToString(
                        "yyyy-MM-dd HH:mm:ss.fff",
                        CultureInfo.InvariantCulture
                    ),
                    sesion.Nombre,
                    puerto,
                    sesion.IdEsclavoModbus.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    sesion.FuncionModbus,
                    sesion.DireccionInicialModbus.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    sesion.CantidadRegistrosModbus.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    registro.Direccion.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    $"0x{registro.ValorHex}",
                    registro.ValorSinSigno.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    registro.ValorConSigno.ToString(
                        CultureInfo.InvariantCulture
                    ),
                    sesion.TramaModbusPrevia,
                    sesion.UltimaRespuestaModbus,
                    sesion.CrcModbusValido == true
                        ? "SI"
                        : "NO"
                ];

                filas.AppendLine(
                    string.Join(",", columnas.Select(EscaparCsv))
                );
            }

            await FileExportService.EscribirTextoAsync(
                sesion.RutaArchivoCsv,
                filas.ToString(),
                anexar: true
            );

            sesion.FilasCsvGuardadas +=
                sesion.RegistrosModbus.Count;
            sesion.UltimoErrorCsv = string.Empty;
        }
        catch (Exception ex)
        {
            sesion.RegistroCsvActivo = false;
            sesion.UltimoErrorCsv = ex.Message;
            sesion.MensajeEstado =
                $"El registro CSV se detuvo: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                sesion.MensajeEstado
            );
        }
        finally
        {
            sesion.BloqueoCsv.Release();
        }
    }

    private static string EscaparCsv(string valor)
    {
        string seguro = valor.Replace("\"", "\"\"");
        return $"\"{seguro}\"";
    }

    private static string CrearNombreArchivoSeguro(string valor)
    {
        HashSet<char> invalidos =
            Path.GetInvalidFileNameChars().ToHashSet();

        string limpio = new(
            valor.Select(caracter =>
                    invalidos.Contains(caracter) ||
                    char.IsWhiteSpace(caracter)
                        ? '_'
                        : caracter)
                .ToArray()
        );

        return string.IsNullOrWhiteSpace(limpio)
            ? "Sesion"
            : limpio;
    }

    private static string ClaseLinea(string linea)
    {
        if (linea.Contains(
                "ERROR:",
                StringComparison.Ordinal))
        {
            return "error";
        }

        if (linea.Contains(
                "SYS:",
                StringComparison.Ordinal))
        {
            return "system";
        }

        if (linea.Contains(
                "TX:",
                StringComparison.Ordinal))
        {
            return "sent";
        }

        return "received";
    }

