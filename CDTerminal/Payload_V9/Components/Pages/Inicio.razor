    }

    private void ActualizarPuertosIot()
    {
        if (ServicioIot.EstaConectado)
        {
            return;
        }

        mostrarListaPuertosIot = false;
        mostrarListaVelocidadesIot = false;

        try
        {
            puertosIot = ServicioIot.ObtenerPuertosDisponibles();

            if (!string.IsNullOrWhiteSpace(puertoIotSeleccionado) &&
                !puertosIot.Contains(
                    puertoIotSeleccionado,
                    StringComparer.OrdinalIgnoreCase))
            {
                puertoIotSeleccionado = string.Empty;
            }

            if (string.IsNullOrWhiteSpace(puertoIotSeleccionado) &&
                puertosIot.Count == 1)
            {
                puertoIotSeleccionado = puertosIot[0];
            }

            mensajeConfiguracionIot = puertosIot.Count == 0
                ? "No se detectaron puertos COM. Conecta el controlador y actualiza."
                : $"{puertosIot.Count} puerto(s) disponible(s).";
        }
        catch (Exception ex)
        {
            errorConfiguracionIot =
                $"No fue posible actualizar los puertos: {ex.Message}";
        }
    }

    private void AlternarConexionIot()
    {
        if (configuracionIotEnCurso)
        {
            return;
        }

        errorConfiguracionIot = string.Empty;
        mostrarListaPuertosIot = false;
        mostrarListaVelocidadesIot = false;

        if (ServicioIot.EstaConectado)
        {
            DesconectarIotSilenciosamente();
            mensajeConfiguracionIot = "Controlador desconectado.";
            AgregarLineaTerminalIot("SYS", "Conexión serial cerrada.");
            ActualizarPuertosIot();
            return;
        }

        if (string.IsNullOrWhiteSpace(puertoIotSeleccionado))
        {
            MostrarErrorConfiguracionIot(
                "Selecciona el puerto COM del controlador."
            );
            return;
        }

        try
        {
            configuracionSerialIot.NombrePuerto =
                puertoIotSeleccionado;

            // Garantiza que esta terminal sea la que recibe el evento RX, incluso
            // después de cerrar y volver a abrir el módulo varias veces.
            ServicioIot.DatosRecibidos -= AlRecibirDatosIot;
            ServicioIot.ErrorOcurrido -= AlOcurrirErrorIot;
            ServicioIot.ConexionPerdida -= AlPerderConexionIot;
            ServicioIot.DatosRecibidos += AlRecibirDatosIot;
            ServicioIot.ErrorOcurrido += AlOcurrirErrorIot;
            ServicioIot.ConexionPerdida += AlPerderConexionIot;

            bytesRecibidosIot = 0;
            eventosRecepcionIot = 0;

            ServicioIot.Conectar(configuracionSerialIot);
            bufferRecepcionIot.Clear();
            fragmentoRecepcionIot = string.Empty;
            ignorarSiguienteLfIot = false;

            mensajeConfiguracionIot =
                $"Conectado a {ServicioIot.PuertoActual} a {configuracionSerialIot.Velocidad} bps. Escuchando RX continuamente.";

            AgregarLineaTerminalIot(
                "SYS",
                $"Conectado a {ServicioIot.PuertoActual} · {configuracionSerialIot.Velocidad} bps · 8N1 · RAW · DTR {(configuracionSerialIot.HabilitarDtr ? "ON" : "OFF")} · RTS {(configuracionSerialIot.HabilitarRts ? "ON" : "OFF")}."
            );
        }
        catch (Exception ex)
        {
            errorConfiguracionIot =
                $"No fue posible conectar {puertoIotSeleccionado}: {ex.Message}";
            mensajeConfiguracionIot = "La conexión serial falló.";
            ActualizarPuertosIot();
        }
    }

    private void DesconectarIotSilenciosamente()
    {
        leyendoConfiguracionIot = false;
        mostrarListaPuertosIot = false;
        mostrarListaVelocidadesIot = false;
        bufferRecepcionIot.Clear();
        fragmentoRecepcionIot = string.Empty;
        ignorarSiguienteLfIot = false;

        if (!ServicioIot.EstaConectado)
        {
            return;
        }

        try
        {
            ServicioIot.Desconectar();
        }
        catch
        {
            // La navegación no debe quedar bloqueada por un error al cerrar el puerto.
        }
    }

    private void AlRecibirDatosIot(
        object? sender,
        string datos)
    {
        if (string.IsNullOrEmpty(datos))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            bytesRecibidosIot += Encoding.ASCII.GetByteCount(datos);
            eventosRecepcionIot++;
            ProcesarDatosRecibidosIot(datos);
            StateHasChanged();
        });
    }

    private void ProcesarDatosRecibidosIot(string datos)
    {
        foreach (char caracter in datos)
        {
            if (caracter == '\r')
            {
                CompletarLineaRecibidaIot();
                ignorarSiguienteLfIot = true;
                continue;
            }

            if (caracter == '\n')
            {
                if (ignorarSiguienteLfIot)
                {
                    ignorarSiguienteLfIot = false;
                    continue;
                }

                CompletarLineaRecibidaIot();
                continue;
            }

            ignorarSiguienteLfIot = false;

            if (bufferRecepcionIot.Length == 0)
            {
                marcaInicioFragmentoIot = DateTime.Now;
            }

            bufferRecepcionIot.Append(caracter);

            // Evita que una transmisión sin CR/LF crezca indefinidamente.
            if (bufferRecepcionIot.Length >= 1024)
            {
                CompletarLineaRecibidaIot();
            }
        }

        ActualizarFragmentoRecepcionIot();
    }

    private void ActualizarFragmentoRecepcionIot()
    {
        if (bufferRecepcionIot.Length == 0)
        {
            fragmentoRecepcionIot = string.Empty;
            return;
        }

        string contenido = LimpiarContenidoTerminalIot(
            bufferRecepcionIot.ToString()
        );

        fragmentoRecepcionIot = string.IsNullOrWhiteSpace(contenido)
            ? string.Empty
            : $"[{marcaInicioFragmentoIot:HH:mm:ss.fff}] RX: {contenido}";

        scrollTerminalIotPendiente = true;
    }

    private void CompletarLineaRecibidaIot()
    {
        string linea = LimpiarContenidoTerminalIot(
            bufferRecepcionIot.ToString()
        );

        bufferRecepcionIot.Clear();
        fragmentoRecepcionIot = string.Empty;

        if (string.IsNullOrWhiteSpace(linea))
        {
            return;
        }

        ProcesarLineaConfiguracionIot(linea);
        AgregarLineaTerminalIot("RX", linea);
    }

    private void AlOcurrirErrorIot(
        object? sender,
        string error)
    {
        _ = InvokeAsync(() =>
        {
            errorConfiguracionIot = error;
            mensajeConfiguracionIot = "Ocurrió un error en la conexión serial.";
            AgregarLineaTerminalIot("ERROR", error);
            StateHasChanged();
        });
    }

    private void AlPerderConexionIot(
        object? sender,
        string mensaje)
    {
        _ = InvokeAsync(() =>
        {
            bool desconexionEsperada = reinicioIotSolicitado;
            reinicioIotSolicitado = false;
            leyendoConfiguracionIot = false;
            configuracionIotEnCurso = false;
            confirmarResetIot = false;

            mensajeConfiguracionIot = desconexionEsperada
                ? "El controlador recibió la orden de reinicio. Espera unos segundos y vuelve a conectar el puerto."
                : mensaje;

            AgregarLineaTerminalIot(
                desconexionEsperada ? "SYS" : "ERROR",
                desconexionEsperada
                    ? "El puerto se cerró durante el reinicio del controlador."
                    : mensaje
            );

            try
            {
                puertosIot = ServicioIot.ObtenerPuertosDisponibles();
            }
            catch
            {
                puertosIot = Array.Empty<string>();
            }

            StateHasChanged();
        });
    }

    private async Task LeerConfiguracionEquipoIotAsync()
    {
        if (!PuedeOperarConfiguracionIot)
        {
            return;
        }

        errorConfiguracionIot = string.Empty;
        configuracionIotEnCurso = true;
        PrepararLecturaConfiguracionIot();
        mensajeConfiguracionIot =
            "Solicitando la configuración guardada en EEPROM con el comando CONFIG...";

        try
        {
            string comando = $"{IdModuloIotNormalizado}configZ";
            EnviarComandoConfiguracionIot(comando);

            await Task.Delay(5200);

            if (leyendoConfiguracionIot)
            {
                leyendoConfiguracionIot = false;
                mensajeConfiguracionIot =
                    "El comando fue enviado, pero la respuesta no llegó completa. Revisa la terminal RX.";
            }
        }
        catch (Exception ex)
        {
            leyendoConfiguracionIot = false;
            errorConfiguracionIot =
                $"No fue posible leer la configuración: {ex.Message}";
            mensajeConfiguracionIot =
                "La lectura de configuración falló.";
        }
        finally
        {
            configuracionIotEnCurso = false;
        }
    }

