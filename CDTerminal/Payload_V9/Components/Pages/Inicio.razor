    private void SolicitarResetIot()
    {
        if (!PuedeOperarConfiguracionIot)
        {
            return;
        }

        confirmarResetIot = true;
        errorConfiguracionIot = string.Empty;
        mensajeConfiguracionIot =
            "Confirma el reinicio. El puerto serial puede desconectarse temporalmente.";
    }

    private void CancelarResetIot()
    {
        if (configuracionIotEnCurso)
        {
            return;
        }

        confirmarResetIot = false;
        mensajeConfiguracionIot =
            "Reinicio cancelado. El controlador continúa conectado.";
    }

    private async Task EnviarResetIotAsync()
    {
        if (!PuedeOperarConfiguracionIot)
        {
            return;
        }

        if (!ValidarIdModuloIot(out string error))
        {
            MostrarErrorConfiguracionIot(error);
            return;
        }

        confirmarResetIot = false;
        errorConfiguracionIot = string.Empty;
        configuracionIotEnCurso = true;
        reinicioIotSolicitado = true;
        mensajeConfiguracionIot =
            "Enviando la orden de reinicio al controlador...";

        try
        {
            string comando = $"{IdModuloIotNormalizado}resetZ";
            EnviarComandoConfiguracionIot(comando);

            mensajeEstado = "Configuración IoT: orden de reinicio enviada.";

            // El puerto puede permanecer abierto o cerrarse según el bootloader.
            await Task.Delay(1800);

            if (reinicioIotSolicitado)
            {
                reinicioIotSolicitado = false;
                mensajeConfiguracionIot =
                    "Orden de reinicio enviada. Espera a que el controlador vuelva a iniciar.";
                AgregarLineaTerminalIot(
                    "SYS",
                    "Comando de reinicio enviado; esperando el arranque del controlador."
                );
            }
        }
        catch (Exception ex)
        {
            reinicioIotSolicitado = false;
            errorConfiguracionIot =
                $"No fue posible reiniciar el controlador: {ex.Message}";
            mensajeConfiguracionIot =
                "La orden de reinicio no pudo enviarse.";
            AgregarLineaTerminalIot("ERROR", errorConfiguracionIot);
        }
        finally
        {
            configuracionIotEnCurso = false;
        }
    }

    private async Task EnviarComandoIndividualConfiguracionIotAsync(
        string nombreCampo,
        string comando,
        bool esperarConfiguracionCompleta = false)
    {
        if (!PuedeOperarConfiguracionIot)
        {
            return;
        }

        errorConfiguracionIot = string.Empty;
        configuracionIotEnCurso = true;
        leyendoConfiguracionIot = false;
        mensajeConfiguracionIot =
            $"Enviando {nombreCampo} al controlador...";

        try
        {
            if (esperarConfiguracionCompleta)
            {
                PrepararLecturaConfiguracionIot();
            }

            EnviarComandoConfiguracionIot(comando);

            await Task.Delay(
                esperarConfiguracionCompleta
                    ? 5200
                    : 1600
            );

            bool configuracionRecibida =
                esperarConfiguracionCompleta &&
                LecturaConfiguracionIotCompleta();

            if (esperarConfiguracionCompleta)
            {
                leyendoConfiguracionIot = false;
            }

            mensajeConfiguracionIot = configuracionRecibida
                ? $"{nombreCampo} enviado y configuración confirmada por el equipo."
                : $"{nombreCampo} enviado. Revisa la respuesta en el monitor serial.";

            mensajeEstado =
                $"Configuración IoT: {nombreCampo} enviado.";
        }
        catch (Exception ex)
        {
            leyendoConfiguracionIot = false;
            errorConfiguracionIot =
                $"No fue posible enviar {nombreCampo}: {ex.Message}";
            mensajeConfiguracionIot =
                "El comando no pudo completarse.";

            AgregarLineaTerminalIot(
                "ERROR",
                errorConfiguracionIot
            );
        }
        finally
        {
            configuracionIotEnCurso = false;
        }
    }

    private bool ValidarIdModuloIot(out string error)
    {
        error = string.Empty;
        string id = IdModuloIotNormalizado;

        if (string.IsNullOrWhiteSpace(id) ||
            !id.All(caracter =>
                char.IsLetterOrDigit(caracter) ||
                caracter == '-' ||
                caracter == '_'))
        {
            error =
                "El ID del módulo es obligatorio y solo puede contener letras, números, guion o guion bajo.";
            return false;
        }

        return true;
    }

