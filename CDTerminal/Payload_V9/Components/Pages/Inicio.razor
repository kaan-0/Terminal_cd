                            <div class="rest-connection-icon">@IconoEstadoServidorRest</div>
                            <div>
                                <strong>@TextoEstadoServidorRest</strong>
                                <span>@MensajeEstadoServidorRest</span>
                            </div>
                        </div>

                        <div class="rest-form-grid">
                            <label class="profile-field">
                                <span>Nombre del destino</span>
