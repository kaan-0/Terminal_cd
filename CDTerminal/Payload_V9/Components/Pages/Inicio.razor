    private async Task EnviarLecturaServidorSiCorrespondeAsync(
        TerminalSesion sesion,
        bool esPolling,
        CancellationToken cancellationToken)
    {
        IReadOnlyList<ConfiguracionServidorRest> destinos =
            ServidorRestService.ObtenerDestinos()
                .Where(destino =>
                    destino.Activo &&
                    destino.EnvioAutomatico &&
                    !string.IsNullOrWhiteSpace(destino.UrlBase) &&
                    !string.IsNullOrWhiteSpace(destino.RutaLecturas))
                .ToList();

        if (destinos.Count == 0)
        {
            return;
        }

        foreach (ConfiguracionServidorRest destino in destinos)
        {
            cancellationToken.ThrowIfCancellationRequested();

            await EnviarLecturaDestinoRestAsync(
                destino,
                sesion,
                esPolling ? "polling" : "manual",
                registrarEnTerminal:
                    !esPolling || sesion.RegistrarPollingEnTerminal,
                cancellationToken
            );
        }
    }

    private async Task<bool> EnviarLecturaDestinoRestAsync(
        ConfiguracionServidorRest destino,
        TerminalSesion sesion,
        string origen,
        bool registrarEnTerminal,
        CancellationToken cancellationToken)
    {
        if (sesion.RegistrosModbus.Count == 0)
        {
            return false;
        }

        EstadoDestinoRest estado = ObtenerEstadoDestinoRest(destino.Id);

        try
        {
            LecturaServidorRest lectura =
                CrearLecturaServidorRest(destino, sesion, origen);

            ResultadoServidorRest resultado =
                await ServidorRestService.EnviarLecturaAsync(
                    destino,
                    lectura,
                    cancellationToken
                );

            AplicarResultadoDestinoRest(
                destino,
                resultado,
                esEnvio: true,
                sesion: sesion
            );

            if (resultado.Exitoso)
            {
                if (registrarEnTerminal)
                {
                    AgregarLineaTerminal(
                        sesion,
                        "SYS",
                        $"REST [{destino.Nombre}] enviado · HTTP " +
                        $"{resultado.CodigoEstado} · " +
                        $"{resultado.Duracion.TotalMilliseconds:F0} ms."
                    );
                }

                estado.UltimoErrorRegistrado = string.Empty;
                return true;
            }

            bool errorNuevo = !string.Equals(
                estado.UltimoErrorRegistrado,
                resultado.Mensaje,
                StringComparison.Ordinal
            );

            if (registrarEnTerminal || errorNuevo)
            {
                AgregarLineaTerminal(
                    sesion,
                    "ERROR",
                    $"REST [{destino.Nombre}]: {resultado.Mensaje}"
                );
            }

            estado.UltimoErrorRegistrado = resultado.Mensaje;
            return false;
        }
        catch (OperationCanceledException)
            when (cancellationToken.IsCancellationRequested)
        {
            return false;
        }
        finally
        {
            if (!componenteLiberado)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void AplicarResultadoDestinoRest(
        ConfiguracionServidorRest destino,
        ResultadoServidorRest resultado,
        bool esEnvio,
        TerminalSesion? sesion = null)
    {
        EstadoDestinoRest estado = ObtenerEstadoDestinoRest(destino.Id);
        estado.Disponible = resultado.Exitoso;
        estado.UltimoCodigoHttp = resultado.CodigoEstado;

        if (resultado.Exitoso)
        {
            errorServidorRest = string.Empty;
            estado.Mensaje = esEnvio
                ? $"Lectura enviada en " +
                  $"{resultado.Duracion.TotalMilliseconds:F0} ms."
                : $"Conexión correcta en " +
                  $"{resultado.Duracion.TotalMilliseconds:F0} ms.";

            if (esEnvio)
            {
                estado.EnviosCorrectos++;
                estado.UltimaTransmision = DateTime.Now;
            }
        }
        else
        {
            estado.Mensaje = resultado.Mensaje;

            if (destino.Id == destinoRestEditando.Id)
            {
                errorServidorRest = resultado.Mensaje;
            }

            if (esEnvio)
            {
                estado.EnviosFallidos++;
            }
        }

        string mensaje = resultado.Exitoso
            ? $"{destino.Nombre}: {estado.Mensaje}"
            : $"{destino.Nombre}: {resultado.Mensaje}";

        if (sesion is null)
        {
            mensajeEstado = mensaje;
        }
        else
        {
            sesion.MensajeEstado = mensaje;
        }
    }

    private EstadoDestinoRest ObtenerEstadoDestinoRest(Guid destinoId)
    {
        if (!estadosDestinosRest.TryGetValue(
                destinoId,
                out EstadoDestinoRest? estado))
        {
            estado = new EstadoDestinoRest();
            estadosDestinosRest[destinoId] = estado;
        }

        return estado;
    }

    private static string ClaseEstadoDestinoRest(
        EstadoDestinoRest estado)
    {
        return estado.Disponible switch
        {
            true => "connected",
            false => "failed",
            _ => "idle"
        };
    }

    private LecturaServidorRest CrearLecturaServidorRest(
        ConfiguracionServidorRest destino,
        TerminalSesion sesion,
        string origen)
    {
        return new LecturaServidorRest
        {
            DeviceId = destino.IdDispositivo.Trim(),
            TimestampUtc = DateTime.UtcNow,
            Source = origen,
            Session = sesion.Nombre,
            Port = sesion.Servicio.PuertoActual ??
                   sesion.PuertoSeleccionado,
            BaudRate = sesion.Configuracion.Velocidad,
            SlaveId = sesion.IdEsclavoModbus,
            Function = sesion.FuncionModbus == "04" ? 4 : 3,
            StartAddress = sesion.DireccionInicialModbus,
            RequestedQuantity = sesion.CantidadRegistrosModbus,
            CrcValid = sesion.CrcModbusValido == true,
            Tx = sesion.TramaModbusPrevia,
            Rx = sesion.UltimaRespuestaModbus,
            Registers = sesion.RegistrosModbus
                .Select(registro => new RegistroServidorRest
                {
                    Address = registro.Direccion,
                    Hex = registro.ValorHex,
                    Unsigned = registro.ValorSinSigno,
                    Signed = registro.ValorConSigno
                })
                .ToList()
        };
    }

