    private static string PuntosGraficaSvg(
        TerminalSesion sesion)
    {
        IReadOnlyList<MuestraGrafica> muestras =
            sesion.MuestrasGrafica;

        if (muestras.Count == 0)
        {
            return string.Empty;
        }

        const double ancho = 1000;
        const double alto = 260;
        const double margenX = 18;
        const double margenY = 18;

        (double minimo, double maximo) =
            ObtenerRangoGrafica(muestras);

        double anchoUtil = ancho - margenX * 2;
        double altoUtil = alto - margenY * 2;
        double rango = maximo - minimo;

        List<string> puntos = new(muestras.Count);

        for (int indice = 0;
             indice < muestras.Count;
             indice++)
        {
            double x = muestras.Count == 1
                ? ancho / 2
                : margenX +
                    indice * anchoUtil /
                    (muestras.Count - 1);

            double proporcion =
                (muestras[indice].Valor - minimo) /
                rango;

            double y = margenY +
                (1 - proporcion) * altoUtil;

            puntos.Add(
                $"{FormatoSvg(x)},{FormatoSvg(y)}"
            );
        }

        return string.Join(" ", puntos);
    }

    private static string AreaGraficaSvg(
        TerminalSesion sesion)
    {
        string puntos = PuntosGraficaSvg(sesion);

        if (string.IsNullOrWhiteSpace(puntos))
        {
            return string.Empty;
        }

        string[] lista = puntos.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries
        );

        string primerX = lista[0].Split(',')[0];
        string ultimoX = lista[^1].Split(',')[0];

        return $"M {primerX},242 L {puntos} " +
               $"L {ultimoX},242 Z";
    }

    private static string UltimoPuntoXGrafica(
        TerminalSesion sesion)
    {
        string puntos = PuntosGraficaSvg(sesion);

        if (string.IsNullOrWhiteSpace(puntos))
        {
            return "500";
        }

        string ultimo = puntos.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries
        )[^1];

        return ultimo.Split(',')[0];
    }

    private static string UltimoPuntoYGrafica(
        TerminalSesion sesion)
    {
        string puntos = PuntosGraficaSvg(sesion);

        if (string.IsNullOrWhiteSpace(puntos))
        {
            return "130";
        }

        string ultimo = puntos.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries
        )[^1];

        return ultimo.Split(',')[1];
    }

    private static (double Minimo, double Maximo)
        ObtenerRangoGrafica(
            IReadOnlyList<MuestraGrafica> muestras)
    {
        double minimo = muestras.Min(
            muestra => (double)muestra.Valor
        );

        double maximo = muestras.Max(
            muestra => (double)muestra.Valor
        );

        if (Math.Abs(maximo - minimo) < 0.0001)
        {
            double margen = Math.Max(
                1,
                Math.Abs(maximo) * 0.05
            );

            minimo -= margen;
            maximo += margen;
        }
        else
        {
            double margen =
                (maximo - minimo) * 0.08;

            minimo -= margen;
            maximo += margen;
        }

        return (minimo, maximo);
    }

    private static string FormatoSvg(double valor)
    {
        return valor.ToString(
            "0.###",
            CultureInfo.InvariantCulture
        );
    }

    private static bool ValidarParametrosModbus(
        TerminalSesion sesion)
    {
        if (sesion.IdEsclavoModbus is < 1 or > 247)
        {
            sesion.MensajeEstado =
                "El ID del esclavo debe estar entre 1 y 247.";
            return false;
        }

        if (sesion.DireccionInicialModbus is < 0 or > 65535)
        {
            sesion.MensajeEstado =
                "La dirección inicial debe estar entre 0 y 65535.";
            return false;
        }

        if (sesion.CantidadRegistrosModbus is < 1 or > 125)
        {
            sesion.MensajeEstado =
                "La cantidad de registros debe estar entre 1 y 125.";
            return false;
        }

        long ultimaDireccion =
            (long)sesion.DireccionInicialModbus +
            sesion.CantidadRegistrosModbus - 1;

        if (ultimaDireccion > 65535)
        {
            sesion.MensajeEstado =
                "La consulta supera la dirección Modbus 65535.";
            return false;
        }

        if (sesion.TimeoutModbusMs is < 100 or > 10000)
        {
            sesion.MensajeEstado =
                "El tiempo de espera debe estar entre 100 y 10000 ms.";
            return false;
        }

        if (sesion.ReintentosModbus is < 0 or > 10)
        {
            sesion.MensajeEstado =
                "Los reintentos deben estar entre 0 y 10.";
            return false;
        }

        return true;
    }

    private static bool ValidarParametrosEscrituraModbus(
        TerminalSesion sesion)
    {
        if (sesion.IdEsclavoModbus is < 1 or > 247)
        {
            sesion.MensajeEstado =
                "El ID del esclavo debe estar entre 1 y 247.";
            return false;
        }

        if (sesion.DireccionEscrituraModbus is < 0 or > 65535)
        {
            sesion.MensajeEstado =
                "La dirección de escritura debe estar entre 0 y 65535.";
            return false;
        }

        if (sesion.ValorEscrituraModbus is < 0 or > 65535)
        {
            sesion.MensajeEstado =
                "El valor debe estar entre 0 y 65535.";
            return false;
        }

        if (sesion.TimeoutModbusMs is < 100 or > 10000)
        {
            sesion.MensajeEstado =
                "El tiempo de espera debe estar entre 100 y 10000 ms.";
            return false;
        }

        if (sesion.ReintentosModbus is < 0 or > 10)
        {
            sesion.MensajeEstado =
                "Los reintentos deben estar entre 0 y 10.";
            return false;
        }

        return true;
    }

    private static void ProcesarRespuestaEscrituraModbus(
        TerminalSesion sesion,
        byte[] solicitud,
        byte[] respuesta)
    {
        sesion.RespuestaEscrituraModbus =
            ConvertirAHex(respuesta);

        AgregarLineaTerminal(
            sesion,
            "RX",
            sesion.RespuestaEscrituraModbus
        );

        if (respuesta.Length < 5)
        {
            throw new InvalidDataException(
                "La respuesta de escritura Modbus está incompleta."
            );
        }

        ushort crcCalculado = CalcularCrcModbus(
            respuesta.AsSpan(0, respuesta.Length - 2)
        );

        ushort crcRecibido = (ushort)(
            respuesta[^2] |
            (respuesta[^1] << 8)
        );

        sesion.CrcEscrituraModbusValido =
            crcCalculado == crcRecibido;

        if (sesion.CrcEscrituraModbusValido != true)
        {
            throw new InvalidDataException(
                $"CRC de escritura incorrecto. Recibido " +
                $"0x{crcRecibido:X4}, calculado 0x{crcCalculado:X4}."
            );
        }

        if (respuesta[0] != (byte)sesion.IdEsclavoModbus)
        {
            throw new InvalidDataException(
                $"Respondió el esclavo {respuesta[0]}, " +
                $"pero se esperaba el {sesion.IdEsclavoModbus}."
            );
        }

        byte funcionRespuesta = respuesta[1];

        if (funcionRespuesta == 0x86)
        {
            byte codigoExcepcion = respuesta[2];

            throw new InvalidOperationException(
                $"Excepción Modbus 0x{codigoExcepcion:X2}: " +
                DescribirExcepcionModbus(codigoExcepcion)
            );
        }

        if (funcionRespuesta != 0x06)
        {
            throw new InvalidDataException(
                $"La función recibida 0x{funcionRespuesta:X2} " +
                "no corresponde a la función 06."
            );
        }

        if (respuesta.Length != 8)
        {
            throw new InvalidDataException(
                $"La respuesta F06 debe contener 8 bytes y se " +
                $"recibieron {respuesta.Length}."
            );
        }

        if (!respuesta.AsSpan(0, 6)
            .SequenceEqual(solicitud.AsSpan(0, 6)))
        {
            throw new InvalidDataException(
                "El dispositivo respondió con una dirección o valor " +
                "diferente al solicitado."
            );
        }
    }

    private static void ProcesarRespuestaModbus(
        TerminalSesion sesion,
        byte[] respuesta,
        byte funcionSolicitada,
        bool registrarEnTerminal)
    {
        sesion.UltimaRespuestaModbus =
            ConvertirAHex(respuesta);

        if (registrarEnTerminal)
        {
            AgregarLineaTerminal(
                sesion,
                "RX",
                sesion.UltimaRespuestaModbus
            );
        }

        if (respuesta.Length < 5)
        {
            throw new InvalidDataException(
                "La respuesta Modbus está incompleta."
            );
        }

        ushort crcCalculado = CalcularCrcModbus(
            respuesta.AsSpan(0, respuesta.Length - 2)
        );

        ushort crcRecibido = (ushort)(
            respuesta[^2] |
            (respuesta[^1] << 8)
        );

        sesion.CrcModbusValido =
            crcCalculado == crcRecibido;

        if (sesion.CrcModbusValido != true)
        {
            throw new InvalidDataException(
                $"CRC incorrecto. Recibido 0x{crcRecibido:X4}, " +
                $"calculado 0x{crcCalculado:X4}."
            );
        }

        if (respuesta[0] != (byte)sesion.IdEsclavoModbus)
        {
            throw new InvalidDataException(
                $"Respondió el esclavo {respuesta[0]}, " +
                $"pero se esperaba el {sesion.IdEsclavoModbus}."
            );
        }

        byte funcionRespuesta = respuesta[1];

        if (funcionRespuesta == (byte)(funcionSolicitada | 0x80))
        {
            byte codigoExcepcion = respuesta[2];

            throw new InvalidOperationException(
                $"Excepción Modbus 0x{codigoExcepcion:X2}: " +
                DescribirExcepcionModbus(codigoExcepcion)
            );
        }

        if (funcionRespuesta != funcionSolicitada)
        {
            throw new InvalidDataException(
                $"La función recibida 0x{funcionRespuesta:X2} " +
                $"no coincide con 0x{funcionSolicitada:X2}."
            );
        }

        int cantidadBytes = respuesta[2];
        int cantidadEsperada =
            sesion.CantidadRegistrosModbus * 2;

        if (cantidadBytes != cantidadEsperada)
        {
            throw new InvalidDataException(
                $"El dispositivo devolvió {cantidadBytes} byte(s), " +
                $"pero se esperaban {cantidadEsperada}."
            );
        }

        if (respuesta.Length != cantidadBytes + 5)
        {
            throw new InvalidDataException(
                "La longitud de la respuesta Modbus no es válida."
            );
        }

        sesion.RegistrosModbus.Clear();

        for (int indice = 0;
             indice < sesion.CantidadRegistrosModbus;
             indice++)
        {
            int posicion = 3 + indice * 2;

            ushort valor = (ushort)(
                (respuesta[posicion] << 8) |
                respuesta[posicion + 1]
            );

            sesion.RegistrosModbus.Add(
                new RegistroModbusResultado(
                    sesion.DireccionInicialModbus + indice,
                    valor
                )
            );
        }

        sesion.MensajeEstado =
            $"Lectura completada: " +
            $"{sesion.RegistrosModbus.Count} registro(s).";

        if (registrarEnTerminal)
        {
            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"CRC correcto · " +
                $"{sesion.RegistrosModbus.Count} registro(s) recibido(s)."
            );
        }
    }

    private static string ConvertirAHex(
        IEnumerable<byte> datos)
    {
        return string.Join(
            " ",
            datos.Select(valor => valor.ToString("X2"))
        );
    }

    private static string DescribirExcepcionModbus(
        byte codigo)
    {
        return codigo switch
        {
            0x01 => "Función no soportada.",
            0x02 => "Dirección de registro no válida.",
            0x03 => "Valor de datos no válido.",
            0x04 => "Fallo interno del dispositivo.",
            0x05 => "Solicitud aceptada, procesamiento pendiente.",
            0x06 => "Dispositivo ocupado.",
            0x08 => "Error de paridad de memoria.",
            0x0A => "Ruta de gateway no disponible.",
            0x0B => "El dispositivo de destino no respondió.",
            _ => "Error informado por el dispositivo."
        };
    }

    private static byte[] ConstruirTramaLecturaModbus(
        byte idEsclavo,
        byte funcion,
        ushort direccionInicial,
        ushort cantidadRegistros)
    {
        byte[] trama = new byte[8];

        trama[0] = idEsclavo;
        trama[1] = funcion;
        trama[2] = (byte)(direccionInicial >> 8);
        trama[3] = (byte)direccionInicial;
        trama[4] = (byte)(cantidadRegistros >> 8);
        trama[5] = (byte)cantidadRegistros;

        ushort crc = CalcularCrcModbus(trama.AsSpan(0, 6));

        trama[6] = (byte)(crc & 0xFF);
        trama[7] = (byte)(crc >> 8);

        return trama;
    }

    private static byte[] ConstruirTramaEscrituraRegistroModbus(
        byte idEsclavo,
        ushort direccionRegistro,
        ushort valor)
    {
        byte[] trama = new byte[8];

        trama[0] = idEsclavo;
        trama[1] = 0x06;
        trama[2] = (byte)(direccionRegistro >> 8);
        trama[3] = (byte)direccionRegistro;
        trama[4] = (byte)(valor >> 8);
        trama[5] = (byte)valor;

        ushort crc = CalcularCrcModbus(
            trama.AsSpan(0, 6)
        );

        trama[6] = (byte)(crc & 0xFF);
        trama[7] = (byte)(crc >> 8);

        return trama;
    }

    private static ushort CalcularCrcModbus(
        ReadOnlySpan<byte> datos)
    {
        ushort crc = 0xFFFF;

        foreach (byte dato in datos)
        {
            crc ^= dato;

            for (int bit = 0; bit < 8; bit++)
            {
                bool bitMenosSignificativo =
                    (crc & 0x0001) != 0;

                crc >>= 1;

                if (bitMenosSignificativo)
                {
                    crc ^= 0xA001;
                }
            }
        }

        return crc;
    }

    private static string NombreTipoSesion(TipoSesion tipo)
    {
        return tipo == TipoSesion.ModbusRtu
            ? "Modbus RTU"
            : "Terminal serial";
    }

    private static string DescripcionTipoSesion(TipoSesion tipo)
    {
        return tipo == TipoSesion.ModbusRtu
            ? "Modbus RTU sobre RS-485"
            : "Comunicación serial RAW";
    }

    private static string NombreControlFlujo(
        Handshake control)
    {
        return control switch
        {
            Handshake.None => "Ninguno",
            Handshake.XOnXOff => "XON / XOFF",
            Handshake.RequestToSend => "RTS / CTS",
            Handshake.RequestToSendXOnXOff =>
                "RTS / CTS + XON / XOFF",
            _ => control.ToString()
        };
    }

