    private Task EnviarRutaConectorIotAsync()
    {
        if (!ValidarIdModuloIot(out string error))
        {
            MostrarErrorConfiguracionIot(error);
            return Task.CompletedTask;
        }

        string ruta = NormalizarRutaConectorIot(rutaConectorIot);

        if (string.IsNullOrWhiteSpace(ruta) || ruta == "?")
        {
            MostrarErrorConfiguracionIot(
                "Escribe la URL o ruta del conector."
            );
            return Task.CompletedTask;
        }

        if (ruta.Length > 180)
        {
            MostrarErrorConfiguracionIot(
                "La URL del conector no puede superar 180 caracteres."
            );
            return Task.CompletedTask;
        }

        if (ruta.Any(char.IsWhiteSpace))
        {
            MostrarErrorConfiguracionIot(
                "La URL del conector no puede contener espacios."
            );
            return Task.CompletedTask;
        }

        rutaConectorIot = ruta;

        return EnviarComandoIndividualConfiguracionIotAsync(
            "URL del conector",
            $"{IdModuloIotNormalizado}{ruta}!"
        );
    }

