    private async Task EnviarUltimaLecturaServidorRestAsync()
    {
        if (!PuedeEnviarUltimaLecturaServidorRest)
        {
            return;
        }

        envioServidorRestEnCurso = true;

        try
        {
            await EnviarLecturaDestinoRestAsync(
                destinoRestEditando,
                SesionActiva,
                origen: "manual",
                registrarEnTerminal: true,
                CancellationToken.None
            );
        }
        finally
