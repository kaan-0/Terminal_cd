    private void SeleccionarDestinoRest(Guid destinoId)
    {
        if (operacionServidorRestEnCurso)
        {
            return;
        }

        ConfiguracionServidorRest? destino = destinosRest
            .FirstOrDefault(item => item.Id == destinoId);

        if (destino is null)
        {
            return;
        }

        destinoRestEditando = destino.CrearCopia();
        destinoRestConfirmarEliminacionId = null;
        errorServidorRest = string.Empty;
    }

    private async Task AlternarDestinoActivoAsync(Guid destinoId)
    {
        if (operacionServidorRestEnCurso)
        {
            return;
        }

        ConfiguracionServidorRest? destino = destinosRest
            .FirstOrDefault(item => item.Id == destinoId);

        if (destino is null)
        {
            return;
        }

        ConfiguracionServidorRest copia = destino.CrearCopia();
        copia.Activo = !copia.Activo;

        try
        {
            guardadoServidorRestEnCurso = true;
            await ServidorRestService.GuardarDestinoAsync(copia);
            RecargarDestinosRest();

            if (destinoRestEditando.Id == destinoId)
            {
                SeleccionarDestinoRest(destinoId);
            }

            mensajeEstado = copia.Activo
                ? $"Destino REST '{copia.Nombre}' activado."
                : $"Destino REST '{copia.Nombre}' pausado.";
        }
        catch (Exception ex)
        {
            errorServidorRest = ex.Message;
            mensajeEstado = $"No fue posible actualizar el destino: {ex.Message}";
        }
        finally
        {
            guardadoServidorRestEnCurso = false;
        }
    }

    private async Task GuardarConfiguracionServidorRestAsync()
    {
        if (operacionServidorRestEnCurso)
        {
            return;
        }

        errorServidorRest = string.Empty;
        guardadoServidorRestEnCurso = true;

        try
        {
            Guid destinoId = destinoRestEditando.Id;

            await ServidorRestService.GuardarDestinoAsync(
                destinoRestEditando
            );

            RecargarDestinosRest();
            SeleccionarDestinoRest(destinoId);

            EstadoDestinoRest estado = ObtenerEstadoDestinoRest(destinoId);
            estado.Mensaje = "Configuración guardada localmente.";

            mensajeEstado =
                $"Destino REST '{destinoRestEditando.Nombre}' guardado.";
        }
        catch (Exception ex)
        {
            errorServidorRest = ex.Message;
            mensajeEstado =
                $"No fue posible guardar el destino: {ex.Message}";
        }
        finally
        {
            guardadoServidorRestEnCurso = false;
        }
    }

