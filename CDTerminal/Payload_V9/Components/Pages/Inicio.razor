            <span class="rest-statusbar @ClaseEstadoDestinosRest">
                <i></i> REST @ResumenEstadoDestinosRestCorto
            </span>
            <span><strong>500</strong> registros máx.</span>
        </div>

    </footer>
    }

</div>

