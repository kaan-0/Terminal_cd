        copia.Paridad = origen.Paridad;
        copia.BitsDeParada = origen.BitsDeParada;
        copia.ControlDeFlujo = origen.ControlDeFlujo;
        copia.HabilitarDtr = origen.HabilitarDtr;
        copia.HabilitarRts = origen.HabilitarRts;

        return copia;
    }

