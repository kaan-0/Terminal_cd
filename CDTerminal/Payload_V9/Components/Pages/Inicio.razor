        $"{NombreBitsParada(configuracion.BitsDeParada)} stop";

    private static string NombreParidad(Parity paridad)
    {
        return paridad switch
        {
            Parity.None => "Sin paridad",
            Parity.Even => "Par",
            Parity.Odd => "Impar",
            Parity.Mark => "Marca",
            Parity.Space => "Espacio",
            _ => paridad.ToString()
        };
    }

    private static string NombreBitsParada(StopBits bits)
    {
        return bits switch
        {
            StopBits.One => "1",
            StopBits.OnePointFive => "1.5",
            StopBits.Two => "2",
            _ => bits.ToString()
        };
    }

    public void Dispose()
    {
        componenteLiberado = true;

        if (ServicioIot is not null)
        {
            ServicioIot.DatosRecibidos -= AlRecibirDatosIot;
            ServicioIot.ErrorOcurrido -= AlOcurrirErrorIot;
            ServicioIot.ConexionPerdida -= AlPerderConexionIot;
            ServicioIot.Dispose();
        }

        foreach (TerminalSesion sesion in sesiones.ToArray())
        {
            sesion.PollingCancellation?.Cancel();
            LiberarSesion(sesion);
        }

        sesiones.Clear();
    }

