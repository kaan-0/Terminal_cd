<div class="campo-selector">

    <label>@Etiqueta</label>

    <div class="selector-personalizado">

        <button type="button"
                class="selector-boton"
                disabled="@Disabled"
                @onclick="AlternarLista">

            <span>@TextoSeleccionado</span>

            <span class="flecha">
                @(mostrarLista ? "▲" : "▼")
            </span>

        </button>

        @if (mostrarLista && !Disabled)
        {
            <div class="selector-opciones">

                @foreach (var opcion in Opciones)
                {
                    <button type="button"
                            class="selector-opcion @(opcion.Valor == ValorSeleccionado ? "seleccionada" : "")"
                            @onclick="() => SeleccionarOpcion(opcion.Valor)">

                        @opcion.Texto

                    </button>
                }

            </div>
        }

    </div>

</div>

@code {
    [Parameter]
    public string Etiqueta { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<OpcionSelector> Opciones { get; set; }
        = Array.Empty<OpcionSelector>();

    [Parameter]
    public string ValorSeleccionado { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValorSeleccionadoChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private bool mostrarLista;

    private string TextoSeleccionado =>
        Opciones
            .FirstOrDefault(opcion =>
                opcion.Valor == ValorSeleccionado)
            ?.Texto
        ?? "Seleccione";

    private void AlternarLista()
    {
        if (!Disabled)
        {
            mostrarLista = !mostrarLista;
        }
    }

    private async Task SeleccionarOpcion(string valor)
    {
        ValorSeleccionado = valor;
        mostrarLista = false;

        await ValorSeleccionadoChanged.InvokeAsync(valor);
    }
}