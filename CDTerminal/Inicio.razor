            BitsDeParada = configuracionPerfil.BitsDeParada,
            ControlDeFlujo = configuracionPerfil.ControlDeFlujo,
            HabilitarDtr = configuracionPerfil.HabilitarDtr,
            HabilitarRts = configuracionPerfil.HabilitarRts,
            IdEsclavoModbus = sesion.IdEsclavoModbus,
            TimeoutModbusMs = sesion.TimeoutModbusMs,
            ReintentosModbus = sesion.ReintentosModbus,
            FuncionModbus = sesion.FuncionModbus,
            DireccionInicialModbus = sesion.DireccionInicialModbus,
            CantidadRegistrosModbus = sesion.CantidadRegistrosModbus,
            IntervaloPollingModbusMs = sesion.IntervaloPollingModbusMs,
            DireccionRegistroGrafica = sesion.DireccionRegistroGrafica,
