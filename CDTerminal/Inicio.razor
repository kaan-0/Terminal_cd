    private void EnviarTexto()
    {
        TerminalSesion sesion = SesionActiva;

        if (!sesion.Servicio.EstaConectado ||
            string.IsNullOrWhiteSpace(
                sesion.TextoParaEnviar))
        {
            return;
        }

        try
        {
            string textoEnviado =
                sesion.TextoParaEnviar;

            sesion.Servicio.EnviarTexto(textoEnviado);

            AgregarLineaTerminal(
                sesion,
                "TX",
                textoEnviado
            );

            sesion.TextoParaEnviar = string.Empty;
            sesion.MensajeEstado =
                "Texto enviado correctamente.";
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible enviar: {ex.Message}";

            AgregarLineaTerminal(
                sesion,
                "ERROR",
                sesion.MensajeEstado
            );
        }
    }

    private void ManejarTeclaEnvio(
        KeyboardEventArgs evento)
    {
        if (evento.Key == "Enter" &&
            PuedeEnviarTexto)
        {
            EnviarTexto();
        }
    }

    private static string MarcaTiempoLinea(string linea)
    {
        int finMarca = linea.IndexOf(']');

        return finMarca >= 0
            ? linea[..(finMarca + 1)]
            : string.Empty;
    }

    private static string TipoVisualLinea(string linea)
    {
        if (linea.Contains("ERROR:", StringComparison.Ordinal))
        {
            return "ERROR";
        }

        if (linea.Contains("SYS:", StringComparison.Ordinal))
        {
            return "SYS";
        }

        if (linea.Contains("TX:", StringComparison.Ordinal))
        {
            return "TX";
        }

        return "RX";
    }

    private static string ContenidoVisualLinea(string linea)
    {
        string[] marcadores = ["ERROR:", "SYS:", "TX:", "RX:"];

        foreach (string marcador in marcadores)
        {
            int posicion = linea.IndexOf(
                marcador,
                StringComparison.Ordinal
            );

            if (posicion >= 0)
            {
                return linea[(posicion + marcador.Length)..]
                    .TrimStart();
            }
        }

        return linea;
    }

