        public bool RegistroCsvActivo { get; set; }
        public string RutaArchivoCsv { get; set; } = string.Empty;
        public int FilasCsvGuardadas { get; set; }
        public DateTime? InicioRegistroCsv { get; set; }
        public string UltimoErrorCsv { get; set; } = string.Empty;
        public SemaphoreSlim BloqueoCsv { get; } = new(1, 1);

        public List<RegistroModbusResultado> RegistrosModbus { get; } =
            new();

        public List<string> LineasTerminal { get; } = new();

        public StringBuilder BufferLineaRecepcion { get; } =
            new();

        public EventHandler<string>? ManejadorDatos { get; set; }
        public EventHandler<string>? ManejadorError { get; set; }
    }
