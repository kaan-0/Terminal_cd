                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(SesionActiva.UltimaRespuestaModbus))
                        {
                            <div class="frame-preview response">
                                <span>RX recibida</span>
                                <code>@SesionActiva.UltimaRespuestaModbus</code>
                            </div>
                        }

                        @if (SesionActiva.RegistrosModbus.Count > 0)
                        {
                            <div class="modbus-results">

                                <div class="modbus-results-header">
                                    <div>
                                        <strong>Registros recibidos</strong>
                                        <span>@SesionActiva.RegistrosModbus.Count valor(es)</span>
                                    </div>

                                    @if (SesionActiva.CrcModbusValido == true)
                                    {
                                        <span class="crc-status valid">✓ CRC correcto</span>
                                    }
                                </div>

                                <div class="modbus-register-table">
                                    <div class="modbus-register-row header">
                                        <span>Dirección</span>
                                        <span>Hexadecimal</span>
                                        <span>Decimal</span>
                                        <span>Con signo</span>
                                    </div>

                                    @foreach (RegistroModbusResultado registro in SesionActiva.RegistrosModbus)
                                    {
                                        <div class="modbus-register-row" @key="registro.Direccion">
                                            <strong>@registro.Direccion</strong>
                                            <code>0x@(registro.ValorHex)</code>
                                            <span>@registro.ValorSinSigno</span>
                                            <span>@registro.ValorConSigno</span>
                                        </div>
                                    }
                                </div>

                            </div>
                        }

                        <div class="modbus-stage-note @(SerialPortService.EstaConectado ? "active" : "")">
                            <span>ⓘ</span>
                            @(SerialPortService.EstaConectado
                                ? "La consulta se enviará por el puerto conectado. La trama TX permanecerá igual; la respuesta RX cambiará con el valor del sensor."
                                : "Conecta el puerto RS-485 antes de leer los registros del sensor.")
                        </div>

                    </div>
                }

            </section>

        </section>

    </main>

    <footer class="app-statusbar">

        <div class="statusbar-message">
            <span class="statusbar-icon">ⓘ</span>
            <span>
                @(string.IsNullOrWhiteSpace(mensajeEstado)
                    ? "CD Terminal listo."
                    : mensajeEstado)
            </span>
        </div>

        <div class="statusbar-data">
            <span><strong>@puertos.Count</strong> puerto(s)</span>
            <span>@NombreTipoSesion(SesionActiva.Tipo)</span>
            <span>
                @(EsSesionModbus
                    ? $"Esclavo {SesionActiva.IdEsclavoModbus} · {SesionActiva.FuncionModbus}"
                    : ResumenConfiguracion)
            </span>
            <span><strong>500</strong> registros máx.</span>
        </div>

    </footer>

</div>

@code {
    private readonly List<TerminalSesion> sesiones = new();

    private int siguienteIdSesion = 1;
    private int siguienteNumeroSerial = 1;
    private int siguienteNumeroModbus = 1;
    private int sesionActivaId;
    private bool mostrarMenuComunicacion;
    private bool mostrarSelectorNuevaSesion;
    private bool componenteLiberado;
    private ElementReference terminalElement;

    private TerminalSesion SesionActiva =>
        sesiones.First(sesion => sesion.Id == sesionActivaId);

    private ISerialPortService SerialPortService =>
        SesionActiva.Servicio;

    private bool EsSesionModbus =>
        SesionActiva.Tipo == TipoSesion.ModbusRtu;

    private IReadOnlyList<string> puertos
    {
