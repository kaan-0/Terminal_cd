    }

    private string pestanaActiva
    {
        get => SesionActiva.PestanaPanel;
        set => SesionActiva.PestanaPanel = value;
    }

    private bool mostrarLista
    {
        get => SesionActiva.MostrarListaPuertos;
        set => SesionActiva.MostrarListaPuertos = value;
    }

    private bool autoScroll
    {
        get => SesionActiva.AutoScroll;
        set => SesionActiva.AutoScroll = value;
    }

    private bool scrollPendiente
    {
        get => SesionActiva.ScrollPendiente;
        set => SesionActiva.ScrollPendiente = value;
    }

    private List<string> lineasTerminal =>
        SesionActiva.LineasTerminal;

    private ConfiguracionSerial configuracion =>
        SesionActiva.Configuracion;

    private StringBuilder bufferLineaRecepcion =>
        SesionActiva.BufferLineaRecepcion;

    private bool ignorarSiguienteLf
    {
        get => SesionActiva.IgnorarSiguienteLf;
        set => SesionActiva.IgnorarSiguienteLf = value;
    }

    private string textoParaEnviar
    {
        get => SesionActiva.TextoParaEnviar;
        set => SesionActiva.TextoParaEnviar = value;
    }

    private bool PuedeEnviarTexto =>
        SerialPortService.EstaConectado &&
        !string.IsNullOrWhiteSpace(textoParaEnviar);

    private bool BloquearParametrosModbus =>
        SesionActiva.ConsultaModbusEnCurso ||
        SesionActiva.PollingModbusActivo;

    private bool PuedeLeerModbus =>
        EsSesionModbus &&
        SerialPortService.EstaConectado &&
        !SesionActiva.ConsultaModbusEnCurso &&
        !SesionActiva.PollingModbusActivo;

    private bool PuedeIniciarPollingModbus =>
        EsSesionModbus &&
        SerialPortService.EstaConectado &&
        !SesionActiva.ConsultaModbusEnCurso &&
        SesionActiva.IntervaloPollingModbusMs is >= 250 and <= 60000;

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesVelocidad =
    [
        new("300", "300"),
        new("600", "600"),
        new("1200", "1200"),
        new("2400", "2400"),
        new("4800", "4800"),
        new("9600", "9600"),
        new("19200", "19200"),
        new("38400", "38400"),
        new("57600", "57600"),
        new("115200", "115200"),
        new("230400", "230400")
    ];

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesBitsDeDatos =
    [
        new("5", "5 bits"),
        new("6", "6 bits"),
        new("7", "7 bits"),
        new("8", "8 bits")
    ];

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesParidad =
    [
        new(nameof(Parity.None), "Ninguna"),
        new(nameof(Parity.Even), "Par"),
        new(nameof(Parity.Odd), "Impar"),
        new(nameof(Parity.Mark), "Marca"),
        new(nameof(Parity.Space), "Espacio")
    ];

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesBitsDeParada =
    [
        new(nameof(StopBits.One), "1"),
        new(nameof(StopBits.OnePointFive), "1.5"),
        new(nameof(StopBits.Two), "2")
    ];

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesControlDeFlujo =
    [
        new(nameof(Handshake.None), "Ninguno"),
        new(nameof(Handshake.XOnXOff), "XON / XOFF"),
        new(nameof(Handshake.RequestToSend), "RTS / CTS"),
        new(
            nameof(Handshake.RequestToSendXOnXOff),
            "RTS / CTS + XON / XOFF"
        )
    ];

    private static readonly IReadOnlyList<OpcionSelector>
        opcionesFuncionesModbus =
    [
        new("03", "03 · Leer Holding Registers"),
        new("04", "04 · Leer Input Registers")
    ];

    protected override void OnInitialized()
    {
        TerminalSesion primeraSesion =
            CrearSesion(TipoSesion.Serial);

        sesiones.Add(primeraSesion);
        sesionActivaId = primeraSesion.Id;

        ActualizarPuertos(primeraSesion);
    }

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        TerminalSesion sesion = SesionActiva;

        if (!sesion.ScrollPendiente || !sesion.AutoScroll)
        {
            return;
        }

        sesion.ScrollPendiente = false;

        await JSRuntime.InvokeVoidAsync(
            "cdTerminal.scrollToBottom",
            terminalElement
        );
    }

    private TerminalSesion CrearSesion(
        TipoSesion tipo,
        ConfiguracionSerial? configuracionBase = null)
    {
        int id = siguienteIdSesion++;
        int numero = tipo == TipoSesion.ModbusRtu
            ? siguienteNumeroModbus++
            : siguienteNumeroSerial++;

        string nombre = tipo == TipoSesion.ModbusRtu
            ? $"Modbus RTU {numero}"
            : $"Terminal {numero}";

        ISerialPortService servicio =
            ServiceProvider.GetRequiredService<ISerialPortService>();

        ConfiguracionSerial nuevaConfiguracion =
            CrearCopiaConfiguracion(configuracionBase);

        TerminalSesion sesion = new(
            id,
            nombre,
            tipo,
            servicio,
            nuevaConfiguracion
        );

        sesion.ManejadorDatos = (_, datos) =>
            AlRecibirDatos(sesion, datos);

        sesion.ManejadorError = (_, error) =>
            AlOcurrirError(sesion, error);

        servicio.DatosRecibidos += sesion.ManejadorDatos;
        servicio.ErrorOcurrido += sesion.ManejadorError;

        return sesion;
    }

    private void AlternarMenuComunicacion()
    {
        mostrarMenuComunicacion = !mostrarMenuComunicacion;
        mostrarSelectorNuevaSesion = false;
    }

    private void AlternarSelectorNuevaSesion()
    {
        mostrarSelectorNuevaSesion = !mostrarSelectorNuevaSesion;
        mostrarMenuComunicacion = false;
    }

    private void CerrarMenusNuevaSesion()
    {
        mostrarMenuComunicacion = false;
        mostrarSelectorNuevaSesion = false;
    }

    private void CrearNuevaSesion(TipoSesion tipo)
    {
        ConfiguracionSerial configuracionBase =
            SesionActiva.Configuracion;

        TerminalSesion nuevaSesion =
            CrearSesion(tipo, configuracionBase);

        sesiones.Add(nuevaSesion);
        sesionActivaId = nuevaSesion.Id;
        terminalElement = default;

        CerrarMenusNuevaSesion();
        ActualizarPuertos(nuevaSesion);

        nuevaSesion.MensajeEstado =
            $"{nuevaSesion.Nombre} creada.";

        if (tipo == TipoSesion.ModbusRtu)
        {
            AgregarLineaTerminal(
                nuevaSesion,
                "SYS",
                "Sesión Modbus RTU creada. Configura el puerto, " +
                "el ID del esclavo y la consulta."
            );
        }
    }

    private async Task SeleccionarTerminalAsync(int id)
    {
        if (id == sesionActivaId ||
            sesiones.All(sesion => sesion.Id != id))
        {
            return;
        }

        TerminalSesion sesionAnterior = SesionActiva;

        if (sesionAnterior.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesionAnterior,
                registrarMensaje: true
            );
        }

        sesionAnterior.MostrarListaPuertos = false;
        CerrarMenusNuevaSesion();
        sesionActivaId = id;
        terminalElement = default;

        TerminalSesion nuevaSesionActiva = SesionActiva;

        if (nuevaSesionActiva.AutoScroll &&
            nuevaSesionActiva.LineasTerminal.Count > 0)
        {
            nuevaSesionActiva.ScrollPendiente = true;
        }
    }

    private async Task CerrarTerminalAsync(int id)
    {
        TerminalSesion? sesion =
            sesiones.FirstOrDefault(item => item.Id == id);

        if (sesion is null)
        {
            return;
        }

        if (sesiones.Count == 1)
        {
            sesion.MensajeEstado =
                "Debe permanecer al menos una terminal abierta.";
            return;
        }

        if (sesion.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesion,
                registrarMensaje: false
            );
        }

        if (sesion.ConsultaModbusEnCurso)
        {
            sesion.MensajeEstado =
                "Espera a que termine la consulta Modbus antes de cerrar la sesión.";
            return;
        }

        int indice = sesiones.IndexOf(sesion);
        bool eraActiva = sesion.Id == sesionActivaId;
        string nombreCerrado = sesion.Nombre;

        LiberarSesion(sesion);
        sesiones.Remove(sesion);

        if (eraActiva)
        {
            int nuevoIndice = Math.Min(
                indice,
                sesiones.Count - 1
            );

            sesionActivaId = sesiones[nuevoIndice].Id;
            terminalElement = default;

            if (SesionActiva.AutoScroll &&
                SesionActiva.LineasTerminal.Count > 0)
            {
                SesionActiva.ScrollPendiente = true;
            }
        }

        SesionActiva.MensajeEstado =
            $"{nombreCerrado} cerrada.";
    }

    private void LiberarSesion(TerminalSesion sesion)
    {
        sesion.PollingCancellation?.Cancel();

        if (sesion.ManejadorDatos is not null)
        {
            sesion.Servicio.DatosRecibidos -=
                sesion.ManejadorDatos;
        }

        if (sesion.ManejadorError is not null)
        {
            sesion.Servicio.ErrorOcurrido -=
                sesion.ManejadorError;
        }

        sesion.Servicio.Dispose();
    }

    private static ConfiguracionSerial CrearCopiaConfiguracion(
        ConfiguracionSerial? origen)
    {
        ConfiguracionSerial copia = new();

        if (origen is null)
        {
            return copia;
        }

        copia.Velocidad = origen.Velocidad;
        copia.BitsDeDatos = origen.BitsDeDatos;
        copia.Paridad = origen.Paridad;
        copia.BitsDeParada = origen.BitsDeParada;
        copia.ControlDeFlujo = origen.ControlDeFlujo;
        copia.HabilitarDtr = origen.HabilitarDtr;
        copia.HabilitarRts = origen.HabilitarRts;

        return copia;
    }

    private void MostrarPuerto()
    {
        pestanaActiva = "puerto";
        mostrarLista = false;
    }

    private void MostrarConfiguracion()
    {
        pestanaActiva = "configuracion";
        mostrarLista = false;
    }

    private void ActualizarPuertos()
    {
        ActualizarPuertos(SesionActiva);
    }

    private void ActualizarPuertos(TerminalSesion sesion)
    {
        sesion.Puertos =
            sesion.Servicio.ObtenerPuertosDisponibles();

        sesion.MostrarListaPuertos = false;

        if (sesion.Puertos.Count == 0)
        {
            sesion.PuertoSeleccionado = string.Empty;
            sesion.Configuracion.NombrePuerto = string.Empty;
            sesion.MensajeEstado =
                "No se encontraron puertos COM.";
            return;
        }

        if (string.IsNullOrWhiteSpace(
                sesion.PuertoSeleccionado) ||
            !sesion.Puertos.Contains(
                sesion.PuertoSeleccionado))
        {
            HashSet<string> puertosEnUso = sesiones
                .Where(item =>
                    item.Id != sesion.Id &&
                    item.Servicio.EstaConectado &&
                    !string.IsNullOrWhiteSpace(
                        item.Servicio.PuertoActual))
                .Select(item => item.Servicio.PuertoActual!)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            sesion.PuertoSeleccionado =
                sesion.Puertos.FirstOrDefault(
                    puerto => !puertosEnUso.Contains(puerto))
                ?? sesion.Puertos[0];
        }

        sesion.Configuracion.NombrePuerto =
            sesion.PuertoSeleccionado;

        sesion.MensajeEstado =
            $"{sesion.Puertos.Count} puerto(s) detectado(s).";
    }

    private void AlternarLista()
    {
        if (!SerialPortService.EstaConectado)
        {
            mostrarLista = !mostrarLista;
        }
    }

    private void SeleccionarPuerto(string puerto)
    {
        puertoSeleccionado = puerto;
        configuracion.NombrePuerto = puerto;
        mostrarLista = false;

        mensajeEstado =
            $"{puerto} seleccionado.";
    }

    private void Conectar()
    {
        TerminalSesion sesion = SesionActiva;

        try
        {
            sesion.Configuracion.NombrePuerto =
                sesion.PuertoSeleccionado;

            sesion.Servicio.Conectar(
                sesion.Configuracion
            );

            sesion.MostrarListaPuertos = false;
            sesion.MensajeEstado =
                $"Conexión establecida en " +
                $"{sesion.PuertoSeleccionado}.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Conectado a {sesion.PuertoSeleccionado} " +
                $"a {sesion.Configuracion.Velocidad} bps."
            );
        }
        catch (UnauthorizedAccessException)
        {
            sesion.MensajeEstado =
                $"No se puede acceder a " +
                $"{sesion.PuertoSeleccionado}. " +
                "Probablemente está siendo utilizado por " +
                "otra terminal o programa.";
        }
        catch (IOException ex)
        {
            sesion.MensajeEstado =
                $"Error de comunicación: {ex.Message}";
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible conectar: {ex.Message}";
        }
    }

    private async Task DesconectarAsync()
    {
        TerminalSesion sesion = SesionActiva;

        if (sesion.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesion,
                registrarMensaje: true
            );
        }

        if (sesion.ConsultaModbusEnCurso)
        {
            sesion.MensajeEstado =
                "Espera a que termine la consulta Modbus antes de desconectar.";
            return;
        }

        try
        {
            string puertoAnterior =
                sesion.Servicio.PuertoActual ??
                sesion.PuertoSeleccionado;

            sesion.Servicio.Desconectar();

            sesion.MensajeEstado =
                $"El puerto {puertoAnterior} fue desconectado.";

            AgregarLineaTerminal(
                sesion,
                "SYS",
                $"Puerto {puertoAnterior} desconectado."
            );
        }
        catch (Exception ex)
        {
            sesion.MensajeEstado =
                $"No fue posible desconectar: {ex.Message}";
        }
    }

    private void AlRecibirDatos(
        TerminalSesion sesion,
        string datos)
    {
        if (sesion.Tipo == TipoSesion.ModbusRtu)
        {
            return;
        }

        if (string.IsNullOrEmpty(datos))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            ProcesarDatosRecibidos(sesion, datos);
            StateHasChanged();
        });
    }

    private void ProcesarDatosRecibidos(
        TerminalSesion sesion,
        string datos)
    {
        foreach (char caracter in datos)
        {
            if (caracter == '\r')
            {
                CompletarLineaRecibida(sesion);
                sesion.IgnorarSiguienteLf = true;
                continue;
            }

            if (caracter == '\n')
            {
                if (sesion.IgnorarSiguienteLf)
                {
                    sesion.IgnorarSiguienteLf = false;
                    continue;
                }

                CompletarLineaRecibida(sesion);
                continue;
            }

            sesion.IgnorarSiguienteLf = false;
            sesion.BufferLineaRecepcion.Append(caracter);
        }
    }

    private void CompletarLineaRecibida(
        TerminalSesion sesion)
    {
        string linea = sesion.BufferLineaRecepcion
            .ToString()
            .Trim();

        sesion.BufferLineaRecepcion.Clear();

        if (string.IsNullOrWhiteSpace(linea))
        {
            return;
        }

        AgregarLineaTerminal(
            sesion,
            "RX",
            linea
        );
    }

    private void AlOcurrirError(
        TerminalSesion sesion,
        string error)
    {
        _ = InvokeAsync(() =>
        {
            AgregarLineaTerminal(
                sesion,
                "ERROR",
                error
            );

            sesion.MensajeEstado = error;
            StateHasChanged();
        });
    }

    private void AgregarLineaTerminal(
        string tipo,
        string contenido)
    {
        AgregarLineaTerminal(
            SesionActiva,
            tipo,
            contenido
        );
    }

    private static void AgregarLineaTerminal(
        TerminalSesion sesion,
        string tipo,
        string contenido)
    {
        string contenidoLimpio = contenido
            .Replace("\r\n", " ")
            .Replace('\r', ' ')
            .Replace('\n', ' ')
            .Trim();

        if (string.IsNullOrWhiteSpace(contenidoLimpio))
        {
            return;
        }

        string texto =
            $"[{DateTime.Now:HH:mm:ss.fff}] " +
            $"{tipo}: {contenidoLimpio}";

        sesion.LineasTerminal.Add(texto);

        if (sesion.LineasTerminal.Count > 500)
        {
            int cantidadEliminar =
                sesion.LineasTerminal.Count - 500;

            sesion.LineasTerminal.RemoveRange(
                0,
                cantidadEliminar
            );
        }

        if (sesion.AutoScroll)
        {
            sesion.ScrollPendiente = true;
        }
    }

    private void LimpiarTerminal()
    {
        TerminalSesion sesion = SesionActiva;

        sesion.LineasTerminal.Clear();
        sesion.BufferLineaRecepcion.Clear();
        sesion.IgnorarSiguienteLf = false;
        sesion.MensajeEstado =
            "La terminal fue limpiada.";
    }

    private static string ClaseLinea(string linea)
    {
        if (linea.Contains(
                "ERROR:",
                StringComparison.Ordinal))
        {
            return "error";
        }

        if (linea.Contains(
                "SYS:",
                StringComparison.Ordinal))
        {
            return "system";
        }

        if (linea.Contains(
                "TX:",
                StringComparison.Ordinal))
        {
            return "sent";
        }

        return "received";
    }

    private string ResumenConfiguracion =>
        $"{configuracion.Velocidad} bps · " +
        $"{configuracion.BitsDeDatos} bits · " +
        $"{NombreParidad(configuracion.Paridad)} · " +
        $"{NombreBitsParada(configuracion.BitsDeParada)} stop";

    private static string NombreParidad(Parity paridad)
    {
        return paridad switch
        {
            Parity.None => "Sin paridad",
            Parity.Even => "Par",
            Parity.Odd => "Impar",
            Parity.Mark => "Marca",
            Parity.Space => "Espacio",
            _ => paridad.ToString()
        };
    }

    private static string NombreBitsParada(StopBits bits)
    {
        return bits switch
        {
            StopBits.One => "1",
            StopBits.OnePointFive => "1.5",
            StopBits.Two => "2",
            _ => bits.ToString()
        };
    }

    public void Dispose()
    {
        componenteLiberado = true;

        foreach (TerminalSesion sesion in sesiones.ToArray())
        {
            sesion.PollingCancellation?.Cancel();
            LiberarSesion(sesion);
        }

        sesiones.Clear();
    }

    private string VelocidadSeleccionada
    {
        get => configuracion.Velocidad.ToString();

        set
        {
            if (int.TryParse(value, out int velocidad))
            {
                configuracion.Velocidad = velocidad;
            }
        }
    }

    private string BitsDeDatosSeleccionados
    {
