@using System.IO
@using System.Text
@using System.Threading
@using System.Threading.Tasks
@implements IDisposable
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JSRuntime
@using Microsoft.Extensions.DependencyInjection

<div class="app-shell">

    <nav class="app-menu" aria-label="Menú principal">

        <div class="menu-links">

            <button type="button"
                    class="menu-item active"
                    @onclick="CerrarMenusNuevaSesion">
                Inicio
            </button>

            <div class="menu-dropdown">

                <button type="button"
                        class="menu-item communication @(mostrarMenuComunicacion ? "open" : "")"
                        @onclick="AlternarMenuComunicacion">
                    Comunicación
                    <span class="menu-arrow">@(mostrarMenuComunicacion ? "▲" : "▼")</span>
                </button>

                @if (mostrarMenuComunicacion)
                {
                    <div class="session-type-menu communication-options">

                        <button type="button"
                                class="session-type-option"
                                @onclick="() => CrearNuevaSesion(TipoSesion.Serial)">
                            <span class="session-type-icon serial">&gt;_</span>
                            <span>
                                <strong>Terminal serial</strong>
                                <small>USB-TTL, RS-232 y comunicación RAW</small>
                            </span>
                        </button>

                        <button type="button"
                                class="session-type-option"
                                @onclick="() => CrearNuevaSesion(TipoSesion.ModbusRtu)">
                            <span class="session-type-icon modbus">MB</span>
                            <span>
                                <strong>Modbus RTU</strong>
                                <small>Sensores y equipos RS-485</small>
                            </span>
                        </button>

                    </div>
                }

            </div>

            <button type="button"
                    class="menu-item"
                    title="Se habilitará en una próxima etapa"
                    disabled>
                Ver
            </button>

            <button type="button"
                    class="menu-item"
                    title="Se habilitará en una próxima etapa"
                    disabled>
                Herramientas
            </button>

            <button type="button"
                    class="menu-item"
                    title="Se habilitará en una próxima etapa"
                    disabled>
                Ayuda
            </button>

        </div>

        <div class="menu-status @(SerialPortService.EstaConectado
                                                   ? "connected"
                                                   : "disconnected")">

            <span class="status-dot"></span>

            @if (SerialPortService.EstaConectado)
            {
                <span>@NombreTipoSesion(SesionActiva.Tipo) · @SerialPortService.PuertoActual</span>
            }
            else
            {
                <span>@NombreTipoSesion(SesionActiva.Tipo) · Desconectado</span>
            }

        </div>

    </nav>

    <main class="workspace">

        <aside class="control-panel">

            <div class="sidebar-tabs">

                <button type="button"
                        class="sidebar-tab @(pestanaActiva == "puerto" ? "active" : "")"
                        @onclick="MostrarPuerto">

                    <span class="sidebar-tab-icon">⌁</span>
                    Conexión

                </button>

                <button type="button"
                        class="sidebar-tab @(pestanaActiva == "configuracion" ? "active" : "")"
                        @onclick="MostrarConfiguracion">

                    <span class="sidebar-tab-icon">⚙</span>
                    Configuración

                </button>

            </div>

            <div class="panel-body">

                @if (pestanaActiva == "puerto")
                {
                    <section class="panel-section">

                        <div class="section-header">

                            <div>
                                <span class="section-icon">⌁</span>
                                <div>
                                    <span class="section-eyebrow">CONEXIÓN</span>
                                    <h2>Puerto serial</h2>
                                </div>
                            </div>

                            <button type="button"
                                    class="icon-button"
                                    title="Actualizar puertos"
                                    disabled="@SerialPortService.EstaConectado"
                                    @onclick="ActualizarPuertos">
                                ↻
                            </button>

                        </div>

                        @if (puertos.Count == 0)
                        {
                            <div class="empty-state">

                                <span class="empty-state-icon">USB</span>
                                <strong>No hay puertos disponibles</strong>
                                <span>
                                    Conecta un dispositivo y presiona actualizar.
                                </span>

                            </div>
                        }
                        else
                        {
                            <div class="field-group">

                                <label>Puerto COM</label>

                                <div class="port-selector">

                                    <button type="button"
                                            class="port-selector-button"
                                            disabled="@SerialPortService.EstaConectado"
                                            @onclick="AlternarLista">

                                        <span class="port-button-content">
                                            <span class="port-symbol">▰</span>
                                            <strong>
                                                @(string.IsNullOrWhiteSpace(puertoSeleccionado)
                                                    ? "Seleccione un puerto"
                                                    : puertoSeleccionado)
                                            </strong>
                                        </span>

                                        <span class="selector-arrow">
                                            @(mostrarLista ? "▲" : "▼")
                                        </span>

                                    </button>

                                    @if (mostrarLista &&
                                         !SerialPortService.EstaConectado)
                                    {
                                        <div class="port-options">

                                            @foreach (var puerto in puertos)
                                            {
                                                <button type="button"
                                                        class="port-option @(puerto == puertoSeleccionado
                                                                                                                                        ? "selected"
                                                                                                                                        : "")"
                                                        @onclick="() => SeleccionarPuerto(puerto)">

                                                    <span class="port-icon">◉</span>
                                                    <span>@puerto</span>

                                                    @if (puerto == puertoSeleccionado)
                                                    {
                                                        <span class="option-check">✓</span>
                                                    }

                                                </button>
                                            }

                                        </div>
                                    }

                                </div>

                            </div>

                            <div class="information-grid">

                                <div class="information-card">
                                    <span class="info-icon">▣</span>
                                    <div>
                                        <span>Puertos detectados</span>
                                        <strong>@puertos.Count</strong>
                                    </div>
                                </div>

                                <div class="information-card selected-port-card">
                                    <span class="info-icon">✓</span>
                                    <div>
                                        <span>Puerto seleccionado</span>
                                        <strong>@puertoSeleccionado</strong>
                                    </div>
                                </div>

                            </div>

                            <div class="side-card configuration-card">

                                <div class="card-title-row">
                                    <span class="card-icon">⚙</span>
                                    <span>CONFIGURACIÓN ACTUAL</span>
                                </div>

                                <dl class="configuration-list">
                                    <div>
                                        <dt>Protocolo</dt>
                                        <dd>@NombreTipoSesion(SesionActiva.Tipo)</dd>
                                    </div>
                                    @if (EsSesionModbus)
                                    {
                                        <div>
                                            <dt>ID esclavo</dt>
                                            <dd>@SesionActiva.IdEsclavoModbus</dd>
                                        </div>
                                    }
                                    <div>
                                        <dt>Baudios</dt>
                                        <dd>@configuracion.Velocidad bps</dd>
                                    </div>
                                    <div>
                                        <dt>Bits de datos</dt>
                                        <dd>@configuracion.BitsDeDatos bits</dd>
                                    </div>
                                    <div>
                                        <dt>Paridad</dt>
                                        <dd>@NombreParidad(configuracion.Paridad)</dd>
                                    </div>
                                    <div>
                                        <dt>Bits de parada</dt>
                                        <dd>@NombreBitsParada(configuracion.BitsDeParada) stop</dd>
                                    </div>
                                    <div>
                                        <dt>Control de flujo</dt>
                                        <dd>@NombreControlFlujo(configuracion.ControlDeFlujo)</dd>
                                    </div>
                                </dl>

                                <button type="button"
                                        class="card-action"
                                        disabled="@SerialPortService.EstaConectado"
                                        @onclick="MostrarConfiguracion">
                                    ✎ Modificar configuración
                                </button>

                            </div>

                            <div class="side-card device-card">

                                <div class="card-title-row">
                                    <span class="card-icon">▣</span>
                                    <span>DISPOSITIVO</span>
                                </div>

                                <dl class="device-list">
                                    <div>
                                        <dt>Estado</dt>
                                        <dd>
                                            <span class="mini-status-dot @(SerialPortService.EstaConectado ? "online" : "offline")"></span>
                                            @(SerialPortService.EstaConectado ? "Conectado" : "Sin conexión")
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Puerto</dt>
                                        <dd>@(SerialPortService.PuertoActual ?? puertoSeleccionado)</dd>
                                    </div>
                                    <div>
                                        <dt>Tipo</dt>
                                        <dd>@DescripcionTipoSesion(SesionActiva.Tipo)</dd>
                                    </div>
                                    <div>
                                        <dt>Sesión</dt>
                                        <dd>@(SerialPortService.EstaConectado ? "Activa" : "—")</dd>
                                    </div>
                                </dl>

                            </div>
                        }

                    </section>
                }
                else
                {
                    <section class="panel-section">

                        <div class="section-header">

                            <div>
                                <span class="section-icon">⚙</span>
                                <div>
                                    <span class="section-eyebrow">PUERTO SERIAL</span>
                                    <h2>Configuración</h2>
                                </div>
                            </div>

                        </div>

                        <div class="configuration-fields">

                            <SelectorPersonalizado Etiqueta="Velocidad"
                                                   Opciones="opcionesVelocidad"
                                                   @bind-ValorSeleccionado="VelocidadSeleccionada"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Bits de datos"
                                                   Opciones="opcionesBitsDeDatos"
                                                   @bind-ValorSeleccionado="BitsDeDatosSeleccionados"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Paridad"
                                                   Opciones="opcionesParidad"
                                                   @bind-ValorSeleccionado="ParidadSeleccionada"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Bits de parada"
                                                   Opciones="opcionesBitsDeParada"
                                                   @bind-ValorSeleccionado="BitsDeParadaSeleccionados"
                                                   Disabled="@SerialPortService.EstaConectado" />

                            <SelectorPersonalizado Etiqueta="Control de flujo"
                                                   Opciones="opcionesControlDeFlujo"
                                                   @bind-ValorSeleccionado="ControlDeFlujoSeleccionado"
                                                   Disabled="@SerialPortService.EstaConectado" />

                        </div>

                        <div class="advanced-options">

                            <span class="advanced-title">
                                Líneas de control
                            </span>

                            <label class="toggle-option">

                                <input type="checkbox"
                                       @bind="configuracion.HabilitarDtr"
                                       disabled="@SerialPortService.EstaConectado" />

                                <span>
                                    <strong>DTR</strong>
                                    <small>Data Terminal Ready</small>
                                </span>

                            </label>

                            <label class="toggle-option">

                                <input type="checkbox"
                                       @bind="configuracion.HabilitarRts"
                                       disabled="@SerialPortService.EstaConectado" />

                                <span>
                                    <strong>RTS</strong>
                                    <small>Request To Send</small>
                                </span>

                            </label>

                        </div>

                        @if (EsSesionModbus)
                        {
                            <div class="modbus-config-section">

                                <div class="modbus-section-heading">
                                    <span class="session-type-icon modbus">MB</span>
                                    <div>
                                        <strong>Parámetros Modbus RTU</strong>
                                        <small>Configuración del dispositivo esclavo</small>
                                    </div>
                                </div>

                                <div class="modbus-config-grid">

                                    <label class="numeric-field">
                                        <span>ID del esclavo</span>
                                        <input type="number"
                                               min="1"
                                               max="247"
                                               @bind="SesionActiva.IdEsclavoModbus" />
                                        <small>Rango permitido: 1 a 247</small>
                                    </label>

                                    <label class="numeric-field">
                                        <span>Tiempo de espera</span>
                                        <div class="input-with-unit">
                                            <input type="number"
                                                   min="100"
                                                   max="10000"
                                                   step="100"
                                                   @bind="SesionActiva.TimeoutModbusMs" />
                                            <span>ms</span>
                                        </div>
                                    </label>

                                    <label class="numeric-field">
                                        <span>Reintentos</span>
                                        <input type="number"
                                               min="0"
                                               max="10"
                                               @bind="SesionActiva.ReintentosModbus" />
                                    </label>

                                </div>

                            </div>
                        }

                    </section>
                }

            </div>

            <div class="connection-footer">

                <div class="connection-summary">

                    <span class="connection-label">
                        Estado de conexión
                    </span>

                    <div class="connection-value">

                        <span class="connection-indicator @(SerialPortService.EstaConectado
                                                                                               ? "online"
                                                                                               : "offline")">
                        </span>

                        <strong>
                            @(SerialPortService.EstaConectado
                                ? SerialPortService.PuertoActual
                                : "Sin conexión")
                        </strong>

                    </div>

                </div>

                @if (SerialPortService.EstaConectado)
                {
                    <button type="button"
                            class="primary-action disconnect"
                            @onclick="DesconectarAsync">
                        <span>■</span>
                        Desconectar
                    </button>
                }
                else
                {
                    <button type="button"
                            class="primary-action connect"
                            disabled="@string.IsNullOrWhiteSpace(puertoSeleccionado)"
                            @onclick="Conectar">
                        <span>▷</span>
                        Conectar
                    </button>
                }

            </div>

        </aside>

        <section class="terminal-workspace">

            <div class="terminal-tabs">

                @foreach (TerminalSesion sesion in sesiones)
                {
                    <button type="button"
                            @key="sesion.Id"
                            class="terminal-tab @(sesion.Id == sesionActivaId ? "active" : "")"
                            title="@(sesion.Servicio.EstaConectado
                                                            ? $"{sesion.Nombre} · {sesion.Servicio.PuertoActual}"
                                                            : sesion.Nombre)"
                            @onclick="() => SeleccionarTerminalAsync(sesion.Id)">

                        <span class="terminal-tab-dot @(sesion.Servicio.EstaConectado ? "online" : "offline")"></span>
                        <span class="terminal-tab-protocol @(sesion.Tipo == TipoSesion.ModbusRtu ? "modbus" : "serial")">
                            @(sesion.Tipo == TipoSesion.ModbusRtu ? "RTU" : "SER")
                        </span>
                        <span class="terminal-tab-name">@sesion.Nombre</span>

                        <span class="terminal-tab-close"
                              title="Cerrar terminal"
                              @onclick:stopPropagation="true"
                              @onclick="() => CerrarTerminalAsync(sesion.Id)">
                            ×
                        </span>

                    </button>
                }

                <div class="new-session-wrapper">

                    <button type="button"
                            class="new-terminal-tab @(mostrarSelectorNuevaSesion ? "open" : "")"
                            title="Abrir nueva sesión"
                            @onclick="AlternarSelectorNuevaSesion">
                        +
                    </button>

                    @if (mostrarSelectorNuevaSesion)
                    {
                        <div class="session-type-menu new-session-options">

                            <div class="session-menu-title">Nueva sesión</div>

                            <button type="button"
                                    class="session-type-option"
                                    @onclick="() => CrearNuevaSesion(TipoSesion.Serial)">
                                <span class="session-type-icon serial">&gt;_</span>
                                <span>
                                    <strong>Terminal serial</strong>
                                    <small>Comunicación libre por puerto COM</small>
                                </span>
                            </button>

                            <button type="button"
                                    class="session-type-option"
                                    @onclick="() => CrearNuevaSesion(TipoSesion.ModbusRtu)">
                                <span class="session-type-icon modbus">MB</span>
                                <span>
                                    <strong>Modbus RTU</strong>
                                    <small>Consultas industriales sobre RS-485</small>
                                </span>
                            </button>

                        </div>
                    }

                </div>

            </div>

            <section class="terminal-panel">

                <header class="terminal-header">

                    <div class="terminal-title">

                        <div class="terminal-icon @(EsSesionModbus ? "modbus" : "serial")">
                            @(EsSesionModbus ? "MB" : ">_")
                        </div>

                        <div>
                            <h2>@(EsSesionModbus ? "Modbus RTU" : "Terminal serial")</h2>
                            <span>
                                @(EsSesionModbus
                                    ? "Consultas y lectura de registros sobre RS-485"
                                    : "Datos recibidos en tiempo real")
                            </span>
                        </div>

                    </div>

                    <div class="terminal-toolbar">

                        <div class="line-counter">
                            @lineasTerminal.Count líneas
                        </div>

                        <label class="auto-scroll-option">

                            <input type="checkbox"
                                   @bind="autoScroll" />

                            <span>Auto scroll</span>

                        </label>

                        <button type="button"
                                class="clear-button"
                                disabled="@(lineasTerminal.Count == 0)"
                                @onclick="LimpiarTerminal">
                            <span>⌫</span>
                            Limpiar
                        </button>

                    </div>

                </header>

                <div class="terminal-screen"
                     @ref="terminalElement">

                    @if (lineasTerminal.Count == 0)
                    {
                        <div class="terminal-empty">

                            <span class="terminal-empty-icon">@(EsSesionModbus ? "MB" : ">_")</span>
                            <strong>
                                @(EsSesionModbus
                                    ? "Configura tu primera consulta"
                                    : "Esperando información")
                            </strong>
                            <p>
                                @(EsSesionModbus
                                    ? "Las tramas preparadas y respuestas aparecerán aquí."
                                    : "Los datos recibidos aparecerán aquí.")
                            </p>

                        </div>
                    }
                    else
                    {
                        @foreach (var linea in lineasTerminal)
                        {
                            <div class="@($"terminal-line {ClaseLinea(linea)}")">
                                <span class="terminal-time">@MarcaTiempoLinea(linea)</span>
                                <span class="terminal-kind">@TipoVisualLinea(linea):</span>
                                <span class="terminal-content">@ContenidoVisualLinea(linea)</span>
                            </div>
                        }
                    }

                </div>

                @if (!EsSesionModbus)
                {
                    <div class="send-container">

                        <div class="send-header">

                            <div>
                                <strong>Escribir al dispositivo</strong>
                                <span>Envía texto al microcontrolador conectado</span>
                            </div>

                            <span class="raw-mode-badge"
                                  title="Actualmente el texto se envía sin CR ni LF">
                                RAW
                            </span>

                        </div>

                        <div class="send-row">

                            <div class="send-input-wrapper">

                                <span class="send-prefix">TX</span>

                                <input type="text"
                                       class="send-input"
                                       placeholder="Escribe aquí..."
                                       autocomplete="off"
                                       @bind="textoParaEnviar"
                                       @bind:event="oninput"
                                       @onkeydown="ManejarTeclaEnvio"
                                       disabled="@(!SerialPortService.EstaConectado)" />

                            </div>

                            <button type="button"
                                    class="send-button"
                                    disabled="@(!PuedeEnviarTexto)"
                                    @onclick="EnviarTexto">
                                <span>➤</span>
                                Enviar
                            </button>

                        </div>

                    </div>
                }
                else
                {
                    <div class="modbus-builder">

                        <div class="modbus-builder-header">
                            <div>
                                <strong>Consultar registros Modbus RTU</strong>
                                <span>Envía la trama binaria y procesa la respuesta del sensor</span>
                            </div>
                            <span class="preview-mode-badge @(SesionActiva.PollingModbusActivo
                                                                  ? "polling"
                                                                  : SesionActiva.ConsultaModbusEnCurso
                                                                      ? "reading"
                                                                      : SerialPortService.EstaConectado ? "ready" : "")">
                                @(SesionActiva.PollingModbusActivo
                                    ? "AUTOMÁTICO"
                                    : SesionActiva.ConsultaModbusEnCurso
                                        ? "LEYENDO"
                                        : SerialPortService.EstaConectado ? "LISTO" : "DESCONECTADO")
                            </span>
                        </div>

                        <div class="modbus-query-grid">

                            <SelectorPersonalizado Etiqueta="Función"
                                                   Opciones="opcionesFuncionesModbus"
                                                   @bind-ValorSeleccionado="FuncionModbusSeleccionada"
                                                   Disabled="@BloquearParametrosModbus" />

                            <label class="numeric-field">
                                <span>Dirección inicial</span>
                                <input type="number"
                                       min="0"
                                       max="65535"
                                       disabled="@BloquearParametrosModbus"
                                       @bind="SesionActiva.DireccionInicialModbus" />
                                <small>Dirección PDU, base 0</small>
                            </label>

                            <label class="numeric-field">
                                <span>Cantidad de registros</span>
                                <input type="number"
                                       min="1"
                                       max="125"
                                       disabled="@BloquearParametrosModbus"
                                       @bind="SesionActiva.CantidadRegistrosModbus" />
                                <small>1 registro = 16 bits</small>
                            </label>

                            <button type="button"
                                    class="generate-frame-button"
                                    disabled="@(!PuedeLeerModbus)"
                                    @onclick="LeerRegistrosModbusAsync">
                                <span>@(SesionActiva.ConsultaModbusEnCurso ? "◌" : "◇")</span>
                                @(SesionActiva.PollingModbusActivo
                                    ? "Polling activo"
                                    : SesionActiva.ConsultaModbusEnCurso
                                        ? "Leyendo..."
                                        : "Leer registros")
                            </button>

                        </div>

                        <div class="modbus-polling-panel @(SesionActiva.PollingModbusActivo ? "active" : "")">

                            <div class="polling-panel-header">
                                <div>
                                    <strong>Lectura automática</strong>
                                    <span>Consulta el sensor repetidamente sin superponer solicitudes</span>
                                </div>

                                <button type="button"
                                        class="polling-action @(SesionActiva.PollingModbusActivo ? "stop" : "start")"
                                        disabled="@(!SesionActiva.PollingModbusActivo && !PuedeIniciarPollingModbus)"
                                        @onclick="AlternarPollingModbusAsync">
                                    <span>@(SesionActiva.PollingModbusActivo ? "■" : "▶")</span>
                                    @(SesionActiva.PollingModbusActivo
                                        ? "Detener"
                                        : "Iniciar polling")
                                </button>
                            </div>

                            <div class="polling-controls">

                                <label class="numeric-field polling-interval">
                                    <span>Intervalo</span>
                                    <div class="input-with-unit">
                                        <input type="number"
                                               min="250"
                                               max="60000"
                                               step="250"
                                               disabled="@SesionActiva.PollingModbusActivo"
                                               @bind="SesionActiva.IntervaloPollingModbusMs" />
                                        <span>ms</span>
                                    </div>
                                    <small>Entre 250 ms y 60 segundos</small>
                                </label>

                                <label class="polling-log-option">
                                    <input type="checkbox"
                                           @bind="SesionActiva.RegistrarPollingEnTerminal" />
                                    <span>
                                        <strong>Registrar cada lectura</strong>
                                        <small>Agrega TX, RX y CRC a la terminal</small>
                                    </span>
                                </label>

                                <div class="polling-stat">
                                    <span>Correctas</span>
                                    <strong>@SesionActiva.LecturasPollingCorrectas</strong>
                                </div>

                                <div class="polling-stat error">
                                    <span>Errores</span>
                                    <strong>@SesionActiva.ErroresPolling</strong>
                                </div>

                                <div class="polling-stat last">
                                    <span>Última lectura</span>
                                    <strong>
                                        @(SesionActiva.UltimaLecturaPolling is null
                                            ? "—"
                                            : SesionActiva.UltimaLecturaPolling.Value.ToString("HH:mm:ss"))
                                    </strong>
                                </div>

                            </div>

                        </div>

                        @if (!string.IsNullOrWhiteSpace(SesionActiva.TramaModbusPrevia))
                        {
                            <div class="frame-preview">
                                <span>TX enviada</span>
