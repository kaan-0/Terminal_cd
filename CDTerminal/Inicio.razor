    private void EditarPerfil(Guid id)
    {
        PerfilDispositivo? perfil = perfilesDispositivo
            .FirstOrDefault(item => item.Id == id);

        if (perfil is null)
        {
            return;
        }

        perfilEditandoId = perfil.Id;
        nombrePerfil = perfil.Nombre;
        descripcionPerfil = perfil.Descripcion;
        errorPerfil = string.Empty;
        mostrarFormularioPerfil = true;
        perfilConfirmarEliminacionId = null;
    }

    private async Task GuardarPerfilActualAsync()
    {
        string nombre = nombrePerfil.Trim();

        if (string.IsNullOrWhiteSpace(nombre))
        {
            errorPerfil = "Escribe un nombre para el perfil.";
            return;
        }

        try
        {
            PerfilDispositivo perfil;

            if (PerfilEnEdicion is { } existente)
            {
                perfil = CrearCopiaPerfil(existente);
                perfil.Nombre = nombre;
                perfil.Descripcion = descripcionPerfil.Trim();
            }
            else
            {
                perfil = CrearPerfilDesdeSesion(
                    SesionActiva,
                    nombre,
                    descripcionPerfil.Trim()
                );
            }

            await PerfilDispositivoService.GuardarAsync(perfil);

            perfilesDispositivo =
                PerfilDispositivoService.ObtenerPerfiles();

            mensajeEstado = $"Perfil '{perfil.Nombre}' guardado.";
            mostrarFormularioPerfil = false;
            perfilEditandoId = null;
            errorPerfil = string.Empty;
        }
        catch (Exception ex)
        {
            errorPerfil = $"No fue posible guardar el perfil: {ex.Message}";
        }
    }

    private async Task CargarPerfilAsync(Guid id)
    {
        PerfilDispositivo? perfil = perfilesDispositivo
            .FirstOrDefault(item => item.Id == id);

        if (perfil is null)
        {
            return;
        }

        TipoSesion tipo = EsPerfilModbus(perfil)
            ? TipoSesion.ModbusRtu
            : TipoSesion.Serial;

        TerminalSesion sesionActual = SesionActiva;

        if (sesionActual.PollingModbusActivo)
        {
            await DetenerPollingModbusAsync(
                sesionActual,
                registrarMensaje: false
            );
        }

        bool reutilizarSesion =
            sesionActual.Tipo == tipo &&
            !sesionActual.Servicio.EstaConectado &&
            !sesionActual.ConsultaModbusEnCurso &&
            !sesionActual.RegistroCsvActivo;

        TerminalSesion destino;

        if (reutilizarSesion)
        {
            destino = sesionActual;
        }
        else
        {
            destino = CrearSesion(tipo);
            sesiones.Add(destino);
            sesionActivaId = destino.Id;
            terminalElement = default;
        }

        ActualizarPuertos(destino);
        AplicarPerfil(destino, perfil);

        destino.Nombre = perfil.Nombre;
        destino.PestanaPanel = "puerto";
        destino.MostrarListaPuertos = false;

        bool puertoEncontrado =
            string.IsNullOrWhiteSpace(perfil.PuertoPreferido) ||
            destino.Puertos.Contains(
                perfil.PuertoPreferido,
                StringComparer.OrdinalIgnoreCase
            );

        destino.MensajeEstado = puertoEncontrado
            ? $"Perfil '{perfil.Nombre}' cargado. Presiona Conectar para iniciar."
            : $"Perfil '{perfil.Nombre}' cargado, pero {perfil.PuertoPreferido} no está disponible.";

        AgregarLineaTerminal(
            destino,
            "SYS",
            $"Perfil de dispositivo cargado: {perfil.Nombre}."
        );

        CerrarModalPerfiles();
    }

